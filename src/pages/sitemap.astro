---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// ─────────── Gather data ───────────
const allNotes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Site structure — hand-curated for editorial framing.
// Each entry: title, href, deck (a one-line description), section.
type SiteEntry = {
  roman: string;
  title: string;
  href: string;
  deck: string;
  meta?: string;
};

const sections: { id: string; label: string; entries: SiteEntry[] }[] = [
  {
    id: '01',
    label: 'The office',
    entries: [
      {
        roman: 'i.',
        title: 'Home',
        href: '/',
        deck: 'The masthead. The morning record.',
        meta: 'The first page anyone meets',
      },
      {
        roman: 'ii.',
        title: 'About',
        href: '/about',
        deck: 'Who works here. How the office is run. What it believes.',
      },
      {
        roman: 'iii.',
        title: 'Contact',
        href: '/contact',
        deck: 'Four honest ways to write to the desk.',
      },
    ],
  },
  {
    id: '02',
    label: 'The tools',
    entries: [
      {
        roman: 'i.',
        title: 'Build a Data Story',
        href: '/build',
        deck: 'A guided workshop. Five questions, two public datasets, one headline you did not have yesterday.',
        meta: 'Free · No signup · Yours to keep',
      },
      {
        roman: 'ii.',
        title: 'Earned Media Skills',
        href: '/skills',
        deck: 'Twenty-eight open-source markdown skills your AI agent can read. Pitch craft, journalist research, the humanizer.',
        meta: 'MIT licensed · GitHub: 701am/earned-media-skills',
      },
    ],
  },
  {
    id: '03',
    label: 'The industries',
    entries: [
      {
        roman: 'i.',
        title: 'Industries',
        href: '/industries',
        deck: 'Where the office is open, one vertical at a time. The method does not bend; the angle always does.',
        meta: 'The hub',
      },
      {
        roman: 'ii.',
        title: 'Healthcare',
        href: '/industries/healthcare',
        deck: 'For the providers, staffing firms, payers, and health-tech companies the sector has to trust. Trust is earned in print, long before the contract.',
      },
      {
        roman: 'iii.',
        title: 'Higher Education',
        href: '/industries/higher-education',
        deck: 'For colleges, EdTech companies, and enrolment partners fighting to be remembered through the cliff. We mine your outcomes data for the angle.',
      },
      {
        roman: 'iv.',
        title: 'B2B',
        href: '/industries/b2b',
        deck: 'Your buyer reads about you before they reply to you. We turn proprietary data into the benchmark that makes the sector quote you first.',
      },
      {
        roman: 'v.',
        title: 'Startups',
        href: '/industries/startup',
        deck: 'You can\'t outspend the incumbents — you can out-story them. We turn the founder story and the traction into press that recruits, raises, and sells.',
      },
      {
        roman: 'vi.',
        title: 'AI',
        href: '/industries/ai',
        deck: 'Everyone says they\'re AI now. We find the result you can defend and place it where the serious press reads, so the market learns who means it.',
      },
      {
        roman: 'vii.',
        title: 'Consumer Services',
        href: '/industries/consumer-services',
        deck: 'Home, fitness, finance, wellness — categories where the recognised name wins. We mine your customer data for the trend an editor is already chasing.',
      },
      {
        roman: 'viii.',
        title: 'Fashion Brands',
        href: '/industries/fashion-brands',
        deck: 'The brands that endure aren\'t the loudest — they\'re the ones with a story editors want to tell. We earn the editorial credibility a campaign can\'t buy.',
      },
    ],
  },
  {
    id: '04',
    label: 'The field manual',
    entries: [
      {
        roman: 'i.',
        title: 'The Scroll',
        href: '/legend-maker',
        deck: 'The Legend-Maker — the full earned-media method, written down in long form. The same playbook the office uses, given away.',
        meta: 'Approx. 35 min read',
      },
    ],
  },
  {
    id: '05',
    label: 'The work',
    entries: [
      {
        roman: 'i.',
        title: 'Sunrise discovery call',
        href: '/discovery',
        deck: 'Thirty minutes. No deck. No pitch. No charge. We listen to the shape of your business and tell you, plainly, whether earned media can move it.',
      },
    ],
  },
];

// Topic taxonomy counts
const topicCounts = new Map<string, number>();
for (const note of allNotes) {
  topicCounts.set(note.data.topic, (topicCounts.get(note.data.topic) || 0) + 1);
}

// ─────────── Header values ───────────
const today = new Date();
const days = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const todayLabel = `${days[today.getDay()]} · ${today.getDate()} ${months[today.getMonth()]} ${today.getFullYear()}`;

const totalPages = sections.reduce((s, sec) => s + sec.entries.length, 0) + allNotes.length;
const totalDispatches = allNotes.length;

const monthLong = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout
  title="Archive — every page of the record · 701am"
  description="The complete index of 701am: tools, dispatches, field manual, and the office. Every page in the record, sectioned and dated."
  pageType="collectionPage"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Archive' },
  ]}
>

  <main class="sm">

    <!-- ════════════════════════════════════════════════════════════
         MASTHEAD
         ════════════════════════════════════════════════════════════ -->
    <header class="sm-mast">
      <p class="sm-mast-eyebrow">
        <span class="sm-mast-rule"></span>
        ★ The office archive ★
        <span class="sm-mast-rule"></span>
      </p>
      <h1 class="sm-mast-h">
        A complete index<br />
        of <em>the record.</em>
      </h1>
      <p class="sm-mast-deck">
        Every page filed under 701am, ordered by purpose. <em>Dispatches, tools, the field manual, the office itself.</em>
      </p>

      <ul class="sm-mast-meta">
        <li><span class="sm-mast-num">{totalPages}</span> <span class="sm-mast-label">pages in the record</span></li>
        <li><span class="sm-mast-num">{totalDispatches}</span> <span class="sm-mast-label">dispatches filed</span></li>
        <li><span class="sm-mast-num">{sections.length}</span> <span class="sm-mast-label">sections of the office</span></li>
      </ul>

      <p class="sm-mast-stamp">
        Filed at sunrise · {todayLabel} · Compiled on every deploy
      </p>
    </header>

    <!-- ════════════════════════════════════════════════════════════
         QUICK LINKS (machines + humans)
         ════════════════════════════════════════════════════════════ -->
    <section class="sm-quick" aria-label="Quick references">
      <p class="sm-quick-label">For the hurried:</p>
      <ul class="sm-quick-list">
        <li><a href="/">Home</a></li>
        <li><a href="/build">Build a Data Story</a></li>
        <li><a href="/skills">Skills</a></li>
        <li><a href="/legend-maker">The Scroll</a></li>
        <li><a href="/notes">All dispatches</a></li>
        <li><a href="/discovery">Discovery call</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </section>

    <!-- ════════════════════════════════════════════════════════════
         CURATED SECTIONS — the hand-organized site map
         ════════════════════════════════════════════════════════════ -->
    {sections.map((section) => (
      <section class="sm-section" id={`section-${section.id}`}>
        <header class="sm-section-head">
          <p class="sm-section-label">§ {section.id} · {section.label}</p>
          <span class="sm-section-count">{section.entries.length} {section.entries.length === 1 ? 'entry' : 'entries'}</span>
        </header>

        <ol class="sm-list">
          {section.entries.map((entry) => (
            <li class="sm-row">
              <span class="sm-row-num">{entry.roman}</span>
              <a class="sm-row-title" href={entry.href}>
                <span class="sm-row-title-text">{entry.title}</span>
                <span class="sm-row-arrow" aria-hidden="true">→</span>
              </a>
              <span class="sm-row-href">{entry.href}</span>
              <p class="sm-row-deck">{entry.deck}</p>
              {entry.meta && <p class="sm-row-meta">{entry.meta}</p>}
            </li>
          ))}
        </ol>
      </section>
    ))}

    <!-- ════════════════════════════════════════════════════════════
         § 05 — DISPATCHES (auto-generated from content collection)
         ════════════════════════════════════════════════════════════ -->
    <section class="sm-section sm-section--dispatches" id="section-dispatches">
      <header class="sm-section-head">
        <p class="sm-section-label">§ 05 · The dispatches</p>
        <span class="sm-section-count">{allNotes.length} {allNotes.length === 1 ? 'entry' : 'entries'}</span>
      </header>

      <ol class="sm-list sm-list--compact">
        {allNotes.map((note, i) => {
          const romans = ['i.','ii.','iii.','iv.','v.','vi.','vii.','viii.','ix.','x.','xi.','xii.'];
          const roman = romans[i] || `${i + 1}.`;
          return (
            <li class="sm-row sm-row--dispatch">
              <span class="sm-row-num">{roman}</span>
              <a class="sm-row-title" href={`/notes/${note.id}`}>
                <span class="sm-row-num-stamp">№ {String(note.data.number).padStart(3, '0')}</span>
                <span class="sm-row-title-text">{note.data.title}</span>
                <span class="sm-row-arrow" aria-hidden="true">→</span>
              </a>
              <span class="sm-row-href">/notes/{note.id}</span>
              <p class="sm-row-deck">{note.data.deck}</p>
              <p class="sm-row-meta">
                Filed {monthLong(note.data.date)}
                {' · '}
                {note.data.topic}
                {note.data.readingTime && <> {' · '} {note.data.readingTime} read</>}
              </p>
            </li>
          );
        })}
      </ol>

      <!-- Topic taxonomy -->
      {topicCounts.size > 0 && (
        <div class="sm-taxonomy">
          <p class="sm-taxonomy-label">Filed under</p>
          <ul class="sm-taxonomy-list">
            {Array.from(topicCounts.entries()).sort((a, b) => b[1] - a[1]).map(([topic, count]) => (
              <li>
                <span class="sm-tax-name">{topic}</span>
                <span class="sm-tax-count">{count}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <!-- ════════════════════════════════════════════════════════════
         § 06 — FOR MACHINES
         ════════════════════════════════════════════════════════════ -->
    <section class="sm-section sm-section--machines" id="section-machines">
      <header class="sm-section-head">
        <p class="sm-section-label">§ 06 · For machines</p>
        <span class="sm-section-count">Discovery endpoints</span>
      </header>

      <p class="sm-machines-deck">
        Everything below is for the crawlers, indexers, and AI agents that read the office. Humans are welcome too.
      </p>

      <ul class="sm-machines">
        <li>
          <a href="/sitemap-index.xml">
            <span class="sm-mach-name">XML sitemap index</span>
            <span class="sm-mach-path">/sitemap-index.xml</span>
            <span class="sm-mach-desc">The machine-readable sitemap with priorities, change frequencies, and git-derived lastmod dates.</span>
          </a>
        </li>
        <li>
          <a href="/rss.xml">
            <span class="sm-mach-name">RSS feed</span>
            <span class="sm-mach-path">/rss.xml</span>
            <span class="sm-mach-desc">Every dispatch, in full, syndicated. Subscribe in any feed reader.</span>
          </a>
        </li>
        <li>
          <a href="/llms.txt">
            <span class="sm-mach-name">llms.txt</span>
            <span class="sm-mach-path">/llms.txt</span>
            <span class="sm-mach-desc">A machine-readable summary of the site, written for AI agents and language models.</span>
          </a>
        </li>
        <li>
          <a href="/robots.txt">
            <span class="sm-mach-name">robots.txt</span>
            <span class="sm-mach-path">/robots.txt</span>
            <span class="sm-mach-desc">The crawler policy. Open to search engines and reputable AI training crawlers.</span>
          </a>
        </li>
        <li>
          <span class="sm-mach-inline">
            <span class="sm-mach-name">Markdown alternates</span>
            <span class="sm-mach-path">/notes/&lt;slug&gt;.md</span>
            <span class="sm-mach-desc">Every dispatch is also served as raw markdown for AI agents that prefer it. Set <code>Accept: text/markdown</code>, or append <code>.md</code> directly.</span>
          </span>
        </li>
      </ul>
    </section>

    <!-- ════════════════════════════════════════════════════════════
         COLOPHON
         ════════════════════════════════════════════════════════════ -->
    <footer class="sm-coda">
      <p class="sm-coda-stamp">★ Colophon ★</p>
      <p class="sm-coda-p">
        This index is regenerated on every deploy from the source files in the office.
        Dates are derived from git history; structure is hand-curated.
        If you find a page that should be in the record but isn't,
        <a href="/contact">write to the desk</a>.
      </p>
      <p class="sm-coda-sig">— The desk at 701am · Filed at sunrise, in perpetuity</p>
    </footer>

  </main>

</BaseLayout>

<style is:global>
  /* ═══════════════════════════════════════════════════════════════════
     /sitemap — the HTML sitemap
     Editorial archive treatment in the 701am salmon-FT palette
     ═══════════════════════════════════════════════════════════════════ */

  .sm {
    background: var(--paper);
    padding: var(--x1) var(--x1) var(--x1);
    max-width: 68rem;
    margin: 0 auto;
  }

  /* ─────────── MASTHEAD ─────────── */
  .sm-mast {
    text-align: center;
    padding: calc(var(--x1) + var(--x2)) var(--x3) var(--x1);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--x1);
  }
  .sm-mast-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    margin: 0 0 var(--x2);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.30em;
    color: var(--claret);
    text-transform: uppercase;
  }
  .sm-mast-rule {
    display: inline-block;
    width: 42px;
    height: 1px;
    background: var(--claret);
    opacity: 0.55;
  }
  .sm-mast-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 var(--x2);
    text-wrap: balance;
  }
  .sm-mast-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .sm-mast-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.125rem, 2vw, 1.4rem);
    line-height: 1.45;
    color: var(--ink-soft);
    max-width: 44ch;
    margin: 0 auto var(--x1);
    text-wrap: balance;
  }
  .sm-mast-deck em { color: var(--claret); font-style: italic; }

  .sm-mast-meta {
    list-style: none;
    display: inline-flex;
    align-items: baseline;
    gap: var(--x1);
    margin: var(--x1) 0 var(--x3);
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sm-mast-meta li {
    display: inline-flex;
    align-items: baseline;
    gap: var(--x5);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--ink-faint);
    font-size: 14px;
  }
  .sm-mast-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 2.5rem;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .sm-mast-label { line-height: 1.2; }

  .sm-mast-stamp {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    margin: var(--x4) 0 0;
  }

  /* ─────────── QUICK LINKS ─────────── */
  .sm-quick {
    background: var(--paper-soft);
    border: 1px solid var(--rule);
    padding: var(--x4) var(--x3);
    margin: 0 auto var(--x1);
    display: flex;
    align-items: center;
    gap: var(--x3);
    flex-wrap: wrap;
    max-width: 64rem;
  }
  .sm-quick-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.26em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
    flex-shrink: 0;
  }
  .sm-quick-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--x4);
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }
  .sm-quick-list li {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 15px;
  }
  .sm-quick-list a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .sm-quick-list a:hover {
    color: var(--claret);
    border-bottom-color: var(--claret);
  }

  /* ─────────── SECTION ─────────── */
  .sm-section {
    padding: calc(var(--x1) + var(--x3)) 0 var(--x1);
    border-top: 1px solid var(--rule);
  }
  .sm-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--x3);
    margin-bottom: var(--x2);
    padding: 0 var(--x3);
  }
  .sm-section-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
  }
  .sm-section-count {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--ink-fainter);
    font-size: 13px;
    font-variant-numeric: oldstyle-nums;
  }

  /* ─────────── LIST + ROWS ─────────── */
  .sm-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sm-row {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    grid-template-areas:
      "num title href"
      "num deck deck"
      "num meta meta";
    gap: 4px var(--x3);
    padding: var(--x3) var(--x3);
    border-bottom: 1px solid var(--rule);
    transition: background 0.2s ease;
  }
  .sm-row:last-child { border-bottom: none; }
  .sm-row:hover { background: var(--paper-soft); }
  .sm-row:hover .sm-row-arrow { transform: translateX(4px); color: var(--claret); }

  .sm-row-num {
    grid-area: num;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    color: var(--claret);
    font-size: 1.625rem;
    line-height: 1.1;
    font-variant-numeric: oldstyle-nums;
    letter-spacing: -0.02em;
  }
  .sm-row-title {
    grid-area: title;
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .sm-row-title-text {
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .sm-row-title:hover .sm-row-title-text {
    color: var(--claret);
    border-bottom-color: var(--claret);
  }
  .sm-row-arrow {
    color: var(--ink-fainter);
    font-size: 1.25rem;
    line-height: 1;
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .sm-row-href {
    grid-area: href;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    font-size: 11px;
    color: var(--ink-fainter);
    letter-spacing: 0.04em;
    align-self: center;
    white-space: nowrap;
  }
  .sm-row-deck {
    grid-area: deck;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 4px 0 0;
    max-width: 60ch;
  }
  .sm-row-meta {
    grid-area: meta;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    margin: 4px 0 0;
  }

  /* Dispatch-specific styling */
  .sm-row--dispatch .sm-row-title { font-size: 1.25rem; }
  .sm-row-num-stamp {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-size: 13px;
    font-variant-numeric: oldstyle-nums;
    border-right: 1px solid var(--rule-strong);
    padding-right: 10px;
    margin-right: 2px;
    line-height: 1.4;
  }

  /* ─────────── TAXONOMY ─────────── */
  .sm-taxonomy {
    margin: var(--x2) var(--x3) 0;
    padding: var(--x3) 0 0;
    border-top: 1px solid var(--rule);
  }
  .sm-taxonomy-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x4);
  }
  .sm-taxonomy-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--x4);
    margin: 0;
    padding: 0;
  }
  .sm-taxonomy-list li {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 6px 14px;
    background: var(--paper-soft);
    border: 1px solid var(--rule);
  }
  .sm-tax-name {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--ink);
    font-size: 14px;
  }
  .sm-tax-count {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
