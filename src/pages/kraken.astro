<script>
  // ═══════════════════════════════════════════════════════════════════
  // KRAKEN — client orchestration
  // ═══════════════════════════════════════════════════════════════════

  const app = document.querySelector('[data-kraken-app]');
  if (app) {
    const stages = {
      input: app.querySelector('[data-stage="input"]'),
      loading: app.querySelector('[data-stage="loading"]'),
      report: app.querySelector('[data-stage="report"]'),
      error: app.querySelector('[data-stage="error"]'),
    };
    const form = app.querySelector('[data-kr-form]');
    const textarea = app.querySelector('#kr-input') as HTMLTextAreaElement;
    const counter = app.querySelector('[data-kr-counter]');
    const submit = app.querySelector('[data-kr-submit]');
    const retry = app.querySelector('[data-kr-retry]');
    const errMsg = app.querySelector('[data-kr-error-msg]');

    function showStage(name) {
      Object.entries(stages).forEach(([k, el]) => {
        if (el) (el as HTMLElement).hidden = k !== name;
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Character counter
    if (textarea && counter) {
      textarea.addEventListener('input', () => {
        counter.textContent = `${textarea.value.length} / 800`;
      });
    }

    // Loading stage controller
    const STEPS = [
      { key: 'research', label: 'Pulling recent coverage', estMs: 8000 },
      { key: 'ideate', label: 'Running 5 interpretive lenses', estMs: 14000 },
      { key: 'cluster', label: 'Clustering 50 framings', estMs: 1000 },
      { key: 'synthesize', label: 'Ranking by editorial success value', estMs: 18000 },
      { key: 'render', label: 'Drafting the report', estMs: 2000 },
    ];
    const stageLabel = app.querySelector('[data-kr-loading-stage]');
    const stageDetail = app.querySelector('[data-kr-loading-detail]');

    function setStep(key) {
      app.querySelectorAll('[data-kr-step]').forEach((el) => {
        const stepKey = el.getAttribute('data-kr-step');
        el.classList.remove('is-active', 'is-done');
        const stepIdx = STEPS.findIndex((s) => s.key === stepKey);
        const activeIdx = STEPS.findIndex((s) => s.key === key);
        if (stepIdx < activeIdx) el.classList.add('is-done');
        else if (stepIdx === activeIdx) el.classList.add('is-active');
      });
      const step = STEPS.find((s) => s.key === key);
      if (step && stageLabel) {
        stageLabel.textContent = step.label + '…';
      }
    }

    // Run the full Kraken pipeline
    async function runKraken(input) {
      showStage('loading');

      try {
        // 1. Research
        setStep('research');
        const researchRes = await fetch('/api/kraken-research', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ input }),
        });
        if (!researchRes.ok) {
          const e = await researchRes.json().catch(() => ({}));
          throw new Error(e.error || 'Research failed');
        }
        const research = await researchRes.json();

        // 2. Ideate (5 parallel calls server-side)
        setStep('ideate');
        const ideateRes = await fetch('/api/kraken-ideate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            input,
            coverageBrief: research.coverageBrief,
          }),
        });
        if (!ideateRes.ok) {
          const e = await ideateRes.json().catch(() => ({}));
          throw new Error(e.error || 'Ideation failed');
        }
        const ideation = await ideateRes.json();

        // 3+4. Cluster + synthesize
        setStep('cluster');
        await new Promise((r) => setTimeout(r, 600));
        setStep('synthesize');
        const synthRes = await fetch('/api/kraken-synthesize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            input,
            framings: ideation.framings,
            coverageBrief: research.coverageBrief,
          }),
        });
        if (!synthRes.ok) {
          const e = await synthRes.json().catch(() => ({}));
          throw new Error(e.error || 'Synthesis failed');
        }
        const { report } = await synthRes.json();

        // 5. Render
        setStep('render');
        await new Promise((r) => setTimeout(r, 400));
        renderReport(report);
        showStage('report');

      } catch (err) {
        if (errMsg) errMsg.textContent = err.message || 'Unknown error';
        showStage('error');
      }
    }

    // Render the report into the DOM
    function renderReport(report) {
      const tpl = document.querySelector('#kr-report-template');
      if (!tpl) return;
      const reportStage = stages.report;
      if (!reportStage) return;

      // Clone template
      reportStage.innerHTML = '';
      reportStage.appendChild((tpl as HTMLTemplateElement).content.cloneNode(true));

      // Header
      const inputEcho = reportStage.querySelector('[data-kr-input-echo]');
      if (inputEcho) inputEcho.textContent = report.input_echo || '—';

      const stampEl = reportStage.querySelector('[data-kr-stamp]');
      if (stampEl) {
        const today = new Date();
        const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        stampEl.textContent = `Filed at sunrise · ${days[today.getDay()]} · ${today.getDate()} ${months[today.getMonth()]} ${today.getFullYear()}`;
      }

      // Cluster map
      const distEl = reportStage.querySelector('[data-kr-distribution]');
      if (distEl && report.cluster_map?.narrative_distribution_note) {
        distEl.textContent = report.cluster_map.narrative_distribution_note;
      }

      renderBubbleChart(reportStage, report.cluster_map?.attractors || []);
      renderAttractorList(reportStage, report.cluster_map?.attractors || []);

      renderStories(reportStage, report.top_stories || []);
      renderPitches(reportStage, report.top_pitches || []);
      renderHeadlines(reportStage, report.top_headlines || []);
      renderInsights(reportStage, report.top_insights || []);
      renderPlacements(reportStage, report.top_placements || []);

      // Wire actions
      const printBtn = reportStage.querySelector('[data-kr-print]');
      if (printBtn) printBtn.addEventListener('click', () => window.print());
      const restartBtn = reportStage.querySelector('[data-kr-restart]');
      if (restartBtn) restartBtn.addEventListener('click', () => {
        if (textarea) textarea.value = '';
        if (counter) counter.textContent = '0 / 800';
        showStage('input');
      });
    }

    // SVG bubble chart for cluster map
    function renderBubbleChart(root, attractors) {
      const host = root.querySelector('[data-kr-bubble-chart]');
      if (!host || !attractors.length) return;

      const W = 760, H = 320;
      const padX = 40, padY = 30;
      const cols = 5, rows = 2;
      const cellW = (W - padX * 2) / cols;
      const cellH = (H - padY * 2) / rows;

      const weights = attractors.map((a) => a.weight || a.esv || 0.5);
      const maxW = Math.max(...weights);
      const minR = 22, maxR = 50;

      let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" aria-label="Cluster map">`;
      attractors.slice(0, 10).forEach((a, i) => {
        const col = i % cols;
        const row = Math.floor(i / cols);
        const cx = padX + cellW * col + cellW / 2;
        const cy = padY + cellH * row + cellH / 2;
        const w = a.weight || a.esv || 0.5;
        const r = minR + ((w / maxW) * (maxR - minR));
        const opacity = 0.55 + ((w / maxW) * 0.4);
        const labelY = cy + r + 14;
        const label = (a.label || '').slice(0, 22);
        svg += `<g class="kr-bubble" opacity="${opacity.toFixed(2)}">
          <circle cx="${cx}" cy="${cy}" r="${r}" fill="var(--claret)" />
          <text class="kr-bubble-rank" x="${cx}" y="${cy}">${a.rank || i + 1}</text>
          <text class="kr-bubble-label" x="${cx}" y="${labelY}">${escapeHtml(label)}</text>
        </g>`;
      });
      svg += '</svg>';
      host.innerHTML = svg;
    }

    function renderAttractorList(root, attractors) {
      const host = root.querySelector('[data-kr-attractor-list]');
      if (!host) return;
      host.innerHTML = attractors.map((a) => `
        <li class="kr-attractor-row">
          <span class="kr-attractor-rank">${a.rank}.</span>
          <span class="kr-attractor-label">${escapeHtml(a.label || '')}</span>
          <span class="kr-attractor-esv">ESV <em>${(a.esv || 0).toFixed(2)}</em></span>
          <span class="kr-attractor-sat" data-sat="${a.saturation_risk || 'medium'}">${a.saturation_risk || '—'}</span>
        </li>
      `).join('');
    }

    function renderStories(root, stories) {
      const host = root.querySelector('[data-kr-stories]');
      if (!host) return;
      host.innerHTML = stories.map((s) => `
        <li class="kr-story">
          <span class="kr-item-rank">${s.rank}.</span>
          <div class="kr-story-body">
            <h4 class="kr-story-title">${escapeHtml(s.story_title || '')}</h4>
            <p class="kr-story-headline">${escapeHtml(s.example_headline || '')}</p>
            <dl class="kr-story-meta">
              <dt>Frame</dt><dd>${escapeHtml(s.frame || '')}</dd>
              <dt>Hook</dt><dd>${escapeHtml(s.core_hook || '')}</dd>
              <dt>Survives because</dt><dd>${escapeHtml(s.survives_filter_because || '')}</dd>
              <dt>Audience</dt><dd>${escapeHtml(s.audience_resonance || '')}</dd>
              <dt>Tier</dt><dd>${escapeHtml(s.publication_tier_likelihood || '')}</dd>
            </dl>
            <a class="kr-story-cta" href="/build?angle=${encodeURIComponent(s.story_title || '')}">
              Refine this in /build <span aria-hidden="true">→</span>
            </a>
          </div>
        </li>
      `).join('');
    }

    function renderPitches(root, pitches) {
      const host = root.querySelector('[data-kr-pitches]');
      if (!host) return;
      host.innerHTML = pitches.map((p) => `
        <li class="kr-pitch">
          <span class="kr-item-rank">${p.rank}.</span>
          <div>
            <p class="kr-pitch-subject">${escapeHtml(p.subject_line || '')}</p>
            <div class="kr-pitch-body">${escapeHtml(p.body || '').replace(/\n/g, '<br/>')}</div>
            <p class="kr-pitch-frame">${escapeHtml(p.implied_frame || '')}</p>
          </div>
        </li>
      `).join('');
    }

    function renderHeadlines(root, headlines) {
      const host = root.querySelector('[data-kr-headlines]');
      if (!host) return;
      host.innerHTML = headlines.map((h) => `
        <li class="kr-headline-set">
          <span class="kr-item-rank">${h.rank}.</span>
          <div>
            <p class="kr-headline-cluster">Cluster ${h.cluster_id || h.rank}</p>
            <ol class="kr-headline-variations">
              ${(h.variations || []).map((v) => `<li>${escapeHtml(v)}</li>`).join('')}
            </ol>
            ${h.format_notes ? `<p class="kr-headline-notes">${escapeHtml(h.format_notes)}</p>` : ''}
          </div>
        </li>
      `).join('');
    }

    function renderInsights(root, insights) {
      const host = root.querySelector('[data-kr-insights]');
      if (!host) return;
      host.innerHTML = insights.map((i) => `
        <li class="kr-insight">
          <span class="kr-item-rank">${i.rank}.</span>
          <div>
            <p class="kr-insight-type">${escapeHtml(i.type || '—')}</p>
            <p class="kr-insight-body">${escapeHtml(i.insight || '')}</p>
            ${i.why_it_feels_revealed ? `<p class="kr-insight-why">${escapeHtml(i.why_it_feels_revealed)}</p>` : ''}
          </div>
        </li>
      `).join('');
    }

    function renderPlacements(root, placements) {
      const host = root.querySelector('[data-kr-placements]');
      if (!host) return;
      host.innerHTML = placements.map((p) => `
        <li class="kr-placement">
          <span class="kr-item-rank">${p.rank}.</span>
          <div>
            <h4 class="kr-placement-archetype">${escapeHtml(p.outlet_archetype || '')}</h4>
            <p class="kr-placement-outlets">${(p.specific_outlets || []).map(escapeHtml).join(' · ')}</p>
            <p class="kr-placement-shift">${escapeHtml(p.framing_adjustment || '')}</p>
            <p class="kr-placement-fit">Fit score<em>${(p.fit_score || 0).toFixed(2)}</em></p>
          </div>
        </li>
      `).join('');
    }

    function escapeHtml(s) {
      if (s == null) return '';
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // Submit handler
    if (form && textarea && submit) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const val = textarea.value.trim();
        if (val.length < 8) {
          textarea.focus();
          return;
        }
        runKraken(val);
      });
    }

    // Retry
    if (retry) {
      retry.addEventListener('click', () => {
        showStage('input');
      });
    }
  }
</script>
