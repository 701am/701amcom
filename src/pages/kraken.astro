---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Kraken — The Newsroom Prediction Engine · 701am"
  description="Drop a dataset, event, organization, or trend. The Kraken runs 50 framings through 5 interpretive lenses, clusters them into 10 stable attractors, and predicts the stories most likely to be published. A free Monte Carlo newsroom simulator from 701am."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Kraken' },
  ]}
>

  <main class="kraken" data-kraken-app>

    <!-- ════════════════════════════════════════════════════════════
         STAGE 1 — INPUT
         ════════════════════════════════════════════════════════════ -->
    <section class="kr-stage kr-stage--input" data-stage="input">

      <header class="kr-mast">
        <p class="kr-mast-eyebrow">
          <span class="kr-mast-rule"></span>
          A free Monte Carlo prediction engine
          <span class="kr-mast-rule"></span>
        </p>

        <!-- The Kraken sigil -->
        <div class="kr-sigil" aria-hidden="true">
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer ring -->
            <circle cx="60" cy="60" r="56" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
            <circle cx="60" cy="60" r="50" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.5" stroke-dasharray="2 4"/>
            <!-- Eye in the center -->
            <ellipse cx="60" cy="60" rx="22" ry="12" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="60" cy="60" r="6" fill="currentColor"/>
            <circle cx="58" cy="58" r="1.6" fill="var(--paper)"/>
            <!-- Tentacles radiating out -->
            <path d="M 60 38 Q 56 26, 62 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 78 48 Q 92 42, 102 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 82 60 Q 100 60, 116 56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 78 72 Q 92 78, 102 90" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 60 82 Q 56 94, 62 106" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 42 72 Q 28 78, 18 90" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 38 60 Q 20 60, 4 56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 42 48 Q 28 42, 18 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>

        <h1 class="kr-mast-h">
          The <em>Kraken.</em>
        </h1>
        <p class="kr-mast-sub">
          The Newsroom Prediction Engine.
        </p>

        <p class="kr-mast-deck">
          Drop a dataset, organization, event, or trend. The Kraken runs <em>50 narrative framings</em> through five interpretive lenses, clusters them into <em>10 stable attractors</em>, and predicts the stories most likely to emerge from a real newsroom.
        </p>

        <p class="kr-mast-stats">
          <span><em>5</em> interpretive lenses</span>
          <span class="kr-mast-stat-sep">·</span>
          <span><em>50</em> parallel framings</span>
          <span class="kr-mast-stat-sep">·</span>
          <span><em>10</em> ranked attractors</span>
          <span class="kr-mast-stat-sep">·</span>
          <span><em>6</em>-section report</span>
        </p>
      </header>

      <!-- The input form -->
      <form class="kr-form" data-kr-form>
        <label class="kr-form-label" for="kr-input">
          <span class="kr-form-label-text">★ The input</span>
          <span class="kr-form-label-meta">A dataset, an organization, an event, or a one-line phenomenon</span>
        </label>

        <textarea
          id="kr-input"
          class="kr-textarea"
          name="input"
          rows="5"
          maxlength="800"
          placeholder="Example: A 60-employee fintech in São Paulo serving small businesses, growing 40% YoY, no press coverage. — or — The U.S. Census household pulse survey showing remote work declining in 2026. — or — Anything from one sentence to three paragraphs."
          required
        ></textarea>

        <div class="kr-form-foot">
          <p class="kr-form-counter" data-kr-counter>0 / 800</p>
          <button type="submit" class="kr-submit" data-kr-submit>
            <span class="kr-submit-text">Release the Kraken</span>
            <span class="kr-submit-arrow" aria-hidden="true">→</span>
          </button>
        </div>
      </form>

      <!-- The methodology note -->
      <details class="kr-method">
        <summary class="kr-method-summary">How the Kraken works <span aria-hidden="true">↓</span></summary>
        <div class="kr-method-body">
          <ol>
            <li><strong>Coverage research.</strong> The Kraken first pulls recent press coverage and dataset references about your input. This grounds the predictions in what has actually been written.</li>
            <li><strong>Five lens passes.</strong> Five parallel calls — each carrying a different interpretive lens (economic, cultural, structural, behavioral, technological) — generate <em>10 distinct framings</em> apiece. <em>50 framings total.</em></li>
            <li><strong>Clustering.</strong> The 50 framings are clustered into the 10 strongest <em>narrative attractors</em> — the stable gravity wells that emerge from the simulation.</li>
            <li><strong>Editorial Success Value.</strong> Each cluster is scored on clarity, novelty against saturation, emotional activation, cross-audience appeal, diffusion potential, rejection resistance, and evidence groundability.</li>
            <li><strong>Six-section report.</strong> The top clusters are expanded into a complete report: cluster map, top 10 stories, top 10 pitches, top 10 headlines, top 10 insights, and top 10 publication targets.</li>
          </ol>
          <p class="kr-method-cost">Total runtime: ~45 seconds. Total cost to 701am: about three cents.<br /><em>The Kraken is free. The cost is ours. The output is yours.</em></p>
        </div>
      </details>

    </section>

    <!-- ════════════════════════════════════════════════════════════
         STAGE 2 — LOADING THEATER
         ════════════════════════════════════════════════════════════ -->
    <section class="kr-stage kr-stage--loading" data-stage="loading" hidden>
      <div class="kr-loading">
        <div class="kr-loading-sigil" aria-hidden="true">
          <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="60" r="56" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
            <circle cx="60" cy="60" r="50" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.5" stroke-dasharray="2 4" class="kr-spin"/>
            <ellipse cx="60" cy="60" rx="22" ry="12" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="60" cy="60" r="6" fill="currentColor"/>
            <circle cx="58" cy="58" r="1.6" fill="var(--paper)"/>
            <path d="M 60 38 Q 56 26, 62 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 78 48 Q 92 42, 102 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 82 60 Q 100 60, 116 56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 78 72 Q 92 78, 102 90" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 60 82 Q 56 94, 62 106" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 42 72 Q 28 78, 18 90" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 38 60 Q 20 60, 4 56" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M 42 48 Q 28 42, 18 30" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="kr-loading-stage" data-kr-loading-stage>The Kraken is waking</p>
        <p class="kr-loading-detail" data-kr-loading-detail>This usually takes about 45 seconds</p>

        <div class="kr-loading-pipeline" aria-hidden="true">
          <ol>
            <li data-kr-step="research"><span class="kr-step-num">i.</span> Pulling recent coverage</li>
            <li data-kr-step="ideate"><span class="kr-step-num">ii.</span> Running 5 interpretive lenses</li>
            <li data-kr-step="cluster"><span class="kr-step-num">iii.</span> Clustering 50 framings</li>
            <li data-kr-step="synthesize"><span class="kr-step-num">iv.</span> Ranking by editorial success value</li>
            <li data-kr-step="render"><span class="kr-step-num">v.</span> Drafting the report</li>
          </ol>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════
         STAGE 3 — REPORT
         ════════════════════════════════════════════════════════════ -->
    <section class="kr-stage kr-stage--report" data-stage="report" hidden>
      <!-- Report markup is rendered by JS — see <template> below -->
    </section>

    <!-- ════════════════════════════════════════════════════════════
         STAGE 4 — ERROR
         ════════════════════════════════════════════════════════════ -->
    <section class="kr-stage kr-stage--error" data-stage="error" hidden>
      <div class="kr-error">
        <p class="kr-error-stamp">★ The Kraken returned empty-handed ★</p>
        <h2 class="kr-error-h">Something went wrong.</h2>
        <p class="kr-error-msg" data-kr-error-msg>An unknown error occurred.</p>
        <button type="button" class="kr-error-retry" data-kr-retry>
          Try again <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>

  </main>

  <!-- ════════════════════════════════════════════════════════════
       TEMPLATE — used by JS to render the report
       ════════════════════════════════════════════════════════════ -->
  <template id="kr-report-template">
    <!-- Report masthead -->
    <header class="kr-report-mast">
      <p class="kr-report-eyebrow">★ The Kraken Report ★</p>
      <p class="kr-report-stamp" data-kr-stamp>Filed at sunrise · Saturday · 16 May 2026</p>
      <h2 class="kr-report-h" data-kr-input-echo>—</h2>
      <p class="kr-report-deck">A predictive map of the stories most likely to emerge from this input, ranked by editorial success value.</p>

      <div class="kr-report-actions">
        <button type="button" class="kr-action" data-kr-print>Print full report ↘</button>
        <button type="button" class="kr-action kr-action--ghost" data-kr-restart>Run another ↺</button>
      </div>
    </header>

    <!-- § 01 — CLUSTER MAP -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 01 · Cluster map</p>
        <h3 class="kr-section-h">Ten stable <em>attractors.</em></h3>
        <p class="kr-section-deck" data-kr-distribution>—</p>
      </header>

      <div class="kr-bubble-chart" data-kr-bubble-chart>
        <!-- SVG rendered by JS -->
      </div>

      <ol class="kr-attractor-list" data-kr-attractor-list>
        <!-- Rows rendered by JS -->
      </ol>
    </section>

    <!-- § 02 — TOP 10 STORIES -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 02 · Top 10 stories</p>
        <h3 class="kr-section-h">The narratives that <em>survive.</em></h3>
        <p class="kr-section-deck">Ten finalized stories. Each scored against editorial filters. Each ready to refine.</p>
      </header>
      <ol class="kr-stories" data-kr-stories></ol>
    </section>

    <!-- § 03 — TOP 10 PITCHES -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 03 · Top 10 pitches</p>
        <h3 class="kr-section-h">Ten pitches, <em>publication-ready.</em></h3>
        <p class="kr-section-deck">Each pitch is structured for the journalist's inbox — subject line, three sentences, no fluff.</p>
      </header>
      <ol class="kr-pitches" data-kr-pitches></ol>
    </section>

    <!-- § 04 — TOP 10 HEADLINES -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 04 · Top 10 headline sets</p>
        <h3 class="kr-section-h">Headlines, <em>by format.</em></h3>
        <p class="kr-section-deck">Five variations per story, formatted for different outlet styles.</p>
      </header>
      <ol class="kr-headlines" data-kr-headlines></ol>
    </section>

    <!-- § 05 — TOP 10 INSIGHTS -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 05 · Top 10 non-obvious insights</p>
        <h3 class="kr-section-h">What the data <em>quietly reveals.</em></h3>
        <p class="kr-section-deck">Signals that survive editorial scrutiny and still feel discovered, not deduced.</p>
      </header>
      <ol class="kr-insights" data-kr-insights></ol>
    </section>

    <!-- § 06 — TOP 10 PLACEMENTS -->
    <section class="kr-section">
      <header class="kr-section-head">
        <p class="kr-section-label">§ 06 · Top 10 publication targets</p>
        <h3 class="kr-section-h">Where the work will <em>most likely land.</em></h3>
        <p class="kr-section-deck">For each story, the outlet archetype most likely to publish it — and the framing adjustment that wins acceptance.</p>
      </header>
      <ol class="kr-placements" data-kr-placements></ol>
    </section>

    <!-- Closing -->
    <footer class="kr-report-coda">
      <p class="kr-coda-stamp">★ End of report ★</p>
      <p class="kr-coda-p">
        Take any of these angles into the <a href="/build" class="kr-coda-link">three-minute workshop</a> to produce a full strategy memo — methodology, pitch, journalist names, and a four-week roadmap.
      </p>
      <p class="kr-coda-sig">— The Kraken · 701am</p>
    </footer>
  </template>

</BaseLayout>

<style is:global>
  /* ═══════════════════════════════════════════════════════════════════
     /kraken — The Newsroom Prediction Engine
     ═══════════════════════════════════════════════════════════════════ */

  .kraken {
    max-width: 76rem;
    margin: 0 auto;
    padding: var(--x1) 32px var(--x1);
    color: var(--ink);
    font-family: 'Newsreader', Georgia, serif;
  }

  .kr-stage[hidden] { display: none !important; }

  /* ═══════════ STAGE 1 — INPUT ═══════════ */
  .kr-stage--input {
    padding: calc(var(--x1) + var(--x2)) 0 var(--x1);
  }

  .kr-mast {
    text-align: center;
    padding: 0 var(--x3) var(--x1);
    max-width: 50rem;
    margin: 0 auto;
  }
  .kr-mast-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    margin: 0 0 var(--x1);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.30em;
    color: var(--claret);
    text-transform: uppercase;
  }
  .kr-mast-rule {
    display: inline-block;
    width: 42px;
    height: 1px;
    background: var(--claret);
    opacity: 0.55;
  }
  .kr-sigil {
    width: 110px;
    height: 110px;
    margin: 0 auto var(--x1);
    color: var(--claret);
  }
  .kr-sigil svg {
    width: 100%;
    height: 100%;
  }
  .kr-mast-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .kr-mast-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .kr-mast-sub {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    color: var(--ink-soft);
    margin: 0 0 var(--x1);
  }
  .kr-mast-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 300;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: var(--ink);
    max-width: 38rem;
    margin: 0 auto var(--x1);
  }
  .kr-mast-deck em {
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .kr-mast-stats {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11.5px;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    text-transform: uppercase;
    margin: var(--x2) 0 0;
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .kr-mast-stats em {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    margin-right: 4px;
  }
  .kr-mast-stat-sep {
    color: var(--rule-strong);
  }

  /* The form */
  .kr-form {
    max-width: 48rem;
    margin: var(--x1) auto 0;
    padding: var(--x1) var(--x1);
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    border-top: 3px solid var(--claret);
    box-shadow: 0 12px 32px rgba(15, 14, 14, 0.06);
    position: relative;
  }
  .kr-form::before {
    content: "";
    position: absolute;
    top: 6px; left: 6px; right: 6px; bottom: 6px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  .kr-form-label {
    display: block;
    margin-bottom: var(--x4);
    position: relative;
    z-index: 1;
  }
  .kr-form-label-text {
    display: block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10.5px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .kr-form-label-meta {
    display: block;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13.5px;
    color: var(--ink-fainter);
  }
  .kr-textarea {
    width: 100%;
    padding: 16px 18px;
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    font-family: 'Newsreader', Georgia, serif;
    font-size: 16.5px;
    line-height: 1.55;
    color: var(--ink);
    resize: vertical;
    min-height: 130px;
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    z-index: 1;
  }
  .kr-textarea:focus {
    outline: none;
    border-color: var(--claret);
    box-shadow: 0 0 0 3px rgba(153, 15, 61, 0.08);
  }
  .kr-textarea::placeholder {
    color: var(--ink-fainter);
    font-style: italic;
  }
  .kr-form-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--x4);
    gap: var(--x3);
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }
  .kr-form-counter {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 12.5px;
    color: var(--ink-fainter);
    margin: 0;
    font-variant-numeric: oldstyle-nums;
  }
  .kr-submit {
    background: var(--ink-deep);
    color: var(--paper-soft);
    border: none;
    padding: 14px 28px;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .kr-submit:hover {
    background: var(--claret);
    transform: translateY(-1px);
  }
  .kr-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
  .kr-submit-arrow {
    transition: transform 0.25s ease;
  }
  .kr-submit:hover .kr-submit-arrow {
    transform: translateX(4px);
  }

  /* Methodology details */
  .kr-method {
    max-width: 48rem;
    margin: var(--x1) auto 0;
    padding: 0 var(--x3);
  }
  .kr-method-summary {
    cursor: pointer;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.22em;
    color: var(--ink-soft);
    text-transform: uppercase;
    font-weight: 600;
    list-style: none;
    padding: var(--x4) 0;
    border-top: 1px solid var(--rule);
    transition: color 0.2s ease;
  }
  .kr-method-summary::-webkit-details-marker { display: none; }
  .kr-method-summary:hover { color: var(--claret); }
  .kr-method[open] .kr-method-summary { color: var(--claret); }
  .kr-method-body {
    padding: var(--x3) 0;
    font-family: 'Newsreader', Georgia, serif;
  }
  .kr-method-body ol {
    counter-reset: kr-method-counter;
    list-style: none;
    padding: 0;
    margin: 0 0 var(--x1);
  }
  .kr-method-body li {
    counter-increment: kr-method-counter;
    position: relative;
    padding: var(--x4) 0 var(--x4) var(--x1);
    border-bottom: 1px solid var(--rule);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
  }
  .kr-method-body li::before {
    content: counter(kr-method-counter, lower-roman) ".";
    position: absolute;
    left: 0;
    top: var(--x4);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    font-size: 17px;
  }
  .kr-method-body li strong {
    color: var(--ink);
    font-weight: 500;
  }
  .kr-method-body em { font-style: italic; color: var(--claret); }
  .kr-method-cost {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13.5px;
    color: var(--ink-fainter);
    margin: var(--x4) 0 0;
    line-height: 1.55;
    text-align: center;
  }
  .kr-method-cost em { color: var(--claret); }

  /* ═══════════ STAGE 2 — LOADING ═══════════ */
  .kr-stage--loading {
    padding: var(--x1) 0;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .kr-loading {
    text-align: center;
    max-width: 32rem;
  }
  .kr-loading-sigil {
    width: 96px;
    height: 96px;
    margin: 0 auto var(--x1);
    color: var(--claret);
    animation: kr-pulse 2.4s ease-in-out infinite;
  }
  @keyframes kr-pulse {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }
  .kr-spin {
    transform-origin: 60px 60px;
    animation: kr-rotate 8s linear infinite;
  }
  @keyframes kr-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .kr-loading-stage {
