---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="The 7:01 Newsroom — Build a Story · 701am"
  description="A guided workshop. Five questions. Two datasets. One headline you didn't have yesterday."
>

<main class="build-app" data-build-app>

  <!-- ════════════════════════════════════════════
       STEP 0 — Masthead
       ════════════════════════════════════════════ -->
  <section class="step is-active" data-step="0">
    <div class="masthead">
      <p class="masthead-eyebrow">
        <span class="rule"></span>
        Filed at 7:01 a.m. · The desk
        <span class="rule"></span>
      </p>
      <h1 class="masthead-h">
        The <em>7:01</em><br />
        Newsroom.
      </h1>
      <p class="masthead-deck">
        Five questions. Two public datasets. <em>One headline you did not have yesterday.</em>
      </p>
      <p class="masthead-meta">
        A workshop for finding the angle your industry hasn't seen.
        Built by 701am. Free to use. Yours to keep.
      </p>

      <div class="masthead-grid">
        <div class="masthead-tile">
          <span class="masthead-tile-num">i.</span>
          <span class="masthead-tile-label">Tell us about your industry</span>
        </div>
        <div class="masthead-tile">
          <span class="masthead-tile-num">ii.</span>
          <span class="masthead-tile-label">Pick the angle that fits</span>
        </div>
        <div class="masthead-tile">
          <span class="masthead-tile-num">iii.</span>
          <span class="masthead-tile-label">Get the full strategy memo</span>
        </div>
      </div>

      <button class="btn-large" data-action="next">
        Begin <span aria-hidden="true">→</span>
      </button>
      <p class="masthead-fine">
        Takes about three minutes. <em>We never store your answers.</em>
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       PROGRESS BAR — visible for steps 1-5
       ════════════════════════════════════════════ -->
  <div class="progress" data-progress hidden>
    <div class="progress-rail">
      <div class="progress-fill" data-progress-fill></div>
    </div>
    <div class="progress-meta">
      <span class="progress-label" data-progress-label>§ 01 of 05</span>
      <button class="progress-back" type="button" data-action="back" aria-label="Previous step">← Back</button>
    </div>
  </div>

  <!-- ════════════════════════════════════════════
       STEP 1 — Industry
       ════════════════════════════════════════════ -->
  <section class="step" data-step="1">
    <div class="q">
      <p class="q-step">§ 01 · Of five</p>
      <h2 class="q-h">What <em>industry</em> do you work in?</h2>
      <p class="q-deck">Be specific. "B2B SaaS for healthcare" beats "tech." "Independent bookstores" beats "retail."</p>

      <div class="q-input">
        <input type="text" data-field="industry" placeholder="e.g. payroll software for restaurants" maxlength="120" autocomplete="off" />
      </div>

      <div class="q-chips" aria-label="Or pick one">
        <button type="button" data-chip="industry" data-value="B2B SaaS">B2B SaaS</button>
        <button type="button" data-chip="industry" data-value="Fintech">Fintech</button>
        <button type="button" data-chip="industry" data-value="E-commerce">E-commerce</button>
        <button type="button" data-chip="industry" data-value="Healthcare">Healthcare</button>
        <button type="button" data-chip="industry" data-value="Higher education">Higher education</button>
        <button type="button" data-chip="industry" data-value="Real estate">Real estate</button>
        <button type="button" data-chip="industry" data-value="Climate tech">Climate tech</button>
        <button type="button" data-chip="industry" data-value="Professional services">Professional services</button>
      </div>

      <div class="q-actions">
        <button class="btn-large" data-action="next" data-requires="industry">
          Continue <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 2 — Audience
       ════════════════════════════════════════════ -->
  <section class="step" data-step="2">
    <div class="q">
      <p class="q-step">§ 02 · Of five</p>
      <h2 class="q-h">Who <em>reads</em> about your industry?</h2>
      <p class="q-deck">The person who consumes the press coverage we will earn for you. Pick the most important.</p>

      <div class="q-radios" data-radios="audience">
        <label class="q-radio">
          <input type="radio" name="audience" value="founders and operators" />
          <span class="q-radio-h">Founders &amp; operators</span>
          <span class="q-radio-p">Other people running businesses in your space</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="audience" value="investors and analysts" />
          <span class="q-radio-h">Investors &amp; analysts</span>
          <span class="q-radio-p">VCs, PE, public-market analysts, financial press</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="audience" value="policymakers and regulators" />
          <span class="q-radio-h">Policymakers &amp; regulators</span>
          <span class="q-radio-p">Government, advocacy, public-affairs press</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="audience" value="end consumers" />
          <span class="q-radio-h">End consumers</span>
          <span class="q-radio-p">The people who buy your product directly</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="audience" value="industry insiders" />
          <span class="q-radio-h">Industry insiders</span>
          <span class="q-radio-p">Operators &amp; specialists in your trade</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="audience" value="the general public" />
          <span class="q-radio-h">The general public</span>
          <span class="q-radio-p">Mainstream readers, daily newspapers, network TV</span>
        </label>
      </div>

      <div class="q-actions">
        <button class="btn-large" data-action="next" data-requires="audience">
          Continue <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 3 — Geography
       ════════════════════════════════════════════ -->
  <section class="step" data-step="3">
    <div class="q">
      <p class="q-step">§ 03 · Of five</p>
      <h2 class="q-h">Where does your <em>story</em> matter most?</h2>
      <p class="q-deck">The geography determines which datasets we can use and which reporters will care.</p>

      <div class="q-radios" data-radios="geography">
        <label class="q-radio">
          <input type="radio" name="geography" value="US national" />
          <span class="q-radio-h">US national</span>
          <span class="q-radio-p">National press, federal datasets, country-wide story</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="geography" value="US regional" />
          <span class="q-radio-h">A specific US region</span>
          <span class="q-radio-p">State or metro story, regional papers, local press</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="geography" value="global" />
          <span class="q-radio-h">Global</span>
          <span class="q-radio-p">International datasets, multiple-country comparisons</span>
        </label>
        <label class="q-radio">
          <input type="radio" name="geography" value="unsure" />
          <span class="q-radio-h">I'm not sure</span>
          <span class="q-radio-p">We'll pick the geography that fits the best angle</span>
        </label>
      </div>

      <div class="q-actions">
        <button class="btn-large" data-action="next" data-requires="geography">
          Continue <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 4 — Position
       ════════════════════════════════════════════ -->
  <section class="step" data-step="4">
    <div class="q">
      <p class="q-step">§ 04 · Of five</p>
      <h2 class="q-h">What do you want to be <em>known</em> for?</h2>
      <p class="q-deck">A sentence or two. The editorial position you want the world to associate with your business.</p>

      <div class="q-input">
        <textarea data-field="position" rows="4" placeholder="e.g. The authoritative voice on what small restaurants actually pay their staff in 2026" maxlength="400"></textarea>
        <div class="q-input-counter" data-counter="position">0 / 400</div>
      </div>

      <div class="q-actions">
        <button class="btn-large" data-action="next" data-requires="position">
          Continue <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 5 — Beats
       ════════════════════════════════════════════ -->
  <section class="step" data-step="5">
    <div class="q">
      <p class="q-step">§ 05 · Of five</p>
      <h2 class="q-h">Which <em>beats</em> do you want to land?</h2>
      <p class="q-deck">Pick as many as fit. We'll write a strategy that has a real chance with each.</p>

      <div class="q-checks" data-checks="beats">
        <label class="q-check"><input type="checkbox" value="tech press" /><span>Tech press</span></label>
        <label class="q-check"><input type="checkbox" value="business press" /><span>Business press</span></label>
        <label class="q-check"><input type="checkbox" value="trade and industry" /><span>Trade &amp; industry</span></label>
        <label class="q-check"><input type="checkbox" value="policy and regulatory" /><span>Policy &amp; regulatory</span></label>
        <label class="q-check"><input type="checkbox" value="lifestyle and consumer" /><span>Lifestyle &amp; consumer</span></label>
        <label class="q-check"><input type="checkbox" value="local and regional" /><span>Local &amp; regional</span></label>
        <label class="q-check"><input type="checkbox" value="longform and feature" /><span>Longform &amp; feature</span></label>
        <label class="q-check"><input type="checkbox" value="podcast and broadcast" /><span>Podcast &amp; broadcast</span></label>
      </div>

      <div class="q-actions">
        <button class="btn-large" data-action="generate">
          Find the angle <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       LOADING — Generating ideas
       ════════════════════════════════════════════ -->
  <section class="step step-loading" data-step="loading-ideas">
    <div class="loading">
      <div class="loading-marquee">
        <p class="loading-eyebrow">★ The desk is working ★</p>
        <h2 class="loading-h" data-loading-line>The desk is reading your context…</h2>
        <div class="loading-bar"><div class="loading-bar-fill"></div></div>
        <p class="loading-fine">Generating five distinct angles from your inputs.</p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 6 — Five angle cards
       ════════════════════════════════════════════ -->
  <section class="step" data-step="6">
    <div class="ideas">
      <p class="ideas-eyebrow">★ Five candidate angles ★</p>
      <h2 class="ideas-h">Pick the one <em>that fits.</em></h2>
      <p class="ideas-deck">
        Each is a distinct archetype — index, ranking, surprise statistic, geographic
        pattern, or trend. <em>Pick the one a reporter on your beat would actually open.</em>
      </p>

      <div class="ideas-grid" data-ideas-grid>
        <!-- cards injected by JS -->
      </div>

      <div class="ideas-actions">
        <button class="btn-secondary" data-action="regenerate" type="button">
          Show me five different ideas
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       LOADING — Searching public record + drafting
       ════════════════════════════════════════════ -->
  <section class="step step-loading" data-step="loading-synth">
    <div class="loading">
      <div class="loading-marquee">
        <p class="loading-eyebrow">★ The research desk ★</p>
        <h2 class="loading-h" data-synth-line>Searching the public record…</h2>
        <div class="loading-bar"><div class="loading-bar-fill"></div></div>
        <p class="loading-fine">Finding datasets. Drafting the strategy memo.</p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       STEP 7 — The deliverable
       ════════════════════════════════════════════ -->
  <section class="step" data-step="7">
    <article class="memo">

      <header class="memo-head">
        <p class="memo-stamp">
          <span class="rule"></span>
          Strategy memo · Filed at 7:01 a.m.
          <span class="rule"></span>
        </p>
        <h2 class="memo-headline" data-memo="headline">—</h2>
        <p class="memo-deck" data-memo="deck">—</p>
        <p class="memo-archetype">
          <span data-memo="archetype">—</span> · <span data-memo="industry">—</span>
        </p>
      </header>

      <div class="memo-grid">

        <section class="memo-section memo-method">
          <p class="memo-section-label">§ 01 · Methodology</p>
          <ol class="memo-method-list" data-memo="methodology"></ol>
        </section>

        <section class="memo-section memo-pitch">
          <p class="memo-section-label">§ 02 · The pitch</p>
          <div class="memo-pitch-card">
            <div class="memo-pitch-row">
              <span class="memo-pitch-key">Subject:</span>
              <span class="memo-pitch-val" data-memo="pitch-subject">—</span>
            </div>
            <div class="memo-pitch-rule"></div>
            <p class="memo-pitch-body" data-memo="pitch-body">—</p>
          </div>
        </section>

        <section class="memo-section memo-reporters">
          <p class="memo-section-label">§ 03 · The reporter list</p>
          <ul class="memo-reporters-list" data-memo="reporters"></ul>
        </section>

        <section class="memo-section memo-sources">
          <p class="memo-section-label">§ 04 · The data</p>
          <ul class="memo-sources-list" data-memo="sources"></ul>
        </section>

        <section class="memo-section memo-roadmap">
          <p class="memo-section-label">§ 05 · The four-week roadmap</p>
          <ol class="memo-roadmap-list" data-memo="roadmap"></ol>
        </section>

        <section class="memo-section memo-north">
          <p class="memo-section-label">§ 06 · North star</p>
          <blockquote class="memo-north-q" data-memo="north_star">—</blockquote>
        </section>

      </div>

      <!-- DUAL CTA — DIY or DFY -->
      <section class="memo-cta">
        <p class="memo-cta-stamp">★ The fork in the road ★</p>
        <h3 class="memo-cta-h">You have the <em>angle.</em><br />Now — execute it how?</h3>
        <p class="memo-cta-deck">
          The desk has handed you the playbook. Two honest ways to run it:
          with us walking beside you, or with the open-source skills running on your own AI.
        </p>

        <div class="memo-cta-fork">

          <div class="memo-cta-card memo-cta-card--with-us">
            <div class="memo-cta-frame" aria-hidden="true"></div>
            <p class="memo-cta-eyebrow">Path I · With us</p>
            <h4 class="memo-cta-card-h">We <em>walk it</em> for you.</h4>
            <p class="memo-cta-card-p">
              Thirty minutes at sunrise. We'll review this memo with you, refine
              the angle to a draft a reporter will actually open, and tell you
              plainly what it takes to land it.
            </p>
            <a class="btn-primary" href="/discovery">
              Book a sunrise call <span aria-hidden="true">→</span>
            </a>
            <p class="memo-cta-fine">★ No deck. No pitch. No charge.</p>
            <div class="memo-cta-seal" aria-hidden="true">
              <span class="memo-cta-seal-time">7:01</span>
            </div>
          </div>

          <div class="memo-cta-card memo-cta-card--diy">
            <div class="memo-cta-frame" aria-hidden="true"></div>
            <p class="memo-cta-eyebrow">Path II · By you</p>
            <h4 class="memo-cta-card-h">Run it on your <em>own AI.</em></h4>
            <p class="memo-cta-card-p">
              The same system that wrote this memo — twenty-eight earned-media
              skills your AI agent can read. <em>Pitch craft, journalist research,
              the humanizer.</em> MIT licensed. Yours to clone.
            </p>
            <a class="btn-primary btn-primary--ghost" href="/skills">
              Browse the skills <span aria-hidden="true">→</span>
            </a>
            <p class="memo-cta-fine">★ Free &amp; open source.</p>
          </div>

        </div>

        <div class="memo-actions">
          <button class="btn-link" type="button" data-action="print">
            <span aria-hidden="true">↓</span> Save this memo as PDF
          </button>
          <button class="btn-link" type="button" data-action="restart">
            <span aria-hidden="true">↻</span> Start over with a different industry
          </button>
        </div>
      </section>

    </article>
  </section>

</main>

<style is:global>
  /* ═══════════════════════════════════════════════
     /build — the wizard
     Editorial type, FT salmon, sparse layout
     ═══════════════════════════════════════════════ */
  .build-app {
    min-height: 100vh;
    background: var(--paper);
    padding: 0 var(--x1);
  }
  .build-app .step {
    display: none;
    max-width: 56rem;
    margin: 0 auto;
    padding: calc(var(--x1) + var(--x2)) 0 var(--x1);
    animation: build-fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .build-app .step.is-active { display: block; }

  @keyframes build-fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─────── MASTHEAD (step 0) ─────── */
  .build-app .masthead {
    text-align: center;
    padding: calc(var(--x1) + var(--x2)) var(--x3);
  }
  .build-app .masthead-eyebrow,
  .build-app .memo-stamp {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x2);
    font-weight: 600;
  }
  .build-app .rule {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: var(--claret);
    opacity: 0.55;
  }
  .build-app .masthead-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(3rem, 9vw, 6.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 var(--x2);
    text-wrap: balance;
  }
  .build-app .masthead-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .build-app .masthead-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.2rem, 2.4vw, 1.5rem);
    line-height: 1.4;
    color: var(--ink-soft);
    max-width: 44ch;
    margin: 0 auto var(--x3);
    text-wrap: balance;
  }
  .build-app .masthead-deck em {
    color: var(--claret);
    font-style: italic;
  }
  .build-app .masthead-meta {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-faint);
    max-width: 38ch;
    margin: 0 auto var(--x1);
  }
  .build-app .masthead-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--x3);
    max-width: 44rem;
    margin: 0 auto var(--x1);
    text-align: left;
  }
  .build-app .masthead-tile {
    display: flex;
    gap: var(--x4);
    align-items: baseline;
    padding: var(--x4) var(--x3);
    border: 1px solid var(--rule);
    background: var(--paper-soft);
  }
  .build-app .masthead-tile-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-size: 1.25rem;
    line-height: 1;
    font-variant-numeric: oldstyle-nums;
  }
  .build-app .masthead-tile-label {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.35;
    color: var(--ink);
  }
  .build-app .masthead-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-fainter);
    margin: var(--x3) 0 0;
  }
  .build-app .masthead-fine em {
    color: var(--claret);
    font-style: italic;
  }

  /* ─────── PROGRESS BAR ─────── */
  .build-app .progress {
    max-width: 56rem;
    margin: 0 auto;
    padding: var(--x3) var(--x3) var(--x4);
  }
  .build-app .progress-rail {
    width: 100%;
    height: 2px;
    background: var(--paper-deep);
    overflow: hidden;
    position: relative;
  }
  .build-app .progress-fill {
    height: 100%;
    background: var(--claret);
    width: 0%;
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .build-app .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--x5);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .build-app .progress-label {
    color: var(--claret);
    font-weight: 600;
  }
  .build-app .progress-back {
    background: none;
    border: none;
    color: var(--ink-faint);
    cursor: pointer;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    padding: 4px 0;
  }
  .build-app .progress-back:hover { color: var(--claret); }

  /* ─────── QUESTION STEPS ─────── */
  .build-app .q {
    padding: var(--x2) var(--x3);
  }
  .build-app .q-step {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x3);
  }
  .build-app .q-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    max-width: 22ch;
    text-wrap: balance;
  }
  .build-app .q-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .build-app .q-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 48ch;
    margin: 0 0 var(--x1);
  }

  /* Inputs */
  .build-app .q-input {
    position: relative;
    margin-bottom: var(--x2);
  }
  .build-app .q-input input,
  .build-app .q-input textarea {
    width: 100%;
    background: var(--paper-soft);
    border: 1px solid var(--rule-strong);
    padding: var(--x3) var(--x2);
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    line-height: 1.4;
    color: var(--ink);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .build-app .q-input input:focus,
  .build-app .q-input textarea:focus {
    outline: none;
    border-color: var(--claret);
    background: var(--paper-soft);
  }
  .build-app .q-input textarea {
    resize: vertical;
    min-height: 120px;
  }
  .build-app .q-input-counter {
    position: absolute;
    bottom: 12px;
    right: 14px;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-fainter);
    pointer-events: none;
  }

  /* Chips */
  .build-app .q-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: var(--x2);
  }
  .build-app .q-chips button {
    background: transparent;
    border: 1px solid var(--rule-strong);
    color: var(--ink);
    padding: 7px 14px;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .build-app .q-chips button:hover,
  .build-app .q-chips button.is-active {
    background: var(--claret);
    color: var(--paper-soft);
    border-color: var(--claret);
  }

  /* Radios */
  .build-app .q-radios {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x4);
    margin-bottom: var(--x2);
  }
  .build-app .q-radio {
    cursor: pointer;
    background: var(--paper-soft);
    border: 1px solid var(--rule-strong);
    padding: var(--x3);
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.3s ease;
    position: relative;
  }
  .build-app .q-radio input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .build-app .q-radio:hover {
    border-color: var(--claret);
    transform: translateY(-2px);
  }
  .build-app .q-radio:has(input:checked) {
    border-color: var(--claret);
    background: var(--paper-deep);
    box-shadow: 0 0 0 1px var(--claret) inset;
  }
  .build-app .q-radio-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.125rem;
    color: var(--ink);
    line-height: 1.25;
  }
  .build-app .q-radio-p {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* Checks */
  .build-app .q-checks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x5);
    margin-bottom: var(--x2);
  }
  .build-app .q-check {
    cursor: pointer;
    background: var(--paper-soft);
    border: 1px solid var(--rule-strong);
    padding: var(--x4) var(--x3);
    display: flex;
    align-items: center;
    gap: var(--x4);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .build-app .q-check input {
    width: 16px;
    height: 16px;
    accent-color: var(--claret);
    cursor: pointer;
  }
  .build-app .q-check span {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    color: var(--ink);
  }
  .build-app .q-check:hover {
    border-color: var(--claret);
  }
  .build-app .q-check:has(input:checked) {
    border-color: var(--claret);
    background: var(--paper-deep);
  }

  .build-app .q-actions {
    margin-top: var(--x2);
  }

  /* Big button */
  .build-app .btn-large {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: var(--ink-deep);
    color: var(--paper-soft);
    border: none;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.3s ease;
  }
  .build-app .btn-large:hover {
    background: var(--claret);
    transform: translateY(-2px);
  }
  .build-app .btn-large[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }
  .build-app .btn-large[disabled]:hover {
    background: var(--ink-deep);
    transform: none;
  }

  .build-app .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .build-app .btn-secondary:hover {
    background: var(--ink);
    color: var(--paper-soft);
  }

  /* ─────── LOADING ─────── */
  .build-app .loading {
    padding: calc(var(--x1) + var(--x1)) var(--x3);
    text-align: center;
  }
  .build-app .loading-marquee {
    max-width: 28rem;
    margin: 0 auto;
  }
  .build-app .loading-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x2);
  }
  .build-app .loading-h {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.5rem, 3.2vw, 2rem);
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 var(--x2);
    min-height: 2.5em;
    text-wrap: balance;
  }
  .build-app .loading-bar {
    height: 2px;
    background: var(--paper-deep);
    overflow: hidden;
    margin: 0 auto var(--x3);
    max-width: 18rem;
    position: relative;
  }
  .build-app .loading-bar-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, var(--claret), transparent);
    animation: load-sweep 1.8s ease-in-out infinite;
  }
  @keyframes load-sweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .build-app .loading-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-fainter);
    margin: 0;
  }

  /* ─────── IDEAS GRID ─────── */
  .build-app .ideas { padding: var(--x2) var(--x3); }
  .build-app .ideas-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x3);
    text-align: center;
  }
  .build-app .ideas-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-align: center;
    margin: 0 0 var(--x3);
    text-wrap: balance;
  }
  .build-app .ideas-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .build-app .ideas-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 50ch;
    margin: 0 auto var(--x1);
    text-align: center;
  }
  .build-app .ideas-deck em { color: var(--claret); font-style: italic; }

  .build-app .ideas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--x3);
    margin: var(--x1) 0;
  }
  .build-app .idea-card {
    position: relative;
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    padding: var(--x2) var(--x2);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease, border-color 0.3s;
    box-shadow: 0 8px 18px rgba(15, 14, 14, 0.06);
  }
  .build-app .idea-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(15, 14, 14, 0.12);
    border-color: var(--claret);
  }
  .build-app .idea-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--x3);
    padding-bottom: var(--x4);
    border-bottom: 1px solid var(--rule-strong);
    gap: var(--x3);
  }
  .build-app .idea-archetype {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
  }
  .build-app .idea-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-size: 1.25rem;
    line-height: 1;
    font-variant-numeric: oldstyle-nums;
  }
  .build-app .idea-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    text-wrap: balance;
  }
  .build-app .idea-angle {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 var(--x3);
  }
  .build-app .idea-meta {
    border-top: 1px solid var(--rule);
    padding-top: var(--x4);
    margin-top: var(--x3);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--x5);
  }
  .build-app .idea-meta-block { display: flex; gap: var(--x4); align-items: baseline; }
  .build-app .idea-meta-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    flex-shrink: 0;
    width: 9rem;
  }
  .build-app .idea-meta-text {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--ink);
  }
  .build-app .idea-pick {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: var(--x3);
    padding: 10px 18px;
    background: var(--ink-deep);
    color: var(--paper-soft);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: background 0.2s ease;
  }
  .build-app .idea-card:hover .idea-pick { background: var(--claret); }

  .build-app .ideas-actions {
    text-align: center;
    margin: var(--x2) 0 var(--x1);
  }

  /* ─────── MEMO (deliverable) ─────── */
  .build-app .memo {
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    padding: var(--x1) var(--x1) var(--x2);
    max-width: 64rem;
    margin: var(--x2) auto;
    box-shadow: 0 24px 60px rgba(15, 14, 14, 0.12);
    position: relative;
  }
  .build-app .memo::before {
    content: "";
    position: absolute;
    top: 14px; left: 14px; right: 14px; bottom: 14px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  .build-app .memo-head {
    text-align: center;
    padding: var(--x2) var(--x2) var(--x1);
    border-bottom: 1px solid var(--rule-strong);
    position: relative;
    z-index: 1;
  }
  .build-app .memo-headline {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 300;
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    text-wrap: balance;
    max-width: 28ch;
    margin-left: auto;
    margin-right: auto;
  }
  .build-app .memo-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.0625rem, 2vw, 1.3125rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 48ch;
    margin: 0 auto var(--x3);
  }
  .build-app .memo-archetype {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    margin: 0;
  }
  .build-app .memo-archetype span {
    color: var(--claret);
    font-weight: 600;
  }
  .build-app .memo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x1) var(--x2);
    padding: var(--x1) var(--x2);
    position: relative;
    z-index: 1;
  }
  .build-app .memo-section {
    padding: 0;
  }
  .build-app .memo-section-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x4);
    padding-bottom: var(--x5);
    border-bottom: 1px solid var(--rule-strong);
  }

  /* Methodology numbered list */
  .build-app .memo-method-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }
  .build-app .memo-method-list li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--x4);
    padding: var(--x5) 0;
    border-bottom: 1px solid var(--rule);
    counter-increment: step;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink);
  }
  .build-app .memo-method-list li:last-child { border-bottom: none; }
  .build-app .memo-method-list li::before {
    content: counter(step);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--claret);
    line-height: 1.2;
    font-variant-numeric: oldstyle-nums;
  }

  /* Pitch card */
  .build-app .memo-pitch-card {
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    padding: var(--x3);
  }
  .build-app .memo-pitch-row {
    display: flex;
    gap: var(--x4);
    align-items: baseline;
    margin-bottom: var(--x4);
  }
  .build-app .memo-pitch-key {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-fainter);
    font-weight: 600;
    flex-shrink: 0;
  }
  .build-app .memo-pitch-val {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    line-height: 1.4;
    color: var(--ink);
    font-weight: 500;
  }
  .build-app .memo-pitch-rule {
    height: 1px;
    background: var(--rule);
    margin: var(--x4) 0;
  }
  .build-app .memo-pitch-body {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
    white-space: pre-wrap;
  }

  /* Reporters list */
  .build-app .memo-reporters-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .build-app .memo-reporters-list li {
    padding: var(--x5) 0;
    border-bottom: 1px solid var(--rule);
    font-family: 'Newsreader', Georgia, serif;
  }
  .build-app .memo-reporters-list li:last-child { border-bottom: none; }
  .build-app .memo-reporters-list li b {
    display: block;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--claret);
    margin-bottom: 4px;
  }
  .build-app .memo-reporters-list li span {
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.9375rem;
  }

  /* Sources list */
  .build-app .memo-sources-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .build-app .memo-sources-list li {
    padding: var(--x5) 0;
    border-bottom: 1px solid var(--rule);
  }
  .build-app .memo-sources-list li:last-child { border-bottom: none; }
  .build-app .memo-sources-list li b {
    display: block;
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--claret);
    margin-bottom: 4px;
  }
  .build-app .memo-sources-list li a {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-strong);
    line-height: 1.35;
    display: inline-block;
  }
  .build-app .memo-sources-list li a:hover {
    color: var(--claret);
    border-bottom-color: var(--claret);
  }

  /* Roadmap timeline — four horizontal phase rows, stacked vertically.
     Each row reads like a line in a project plan: numeral · phase · action · deliverable */
  .build-app .memo-roadmap-list {
    list-style: none;
    margin: 0;
    padding: 0;
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    background: var(--paper);
  }
  .build-app .memo-roadmap-list .roadmap-card,
  .build-app .memo-roadmap-list > li {
    position: relative;
    padding: var(--x3) var(--x2);
    border: none;
    border-bottom: 1px solid var(--rule);
    background: transparent;
    display: grid;
    grid-template-columns: 4.5rem 9rem 1fr 1.2fr;
    gap: var(--x2);
    align-items: center;
    list-style: none;
    transition: background 0.2s ease;
    min-height: auto;
  }
  .build-app .memo-roadmap-list > li:last-child {
    border-bottom: none;
  }
  .build-app .memo-roadmap-list > li:hover {
    background: var(--paper-soft);
  }
  .build-app .memo-roadmap-list .roadmap-card-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 3.25rem;
    line-height: 1;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    letter-spacing: -0.04em;
    text-align: center;
  }
  .build-app .memo-roadmap-list .roadmap-card-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .build-app .memo-roadmap-list .roadmap-card-phase {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    line-height: 1;
  }
  .build-app .memo-roadmap-list .roadmap-card-week {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-fainter);
    font-variant-numeric: oldstyle-nums;
    line-height: 1.2;
  }
  .build-app .memo-roadmap-list .roadmap-card-action {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
  }
  .build-app .memo-roadmap-list .roadmap-card-deliv {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0;
    padding-left: var(--x3);
    border-left: 1px solid var(--rule);
  }
  .build-app .memo-roadmap-list .roadmap-card-deliv::before {
    content: "Deliverable · ";
    font-family: 'Instrument Sans', sans-serif;
    font-style: normal;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
  }

  /* North star */
  .build-app .memo-north {
    grid-column: 1 / -1;
    text-align: center;
    padding: var(--x2) 0 0;
  }
  .build-app .memo-north-q {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.25rem, 2.6vw, 1.75rem);
    line-height: 1.35;
    color: var(--ink);
    max-width: 36rem;
    margin: 0 auto;
    padding: 0;
    border: none;
    position: relative;
  }
  .build-app .memo-north-q::before,
  .build-app .memo-north-q::after {
    content: "★";
    color: var(--claret);
    font-size: 0.7em;
    font-style: normal;
    margin: 0 0.4em;
    vertical-align: middle;
  }

  /* ─────── MEMO CTA (the fork) ─────── */
  .build-app .memo-cta {
    grid-column: 1 / -1;
    text-align: center;
    margin: var(--x1) 0 var(--x2);
    padding: var(--x1) var(--x2) 0;
    border-top: 2px solid var(--ink);
    position: relative;
  }
  .build-app .memo-cta-stamp {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: var(--x1) 0 var(--x3);
  }
  .build-app .memo-cta-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    text-wrap: balance;
  }
  .build-app .memo-cta-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .build-app .memo-cta-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 46ch;
    margin: 0 auto var(--x1);
  }
  .build-app .memo-cta-fork {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x3);
    max-width: 52rem;
    margin: 0 auto var(--x1);
    text-align: left;
  }
  .build-app .memo-cta-card {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--ink);
    padding: var(--x1) var(--x3);
    display: flex;
    flex-direction: column;
    box-shadow: 0 14px 30px rgba(15, 14, 14, 0.08);
  }
  .build-app .memo-cta-frame {
    position: absolute;
    top: 8px; left: 8px; right: 8px; bottom: 8px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  .build-app .memo-cta-card--with-us {
    background: var(--paper-deep);
    border-color: var(--claret);
  }
  .build-app .memo-cta-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--x3);
    padding-bottom: var(--x5);
    border-bottom: 1px solid var(--rule-strong);
    position: relative;
    z-index: 1;
  }
  .build-app .memo-cta-card-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 var(--x3);
    position: relative;
    z-index: 1;
  }
  .build-app .memo-cta-card-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .build-app .memo-cta-card-p {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 var(--x2);
    position: relative;
    z-index: 1;
  }
  .build-app .memo-cta-card-p em { font-style: italic; color: var(--claret); }
  .build-app .memo-cta-card .btn-primary,
  .build-app .memo-cta-card .btn-primary--ghost {
    margin-top: auto;
    align-self: stretch;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .build-app .memo-cta-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-fainter);
    text-align: center;
    margin: var(--x4) 0 0;
    position: relative;
    z-index: 1;
  }
  .build-app .memo-cta-seal {
    position: absolute;
    top: -14px;
    right: var(--x3);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #C8334F 0%, var(--claret) 40%, var(--claret-dark) 85%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 12px rgba(15, 14, 14, 0.28),
                inset 0 -3px 6px rgba(0, 0, 0, 0.22),
                inset 0 3px 6px rgba(255, 255, 255, 0.18);
    transform: rotate(-8deg);
    z-index: 3;
  }
  .build-app .memo-cta-seal::before {
    content: "";
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    border: 1px dashed rgba(255, 241, 224, 0.4);
  }
  .build-app .memo-cta-seal-time {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    color: var(--paper-soft);
    font-variant-numeric: oldstyle-nums;
  }

  .build-app .memo-actions {
    display: flex;
    justify-content: center;
    gap: var(--x2);
    flex-wrap: wrap;
    padding: var(--x2) 0 0;
    border-top: 1px solid var(--rule);
    margin-top: var(--x2);
  }
  .build-app .memo-actions .btn-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    padding: 8px 14px;
    transition: color 0.2s ease;
  }
  .build-app .memo-actions .btn-link:hover { color: var(--claret); }

  /* ─────── RESPONSIVE ─────── */
  @media (max-width: 880px) {
    .build-app .masthead-grid { grid-template-columns: 1fr; }
    .build-app .q-radios { grid-template-columns: 1fr; }
    .build-app .q-checks { grid-template-columns: 1fr; }
    .build-app .memo-grid { grid-template-columns: 1fr; gap: var(--x1); padding: var(--x2) var(--x3); }
    /* Roadmap: numeral + head on top, action + deliv stacked below */
    .build-app .memo-roadmap-list > li {
      grid-template-columns: 3.5rem 1fr;
      grid-template-areas:
        "num head"
        "num action"
        "num deliv";
      gap: var(--x5) var(--x4);
      padding: var(--x3);
    }
    .build-app .memo-roadmap-list .roadmap-card-num { grid-area: num; align-self: start; font-size: 2.5rem; }
    .build-app .memo-roadmap-list .roadmap-card-head { grid-area: head; }
    .build-app .memo-roadmap-list .roadmap-card-action { grid-area: action; }
    .build-app .memo-roadmap-list .roadmap-card-deliv {
      grid-area: deliv;
      padding-left: 0;
      padding-top: var(--x5);
      border-left: none;
      border-top: 1px solid var(--rule);
    }
    .build-app .memo-cta-fork { grid-template-columns: 1fr; gap: var(--x4); }
  }
  @media (max-width: 560px) {
    .build-app .step { padding: var(--x2) 0; }
    .build-app .q, .build-app .ideas, .build-app .masthead { padding-left: var(--x3); padding-right: var(--x3); }
    .build-app .memo { padding: var(--x3) var(--x4); margin: var(--x3) var(--x4); }
    .build-app .memo::before { top: 10px; left: 10px; right: 10px; bottom: 10px; }
    .build-app .memo-head { padding: var(--x2) var(--x3); }
    .build-app .memo-roadmap-list > li {
      grid-template-columns: 1fr;
      grid-template-areas:
        "head"
        "num"
        "action"
        "deliv";
      gap: var(--x5);
    }
    .build-app .memo-roadmap-list .roadmap-card-num {
      text-align: left;
      font-size: 2rem;
    }
    .build-app .idea-meta-block { flex-direction: column; gap: 2px; }
    .build-app .idea-meta-label { width: auto; }
  }

  /* ─────── PRINT — save the memo as PDF ─────── */
  @media print {
    @page { margin: 0.5in; }
    body { background: white !important; }
    .build-app .step:not([data-step="7"]) { display: none !important; }
    .build-app .progress { display: none !important; }
    .build-app .topbar, .build-app .footer, .topbar, .footer, header, footer { display: none !important; }
    .build-app .memo {
      box-shadow: none !important;
      border: 1px solid #000 !important;
      max-width: 100% !important;
      margin: 0 !important;
    }
    .build-app .memo::before { display: none; }
    .build-app .memo-cta { display: none !important; }
    .build-app .memo-actions { display: none !important; }
    .build-app .memo-grid { grid-template-columns: 1fr 1fr !important; }
    .build-app .memo-roadmap-list > li {
      grid-template-columns: 4.5rem 9rem 1fr 1.2fr !important;
      page-break-inside: avoid;
    }
  }
</style>

<script>
// ════════════════════════════════════════════════════════════════════════
// /build — wizard controller
// ════════════════════════════════════════════════════════════════════════

const app = document.querySelector('[data-build-app]');
const state = {
  step: 0,
  total: 5,
  answers: {
    industry: '',
    audience: '',
    geography: '',
    position: '',
    beats: [],
  },
  ideas: null,
  chosenIdea: null,
  sources: null,
  memo: null,
};

const steps = Array.from(app.querySelectorAll('[data-step]'));
const progressEl = app.querySelector('[data-progress]');
const progressFill = app.querySelector('[data-progress-fill]');
const progressLabel = app.querySelector('[data-progress-label]');

function showStep(key) {
  steps.forEach((s) => s.classList.remove('is-active'));
  const target = steps.find((s) => s.getAttribute('data-step') === String(key));
  if (target) target.classList.add('is-active');
  state.step = key;
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function updateProgress() {
  const s = state.step;
  const numericSteps = ['1','2','3','4','5'];
  if (numericSteps.includes(String(s))) {
    progressEl.hidden = false;
    const idx = numericSteps.indexOf(String(s)) + 1;
    progressFill.style.width = `${(idx / 5) * 100}%`;
    progressLabel.textContent = `§ 0${idx} of 05`;
  } else {
    progressEl.hidden = true;
  }
}

// Field bindings (text inputs / textareas)
app.querySelectorAll('[data-field]').forEach((el) => {
  el.addEventListener('input', (e) => {
    const key = el.getAttribute('data-field');
    state.answers[key] = e.target.value.trim();
    const counterEl = app.querySelector(`[data-counter="${key}"]`);
    if (counterEl) {
      const max = el.getAttribute('maxlength') || 400;
      counterEl.textContent = `${e.target.value.length} / ${max}`;
    }
  });
});

// Chip bindings (industry quick-pick) — set state AND dispatch input event so all listeners sync
app.querySelectorAll('[data-chip]').forEach((btn) => {
  btn.addEventListener('click', () => {
    const key = btn.getAttribute('data-chip');
    const val = btn.getAttribute('data-value');
    state.answers[key] = val;
    const input = app.querySelector(`[data-field="${key}"]`);
    if (input) {
      input.value = val;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }
    app.querySelectorAll(`[data-chip="${key}"]`).forEach((b) => b.classList.remove('is-active'));
    btn.classList.add('is-active');
  });
});

/* ─────────────────────────────────────────────────────────
   Radios — bind BOTH 'change' AND 'click' on the group,
   and re-read checked state from DOM each time so we never
   miss a selection. Some browsers (mobile Safari, some FF)
   don't fire 'change' reliably on label-mediated clicks of
   pointer-events:none inputs.
   ─────────────────────────────────────────────────────── */
function syncRadioGroup(group) {
  const key = group.getAttribute('data-radios');
  const checked = group.querySelector('input[type="radio"]:checked');
  if (checked) state.answers[key] = checked.value;
}
app.querySelectorAll('[data-radios]').forEach((group) => {
  // Re-sync on any click anywhere in the group (label, span, anywhere)
  group.addEventListener('click', () => {
    // Defer one tick so the browser finishes checking the input
    setTimeout(() => syncRadioGroup(group), 0);
  });
  // Also bind change as a belt + suspenders
  group.addEventListener('change', () => syncRadioGroup(group));
  // Sync once on init in case a radio is pre-checked
  syncRadioGroup(group);
});

/* ─────────────────────────────────────────────────────────
   Checks — same defensive pattern
   ─────────────────────────────────────────────────────── */
function syncCheckGroup(group) {
  const key = group.getAttribute('data-checks');
  const values = Array.from(group.querySelectorAll('input[type="checkbox"]:checked')).map((i) => i.value);
  state.answers[key] = values;
}
app.querySelectorAll('[data-checks]').forEach((group) => {
  group.addEventListener('click', () => {
    setTimeout(() => syncCheckGroup(group), 0);
  });
  group.addEventListener('change', () => syncCheckGroup(group));
  syncCheckGroup(group);
});

// Actions
app.addEventListener('click', async (e) => {
  const btn = e.target.closest('[data-action]');
  if (!btn) return;
  const action = btn.getAttribute('data-action');
  const requires = btn.getAttribute('data-requires');

  if (requires) {
    // Belt + suspenders: re-sync ALL radio/check groups from the DOM
    // before validating. Cheap and guarantees we never miss a selection
    // that the user made but a 'change' event swallowed.
    app.querySelectorAll('[data-radios]').forEach(syncRadioGroup);
    app.querySelectorAll('[data-checks]').forEach(syncCheckGroup);
    // Also re-pull the current text input value in case input event missed
    const inputEl = app.querySelector(`[data-field="${requires}"]`);
    if (inputEl && typeof inputEl.value === 'string') {
      state.answers[requires] = inputEl.value.trim();
    }

    const val = state.answers[requires];
    if (!val || (Array.isArray(val) && val.length === 0)) {
      btn.animate(
        [{ transform: 'translateX(0)' }, { transform: 'translateX(-6px)' }, { transform: 'translateX(6px)' }, { transform: 'translateX(0)' }],
        { duration: 220 }
      );
      return;
    }
  }

  if (action === 'next') {
    const order = [0,1,2,3,4,5];
    const i = order.indexOf(state.step);
    if (i >= 0 && i < order.length - 1) {
      showStep(order[i + 1]);
    }
  }

  if (action === 'back') {
    const order = [0,1,2,3,4,5];
    const i = order.indexOf(state.step);
    if (i > 0) showStep(order[i - 1]);
  }

  if (action === 'generate') {
    await generateIdeas();
  }

  if (action === 'regenerate') {
    await generateIdeas();
  }

  if (action === 'print') {
    window.print();
  }

  if (action === 'restart') {
    location.reload();
  }
});

// ────────── API calls ──────────
async function generateIdeas() {
  showStep('loading-ideas');
  startLoadingLines([
    'The desk is reading your context…',
    'Sorting through five archetypes of public-data stories…',
    'Mapping them onto your industry…',
    'Cross-checking against the beats you named…',
  ], 'data-loading-line');

  try {
    const res = await fetch('/api/build-ideas', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(state.answers),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.error || `HTTP ${res.status}`);
    }
    const data = await res.json();
    state.ideas = data.ideas || [];
    renderIdeas(state.ideas);
    showStep('6');
  } catch (err) {
    alert('The desk hit a snag: ' + err.message + '\n\nTry again, or check that the API keys are set.');
    showStep('5');
  }
}

function renderIdeas(ideas) {
  const grid = app.querySelector('[data-ideas-grid]');
  const roman = ['i.','ii.','iii.','iv.','v.','vi.','vii.','viii.'];
  grid.innerHTML = ideas.map((idea, i) => `
    <article class="idea-card" data-idea-index="${i}">
      <div class="idea-card-head">
        <span class="idea-archetype">${escapeHtml(idea.archetype || 'Idea')}</span>
        <span class="idea-num">${roman[i] || (i+1)+'.'}</span>
      </div>
      <h3 class="idea-title">${escapeHtml(idea.title || '')}</h3>
      <p class="idea-angle">${escapeHtml(idea.angle || '')}</p>
      <div class="idea-meta">
        <div class="idea-meta-block">
          <span class="idea-meta-label">Why it works</span>
          <span class="idea-meta-text">${escapeHtml(idea.why_it_works || '')}</span>
        </div>
        <div class="idea-meta-block">
          <span class="idea-meta-label">Datasets</span>
          <span class="idea-meta-text">${escapeHtml(idea.dataset_hint || '')}</span>
        </div>
      </div>
      <span class="idea-pick">Pick this angle <span aria-hidden="true">→</span></span>
    </article>
  `).join('');

  grid.querySelectorAll('.idea-card').forEach((card) => {
    card.addEventListener('click', async () => {
      const idx = parseInt(card.getAttribute('data-idea-index'), 10);
      state.chosenIdea = state.ideas[idx];
      await synthesize();
    });
  });
}

async function synthesize() {
  showStep('loading-synth');
  startLoadingLines([
    'Searching the public record…',
    'Pulling sources from federal and international agencies…',
    'Verifying citations…',
    'Drafting the methodology…',
    'Writing the pitch…',
    'Building the roadmap…',
  ], 'data-synth-line');

  try {
    // 1) research
    const resR = await fetch('/api/build-research', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        idea: state.chosenIdea,
        industry: state.answers.industry,
        geography: state.answers.geography,
      }),
    });
    let sources = [];
    if (resR.ok) {
      const dR = await resR.json();
      sources = dR.sources || [];
    }
    state.sources = sources;

    // 2) synthesize
    const resS = await fetch('/api/build-synthesize', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        idea: state.chosenIdea,
        sources,
        context: state.answers,
      }),
    });
    if (!resS.ok) {
      const err = await resS.json().catch(() => ({}));
      throw new Error(err.error || `HTTP ${resS.status}`);
    }
    const data = await resS.json();
    state.memo = data.memo;
    renderMemo(state.memo, state.sources, state.chosenIdea, state.answers);
    showStep('7');
  } catch (err) {
    alert('The desk hit a snag during synthesis: ' + err.message);
    showStep('6');
  }
}

function renderMemo(memo, sources, idea, ctx) {
  const $ = (sel) => app.querySelector(sel);

  $('[data-memo="headline"]').textContent = memo.headline || '—';
  $('[data-memo="deck"]').textContent = memo.deck || '';
  $('[data-memo="archetype"]').textContent = idea.archetype || '—';
  $('[data-memo="industry"]').textContent = ctx.industry || '—';

  const methList = $('[data-memo="methodology"]');
  methList.innerHTML = (memo.methodology || []).map((step) =>
    `<li>${escapeHtml(step)}</li>`
  ).join('');

  $('[data-memo="pitch-subject"]').textContent = memo.pitch?.subject || '—';
  $('[data-memo="pitch-body"]').textContent = memo.pitch?.body || '—';

  const repList = $('[data-memo="reporters"]');
  repList.innerHTML = (memo.reporters || []).map((r) =>
    `<li><b>${escapeHtml(r.beat || '')}</b><span>${escapeHtml(r.outlets || '')}</span></li>`
  ).join('');

  const srcList = $('[data-memo="sources"]');
  srcList.innerHTML = (sources || []).slice(0, 5).map((s) =>
    `<li><b>${escapeHtml(s.source_type || 'Source')}</b><a href="${escapeAttr(s.url)}" target="_blank" rel="noopener">${escapeHtml(s.title || s.url)}</a></li>`
  ).join('') || `<li><b>Source</b><span style="font-family:'Newsreader',serif;color:var(--ink-soft);font-size:0.9375rem;">Use the dataset hint from the chosen angle as your starting point.</span></li>`;

  const roadList = $('[data-memo="roadmap"]');
  roadList.innerHTML = (memo.roadmap || []).map((r) => `
    <li class="roadmap-card">
      <div class="roadmap-card-num">${escapeHtml(String(r.week || ''))}</div>
      <div class="roadmap-card-head">
        <span class="roadmap-card-phase">${escapeHtml(r.phase || '')}</span>
        <span class="roadmap-card-week">Week ${escapeHtml(String(r.week || ''))}</span>
      </div>
      <p class="roadmap-card-action">${escapeHtml(r.action || '')}</p>
      <p class="roadmap-card-deliv">${escapeHtml(r.deliverable || '')}</p>
    </li>
  `).join('');

  $('[data-memo="north_star"]').textContent = memo.north_star || '';
}

// ────────── helpers ──────────
function escapeHtml(s) {
  return String(s || '').replace(/[&<>"']/g, (c) => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[c]));
}
function escapeAttr(s) { return escapeHtml(s); }

let loadingTimer = null;
function startLoadingLines(lines, attr) {
  if (loadingTimer) clearInterval(loadingTimer);
  const el = app.querySelector(`[${attr}]`);
  if (!el) return;
  let i = 0;
  el.textContent = lines[0];
  loadingTimer = setInterval(() => {
    i = (i + 1) % lines.length;
    el.style.opacity = '0';
    setTimeout(() => {
      el.textContent = lines[i];
      el.style.opacity = '1';
    }, 200);
  }, 2200);
}

// Init
showStep(0);
</script>

</BaseLayout>
