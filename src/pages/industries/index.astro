---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
---
<BaseLayout
  title="701am — Industries"
  description="Earned media, written for the industry on your masthead. The method does not bend for the vertical — but the angle always does."
  breadcrumbs={[{ name: 'Industries' }]}
>

  <!-- ════ HERO ════ -->
  <section class="hero" id="top">
    <div class="hero-grain" aria-hidden="true"></div>
    <div class="hero-rays" aria-hidden="true"></div>
    <div class="hero-sun" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-overline">
        <span class="hero-overline-rule"></span>
        The office, by industry
        <span class="hero-overline-rule"></span>
      </p>

      <h1 class="hero-headline">
        The method does not bend.<br />
        <em>The angle always does.</em>
      </h1>

      <p class="hero-deck">
        Every industry has one true sentence an editor cannot refuse — and it is never the same sentence twice. <em>Here is where the office goes to work, one vertical at a time.</em>
      </p>

      <div class="cta-cluster">
        <a class="btn-primary" href="/discovery">
          Book a sunrise call
          <span class="btn-icon" aria-hidden="true">→</span>
        </a>
        <a class="btn-link" href="#industries">
          Browse the industries
          <span class="arrow" aria-hidden="true">↓</span>
        </a>
      </div>

      <p class="cta-fine">Thirty minutes. No deck. No pitch. No charge.</p>
    </div>
  </section>

  <!-- ════ THE INDUSTRIES ════ -->
  <section class="section section-navy" id="industries">
    <div class="container-wide reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ — The desks</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2">Where the office is <em>open.</em></h2>

      <div class="stamp-rule">
        <div class="stamp-rule-bar"></div>
        <div class="stamp-rule-time">7:01</div>
        <div class="stamp-rule-bar"></div>
      </div>

      <div class="ind-grid">
        <a class="ind-card" href="/industries/healthcare">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h"><em>Healthcare.</em></h3>
          <p class="ind-desc">
            For the providers, staffing firms, payers, and health-tech companies the sector has to trust. We mine your outcomes data for the angle the press can't refuse.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/higher-education">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h">Higher <em>Education.</em></h3>
          <p class="ind-desc">
            For the colleges, EdTech companies, and enrolment partners fighting to be remembered through the cliff. We mine your outcomes data for the angle.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/b2b">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h"><em>B2B.</em></h3>
          <p class="ind-desc">
            Your buyer reads about you before they reply to you. We turn your proprietary data into the benchmark that makes the sector quote you first.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/startup">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h"><em>Startups.</em></h3>
          <p class="ind-desc">
            You can't outspend the incumbents — you can out-story them. We turn your founder's story and your traction into the press that recruits, raises, and sells.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/ai">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h"><em>AI.</em></h3>
          <p class="ind-desc">
            Everyone says they're AI now. We find the result you can defend and place it where the serious press reads, so the market learns which AI companies are real.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/consumer-services">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h">Consumer <em>Services.</em></h3>
          <p class="ind-desc">
            Home, fitness, finance, wellness — categories where the recognised name wins. We mine your customer data for the trend a lifestyle editor is already chasing.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>

        <a class="ind-card" href="/industries/fashion-brands">
          <div class="ind-frame" aria-hidden="true"></div>
          <p class="ind-label">Now open</p>
          <h3 class="ind-h">Fashion <em>Brands.</em></h3>
          <p class="ind-desc">
            The brands that endure aren't the loudest — they're the ones with a story editors want to tell. We earn you the editorial credibility a campaign can't buy.
          </p>
          <span class="ind-cta">Read the field manual <span aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ CTA ════ -->
  <CtaBanner
    eyebrow="The work begins at 7:01"
    heading="Don't see your <em>industry?</em>"
    body="The method travels. If you operate in a market where the loudest is not the most remembered, the sunrise call is free — we will tell you straight whether we can help."
    primaryLabel="Book a sunrise call"
    primaryHref="/discovery"
    secondaryLabel="Or read the scroll"
    secondaryHref="/legend-maker"
  />

</BaseLayout>

<style>
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--x3);
    max-width: 56rem;
    margin: var(--x1) auto 0;
  }
  .ind-card {
    position: relative;
    display: block;
    background: var(--paper-soft);
    border: 1px solid var(--rule-strong);
    padding: calc(var(--x2) + var(--x4)) var(--x2) var(--x2);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .ind-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(15, 14, 14, 0.12);
  }
  .ind-frame {
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  .ind-card--soon { background: var(--paper-deep); }
  .ind-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    margin: 0 0 var(--x4);
    position: relative;
  }
  .ind-h {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
    font-size: var(--f3-size);
    line-height: 1.06;
    font-weight: 500;
    letter-spacing: -0.022em;
    color: var(--ink);
    margin: 0 0 var(--x4);
    position: relative;
  }
  .ind-h em { font-style: italic; font-weight: 400; color: var(--claret); }
  .ind-desc {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    font-size: var(--f6-size);
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 var(--x3);
    position: relative;
  }
  .ind-cta {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f6-size);
    color: var(--claret);
    border-bottom: 1px solid var(--claret);
    padding-bottom: 2px;
    position: relative;
    transition: gap 0.2s ease;
  }
  .ind-card:hover .ind-cta { color: var(--claret-dark); border-bottom-color: var(--claret-dark); }

  @media (max-width: 720px) {
    .ind-grid { grid-template-columns: 1fr; }
  }
</style>
