---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Edtech & OPMs — Narrative Attraction Agency for Higher Education" description="Narrative attraction for edtech and OPMs. Category authority through earned media, AI visibility, and thought leadership.">
<div class="ph">
  <p class="ey">Edtech & OPMs</p>
  <h1>Narrative attraction for <span class="g">edtech companies</span>.</h1>
  <p>Category authority through earned media, AI search visibility, and thought leadership. Be the platform institutions trust because your story is everywhere they look.</p>
</div>

<div class="w">
  <div class="g2">
    <div class="cd">
      <h3>Our services for edtech</h3>
      <p>Category authority through trade press, AI citations, and thought leadership. Be the platform institutions trust because the coverage says so — and because AI recommends you.</p>
      <p><a href="/studio" style="color:var(--co);font-weight:600">See all services →</a></p>
    </div>
    <div class="cd">
      <h3>Narrative Attraction Session</h3>
      <p>Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
      <p><a href="/studio" style="color:var(--co);font-weight:600">See pricing →</a></p>
    </div>
  </div>
  <div style="text-align:center;margin-top:48px">
    <a href="#contact" class="btn btn-p">Book a strategy session</a>
  </div>
</div>

<section class="sec sec-d" style="margin-top:80px">
  <div class="w" style="text-align:center;max-width:600px;margin:0 auto">
    <h2 style="font-family:var(--serif);font-size:clamp(24px,3.5vw,36px);font-weight:500;color:#fff;margin-bottom:12px">Prefer to write?</h2>
    <p style="color:var(--txdm);margin-bottom:24px">Send us a note and we'll follow up.</p>
    <a href="mailto:hello@701am.com" style="color:var(--co);font-size:18px;font-weight:600">hello@701am.com</a>
  </div>
</section>
</Layout>
