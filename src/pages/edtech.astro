---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Edtech & OPMs — Narrative Attraction Agency for Higher Education" description="Narrative attraction for edtech and OPMs. Category authority through earned media, AI visibility, and thought leadership.">
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Edtech & OPMs</div>
      <h1>Narrative attraction for <em class="grad">edtech companies</em>.</h1>
      <p class="lede">Category authority through earned media, AI search visibility, and thought leadership. Be the platform institutions trust because your story is everywhere they look.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <aside class="contact-side" style="grid-column:1">
      <div class="cs-block">
        <h4>Our services for edtech</h4>
        <p>Category authority through trade press, AI citations, and thought leadership. Be the platform institutions trust because the coverage says so — and because AI recommends you.</p>
        <a class="cs-link" href="/studio">See all services <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Narrative Attraction Session</h4>
        <p>Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer to write?</h4>
        <p>Send us a note and we'll follow up.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
    </aside>
  </div>
</Layout>

