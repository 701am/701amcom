---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Edtech & OPMs — Digital PR for Higher Education" description="Earned media for edtech and OPMs. Category authority through trade press and thought leadership. Book a discovery call with 701am.">
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Edtech & OPMs</div>
      <h1>Earned media for <em class="grad">edtech companies</em>.</h1>
      <p class="lede">Category authority through trade press, data studies, and thought leadership. Be the platform institutions trust because the coverage says so.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <div class="contact-form" id="contact-card">
      <div style="height:560px;padding:0" id="cal-inline-embed"></div>
    </div>

    <aside class="contact-side">
      <div class="cs-block">
        <h4>Our services for edtech</h4>
        <p>Category authority through trade press and thought leadership. Be the platform institutions trust because the coverage says so.</p>
        <a class="cs-link" href="/studio">See all services <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Earned Media Session</h4>
        <p>Start with a $500 session — 90 minutes, data audit, reporter list. No obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer to write?</h4>
        <p>Send us a note and we'll follow up.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
    </aside>
  </div>
</Layout>

<script type="text/javascript">
  (function(C,A,L){_cmc=function(){C.m.push(arguments)};C.m=C.m||[];C.style=C.style||{};C.ui=C.ui||{};C.loadingQueue=C.loadingQueue||[];C.lightTheme=C.lightTheme||{};C.darkTheme=C.darkTheme||{};L.forEach(function(t){C[t]=function(){_cmc(t,arguments)}});if(!C.loaded){C.loaded=true;var e=A.createElement("script");e.src="https://app.cal.com/embed/embed.js";var t=A.getElementsByTagName("script")[0];t.parentNode.insertBefore(e,t)}}(window,document,["init","ui","on","off","onAny","offAny","manageModal"]));
  Cal("init","discovery",{origin:"https://cal.com"});
  Cal("ui","discovery",{"styles":{"branding":{"brandColor":"#000000"}},"hideEventTypeDetails":false,"layout":"month_view"});
</script>
<script type="text/javascript">
  Cal("inline",{elementOrSelector:"#cal-inline-embed",calLink:"davidkrug/discovery",config:{"layout":"month_view"}});
</script>