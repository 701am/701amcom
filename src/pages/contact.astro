---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact — Narrative Attraction Agency for Higher Education"
  description="Book a discovery call with 701am. Narrative attraction agency for higher education — earned media campaigns, up to 50 placements per engagement."
>
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Get in touch</div>
      <h1>Let's tell your <em class="grad">institution's story</em>.</h1>
      <p class="lede">The enrollment cliff won't wait. AI is rewriting how students find you. Book a discovery call and we'll build a narrative that protects your future.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <aside class="contact-side" style="grid-column:1">
      <div class="cs-block">
        <h4>Narrative Attraction Session</h4>
        <p>Not ready for a full engagement? Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer email?</h4>
        <p>Write us directly — we read everything.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
      <div class="cs-block">
        <h4>What we work on</h4>
        <p>Narrative attraction for higher education — earned media, AI search visibility, and social & new media campaigns for universities, colleges, edtech companies, and the agencies that serve them.</p>
        <p><a class="cs-link" href="/studio">See our services <i class="ti ti-arrow-right"></i></a></p>
      </div>
    </aside>
  </div>

  <section class="band wrap">
    <div class="contact-wrap" style="grid-template-columns:1fr;max-width:680px">
      <div class="contact-form">
        <h4 style="font-family:var(--serif);font-size:22px;font-weight:500;margin-bottom:16px">Or send us a message</h4>
        <form class="cf-form" id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="cf-field">
            <label>I'm with a…</label>
            <div class="cf-seg">
              <label><input type="radio" name="segment" value="university" checked /><span class="opt">University / College</span></label>
              <label><input type="radio" name="segment" value="edtech" /><span class="opt">Edtech / OPM</span></label>
              <label><input type="radio" name="segment" value="agency" /><span class="opt">Agency</span></label>
            </div>
          </div>

          <div class="cf-field">
            <label for="cf-name">Name</label>
            <input type="text" id="cf-name" name="name" placeholder="Your name" required />
          </div>
          <div class="cf-field">
            <label for="cf-email">Work email</label>
            <input type="email" id="cf-email" name="email" placeholder="you@institution.edu" required />
          </div>
          <div class="cf-field">
            <label for="cf-org">Institution / company</label>
            <input type="text" id="cf-org" name="org" placeholder="Where you work" />
          </div>
          <div class="cf-field">
            <label for="cf-msg">What are you trying to do?</label>
            <textarea id="cf-msg" name="message" placeholder="Tell us about your goals — enrollment visibility, earned media, press coverage…"></textarea>
          </div>
          <button type="submit" class="cf-submit" id="cf-submit">Send it</button>
        </form>
      </div>
    </div>
  </section>

  
  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      if (!form) return;
      function enc(d){return Object.keys(d).map(function(k){return encodeURIComponent(k)+'='+encodeURIComponent(d[k])}).join('&')}
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = document.getElementById('cf-submit');
        var data = {
          'form-name': 'contact',
          name: (document.getElementById('cf-name').value || '').trim(),
          email: (document.getElementById('cf-email').value || '').trim(),
          org: (document.getElementById('cf-org').value || '').trim(),
          segment: (document.querySelector('input[name="segment"]:checked') || {}).value || '',
          message: (document.getElementById('cf-msg').value || '').trim(),
          'bot-field': ''
        };
        if (!data.name || !/.+@.+\..+/.test(data.email)) {
          if (!data.name) document.getElementById('cf-name').focus();
          else document.getElementById('cf-email').focus();
          return;
        }
        btn.disabled = true; btn.textContent = 'Sending…';
        fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: enc(data)
        }).then(function () {
          form.innerHTML = '<div style="padding:30px 0"><div style="font-size:18px;font-weight:600;margin-bottom:8px">Got it — thank you.</div><p>We\'ll be in touch shortly. Filed at sunrise.</p></div>';
        }).catch(function () {
          btn.disabled = false; btn.textContent = 'Send it';
          alert("Something went wrong — please email hello@701am.com directly.");
        });
      });
    })();
  </script>
</Layout>