---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — 701am"
  description="Book a sunrise call, request the scroll, or write to the office directly."
>

  <header class="page-masthead">
    <p class="page-eyebrow">
      <span class="page-rule"></span>
      Write to the office
      <span class="page-rule"></span>
    </p>
    <h1 class="page-title">Three ways to <em>begin.</em></h1>
    <p class="page-deck">
      Pick the one that fits the morning you are in. All three end up in the same inbox, and we read every one.
    </p>
  </header>

  <!-- ════ THREE WAYS GRID ════ -->
  <section class="section section-navy" id="sunrise-call">
    <div class="container-wide">
      <div class="contact-cards">
        <article class="contact-card contact-card-featured">
          <div class="contact-card-badge">★ Most people start here ★</div>
          <div class="contact-card-num">i.</div>
          <h2 class="contact-card-h">Book a <em>sunrise call.</em></h2>
          <p class="contact-card-p">
            Thirty minutes. We listen to the shape of your business and tell you, plainly, whether earned media will move the needle for you. <em>No deck. No pitch. No charge.</em> If we cannot help, we will say so, and tell you who can.
          </p>
          <a class="btn-primary" href="https://cal.com/davidkrug/discovery">
            Book the call
            <span class="btn-icon" aria-hidden="true">→</span>
          </a>
        </article>

        <article class="contact-card">
          <div class="contact-card-num">ii.</div>
          <h2 class="contact-card-h">Read <em>the scroll.</em></h2>
          <p class="contact-card-p">
            The Legend-Maker scroll — the same method we use in the office, written down, sent to your inbox. <em>How to find the angle. How to write the pitch. How to earn the placement.</em> No fee. No funnel. Just the work.
          </p>
          <a class="btn-link" href="mailto:dk@701am.com?subject=Send%20me%20the%20scroll">
            Send me the scroll
            <span class="arrow" aria-hidden="true">↓</span>
          </a>
        </article>

        <article class="contact-card">
          <div class="contact-card-num">iii.</div>
          <h2 class="contact-card-h">Write <em>a letter.</em></h2>
          <p class="contact-card-p">
            For anything else — partnerships, press, a question about a dispatch, a thought on the work. <em>Use the form below.</em> We read every one and reply within two business days.
          </p>
          <a class="btn-link" href="#write">
            Use the form
            <span class="arrow" aria-hidden="true">↓</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ════ CONTACT FORM ════ -->
  <section class="section section-cream" id="write">
    <div class="container reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ — A letter to the office</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2 h2-dark">Write to <em>701am.</em></h2>
      <p class="body body-dark body-center" style="margin-bottom: var(--x1);">
        Every letter reaches the same inbox. We reply in plain English, usually within two business days.
      </p>

      <form
        class="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact?sent=true"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="contact-honeypot">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="contact-row">
          <label class="contact-field">
            <span class="contact-label">Your name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label class="contact-field">
            <span class="contact-label">Your email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
        </div>

        <label class="contact-field">
          <span class="contact-label">Company or project</span>
          <input type="text" name="company" autocomplete="organization" />
        </label>

        <label class="contact-field">
          <span class="contact-label">What's on your mind?</span>
          <textarea name="message" rows="6" required placeholder="Tell us, briefly, what you're working on and what kind of help you're looking for."></textarea>
        </label>

        <div class="contact-meta-row">
          <fieldset class="contact-fieldset">
            <legend class="contact-label">Reason for writing</legend>
            <label class="contact-radio">
              <input type="radio" name="reason" value="sunrise-call" checked />
              <span>Book a sunrise call</span>
            </label>
            <label class="contact-radio">
              <input type="radio" name="reason" value="scroll" />
              <span>Request the scroll</span>
            </label>
            <label class="contact-radio">
              <input type="radio" name="reason" value="press" />
              <span>Press or partnership</span>
            </label>
            <label class="contact-radio">
              <input type="radio" name="reason" value="other" />
              <span>Other</span>
            </label>
          </fieldset>
        </div>

        <div class="contact-submit-row">
          <button type="submit" class="btn-primary">
            Send the letter
            <span class="btn-icon" aria-hidden="true">→</span>
          </button>
          <p class="contact-fine">
            <span style="color: var(--gold);">★</span> We never sell, share, or syndicate addresses. Ever.
          </p>
        </div>
      </form>
    </div>
  </section>

  <!-- ════ DIRECT METHODS ════ -->
  <section class="section section-navy">
    <div class="container reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ — The direct line</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2">The <em>direct line.</em></h2>

      <div class="direct-methods">
        <a class="direct-method" href="mailto:dk@701am.com">
          <div class="direct-method-label">Email</div>
          <div class="direct-method-value">dk@701am.com</div>
          <div class="direct-method-sub">For everything. Read within a day.</div>
        </a>
        <a class="direct-method" href="https://cal.com/davidkrug/discovery">
          <div class="direct-method-label">Sunrise call</div>
          <div class="direct-method-value">Book on Cal.com</div>
          <div class="direct-method-sub">Thirty minutes. No deck, no charge.</div>
        </a>
        <a class="direct-method direct-method-urgent" href="tel:+14063106419">
          <div class="direct-method-label">★ Emergencies only</div>
          <div class="direct-method-value">406&middot;310&middot;6419</div>
          <div class="direct-method-sub">Active clients, time-sensitive issues.</div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-masthead {
    padding: calc(var(--x1) + var(--x3)) var(--x1) var(--x1);
    text-align: center;
    border-bottom: 1px solid rgba(212, 168, 83, 0.15);
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .page-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.34em;
    color: var(--gold);
    text-transform: uppercase;
    margin: 0 0 var(--x3);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
  }
  .page-rule {
    display: inline-block;
    width: 28px; height: 1px;
    background: rgba(212, 168, 83, 0.5);
  }
  .page-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.8rem, 6.5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--cream-warm);
    margin: 0 0 var(--x3);
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
    text-wrap: balance;
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
  }
  .page-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold-light);
  }
  .page-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: var(--f5-size);
    line-height: 1.45;
    color: var(--muted);
    max-width: 36ch;
    margin: 0 auto;
  }

  /* Contact cards */
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--x3);
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .contact-card {
    background: rgba(19, 28, 66, 0.55);
    border: 1px solid rgba(212, 168, 83, 0.22);
    padding: var(--x2) var(--x2) var(--x2);
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .contact-card-featured {
    border-color: rgba(212, 168, 83, 0.55);
    background: rgba(212, 168, 83, 0.06);
  }
  .contact-card-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--navy-deep);
    padding: 5px 14px;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.28em;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .contact-card-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 36px;
    color: var(--gold);
    line-height: 1;
    margin-bottom: var(--x4);
    font-variant-numeric: oldstyle-nums;
  }
  .contact-card-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f4-size);
    font-weight: 500;
    line-height: 1.15;
    color: var(--cream-warm);
    margin: 0 0 var(--x3);
    letter-spacing: -0.018em;
    text-wrap: balance;
  }
  .contact-card-h em {
    font-style: italic;
    color: var(--gold-light);
    font-weight: 400;
  }
  .contact-card-p {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 15px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 var(--x2);
    flex: 1;
  }
  .contact-card-p em {
    font-style: italic;
    color: var(--gold-light);
  }

  /* Form */
  .contact-form {
    max-width: var(--measure);
    margin: var(--x1) auto 0;
  }
  .contact-honeypot {
    position: absolute;
    left: -9999px;
    visibility: hidden;
  }
  .contact-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x3);
  }
  .contact-field {
    display: block;
    margin-bottom: var(--x3);
  }
  .contact-label {
    display: block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    margin-bottom: var(--x5);
    font-weight: 500;
  }
  .contact-field input,
  .contact-field textarea {
    width: 100%;
    background: var(--paper-soft);
    border: 1px solid rgba(10, 22, 51, 0.2);
    padding: 12px 14px;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 17px;
    line-height: 1.5;
    color: var(--navy-deep);
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
  }
  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: rgba(10, 22, 51, 0.4);
    font-style: italic;
  }
  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--teal);
    background: rgba(255, 241, 224, 0.85);
    box-shadow: 0 0 0 3px rgba(13, 118, 128, 0.12);
  }
  .contact-field textarea {
    resize: vertical;
    min-height: 120px;
    font-family: 'Newsreader', Georgia, serif;
  }

  .contact-fieldset {
    border: none;
    padding: 0;
    margin: var(--x3) 0;
    display: flex;
    gap: var(--x3);
    flex-wrap: wrap;
    align-items: center;
  }
  .contact-fieldset legend {
    width: 100%;
    margin-bottom: var(--x4);
  }
  .contact-radio {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 15px;
    color: var(--ink);
    cursor: pointer;
  }
  .contact-radio input[type="radio"] {
    accent-color: var(--claret);
    width: 16px;
    height: 16px;
  }

  .contact-submit-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--x3);
    flex-wrap: wrap;
    margin-top: var(--x3);
    padding-top: var(--x3);
    border-top: 1px solid rgba(10, 22, 51, 0.15);
  }
  .contact-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: rgba(30, 30, 30, 0.7);
    margin: 0;
  }

  /* Direct methods */
  .direct-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: var(--measure-wide);
    margin: var(--x1) auto 0;
    border-top: 1px solid rgba(212, 168, 83, 0.25);
  }
  .direct-method {
    display: block;
    padding: var(--x2);
    text-decoration: none;
    color: inherit;
    border-right: 1px solid rgba(212, 168, 83, 0.15);
    border-bottom: 1px solid rgba(212, 168, 83, 0.25);
    transition: background 0.2s;
  }
  .direct-method:last-child { border-right: none; }
  .direct-method:hover { background: rgba(212, 168, 83, 0.04); }
  .direct-method:hover .direct-method-value { color: var(--gold-light); }
  .direct-method-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.30em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: var(--x4);
    font-weight: 500;
  }
  .direct-method-value {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f4-size);
    font-weight: 500;
    color: var(--cream-warm);
    margin-bottom: var(--x5);
    letter-spacing: -0.012em;
    transition: color 0.2s;
  }
  .direct-method-sub {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
  }

  /* Urgent variant — emergencies only card */
  .direct-method-urgent .direct-method-label {
    color: var(--claret);
  }
  .direct-method-urgent:hover {
    background: rgba(142, 58, 58, 0.08);
  }
  .direct-method-urgent:hover .direct-method-value {
    color: var(--coral);
  }

  @media (max-width: 900px) {
    .contact-cards { grid-template-columns: 1fr; gap: var(--x3); }
    .direct-methods { grid-template-columns: 1fr; }
    .direct-method { border-right: none; }
  }
  @media (max-width: 720px) {
    .contact-row { grid-template-columns: 1fr; }
    .contact-submit-row { flex-direction: column; align-items: stretch; gap: var(--x3); }
  }
</style>
