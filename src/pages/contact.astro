---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Narrative Attraction Agency for Higher Education"
  description="Book a discovery call with 701am. Narrative attraction agency for higher education — earned media campaigns, up to 50 placements per engagement.">
<div class="ph">
  <p class="ey">Get in touch</p>
  <h1>Let's tell your <span class="g">institution's story</span>.</h1>
  <p>The enrollment cliff won't wait. AI is rewriting how students find you. Let's build a narrative that protects your future.</p>
  <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:28px">
    <a href="mailto:hello@701am.com" class="btn btn-o">hello@701am.com</a>
  </div>
</div>

<div class="sec sec-c" style="padding-top:0">
  <div class="w" style="max-width:680px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:44px">
      <div style="background:rgba(255,255,255,.7);border:1px solid var(--bl);border-radius:16px;padding:24px">
        <p style="font-family:var(--mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--co);margin-bottom:8px">Session</p>
        <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;color:var(--tx)">Narrative Attraction Session</h3>
        <p style="font-size:14px;color:var(--txm);margin-bottom:12px">$500 — 90 minutes, data audit, story identification, no obligation.</p>
        <a href="/#hp-price" style="font-size:14px;font-weight:600;color:var(--co);text-decoration:none">See pricing →</a>
      </div>
      <div style="background:rgba(255,255,255,.7);border:1px solid var(--bl);border-radius:16px;padding:24px">
        <p style="font-family:var(--mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--co);margin-bottom:8px">Email</p>
        <h3 style="font-size:17px;font-weight:600;margin-bottom:8px;color:var(--tx)">Prefer email?</h3>
        <p style="font-size:14px;color:var(--txm);margin-bottom:12px">Write us directly — we read everything.</p>
        <a href="mailto:hello@701am.com" style="font-size:14px;font-weight:600;color:var(--co);text-decoration:none">hello@701am.com →</a>
      </div>
    </div>

    <h3 style="font-family:var(--serif);font-size:22px;font-weight:500;margin-bottom:20px">Or send us a message</h3>
    <form id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="contact" />
      <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

      <label>I'm with a…</label>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:4px">
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;color:var(--tx)"><input type="radio" name="segment" value="university" checked /><span>University / College</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;color:var(--tx)"><input type="radio" name="segment" value="edtech" /><span>Edtech / OPM</span></label>
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;color:var(--tx)"><input type="radio" name="segment" value="agency" /><span>Agency</span></label>
      </div>

      <label for="cf-name">Name</label>
      <input type="text" id="cf-name" name="name" placeholder="Your name" required />

      <label for="cf-email">Work email</label>
      <input type="email" id="cf-email" name="email" placeholder="you@institution.edu" required />

      <label for="cf-org">Institution / company</label>
      <input type="text" id="cf-org" name="org" placeholder="Where you work" />

      <label for="cf-msg">What are you trying to do?</label>
      <textarea id="cf-msg" name="message" placeholder="Tell us about your goals — enrollment visibility, earned media, press coverage…" rows="4"></textarea>

      <button type="submit" class="btn btn-p" id="cf-submit" style="align-self:flex-start;cursor:pointer">Send it</button>
    </form>
  </div>
</div>

<script is:inline>
(function(){var f=document.getElementById('contact-form');if(!f)return;function e(d){return Object.keys(d).map(function(k){return encodeURIComponent(k)+'='+encodeURIComponent(d[k])}).join('&')}
f.addEventListener('submit',function(u){u.preventDefault();var b=document.getElementById('cf-submit');var d={'form-name':'contact',name:(document.getElementById('cf-name').value||'').trim(),email:(document.getElementById('cf-email').value||'').trim(),org:(document.getElementById('cf-org').value||'').trim(),segment:(document.querySelector('input[name="segment"]:checked')||{}).value||'',message:(document.getElementById('cf-msg').value||'').trim(),'bot-field':''}
if(!d.name||!/.+@.+\..+/.test(d.email)){if(!d.name)document.getElementById('cf-name').focus();else document.getElementById('cf-email').focus();return}
b.disabled=true;b.textContent='Sending…';fetch('/',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:e(d)}).then(function(){f.innerHTML='<div style="padding:40px 0"><p style="font-size:20px;font-weight:600;margin-bottom:8px">Got it — thank you.</p><p style="color:var(--txm)">We\'ll be in touch shortly. Filed at sunrise.</p></div>'}).catch(function(){b.disabled=false;b.textContent='Send it'})})})();
</script>
</Layout>
