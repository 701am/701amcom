---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const notes = (await getCollection('notes', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return notes.map((note, idx) => ({
    params: { slug: note.id },
    props: {
      note,
      prev: notes[idx + 1] ?? null,
      next: notes[idx - 1] ?? null,
    },
  }));
}

interface Props {
  note: CollectionEntry<'notes'>;
  prev: CollectionEntry<'notes'> | null;
  next: CollectionEntry<'notes'> | null;
}

const { note, prev, next } = Astro.props;
const { Content } = await render(note);

const dateLong = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(note.data.date);
---
<BaseLayout
  title={`${note.data.title} — 701am`}
  description={note.data.deck}
  pageType="article"
  article={{
    publishedTime: note.data.date,
    modifiedTime: note.data.date,
    topic: note.data.topic,
    tags: note.data.tags,
    number: note.data.number,
    readingTime: note.data.readingTime,
  }}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Dispatches', url: '/notes' },
    { name: note.data.title },
  ]}
  markdownAlternate={`/notes/${note.id}.md`}
>

  <div class="post-eyebrow-strip">
    <a class="post-back" href="/notes">All dispatches</a>
    <div class="post-meta-strip">
      <span><strong>№</strong> {String(note.data.number).padStart(3, '0')}</span>
      <span><strong>Filed</strong> {dateLong}</span>
      {note.data.readingTime && <span><strong>{note.data.readingTime}</strong> read</span>}
    </div>
  </div>

  <article class="post-article">
    <p class="post-num">
      Dispatch № {String(note.data.number).padStart(3, '0')} · {note.data.topic}
    </p>

    <h1 class="post-title" set:html={note.data.title} />
    <p class="post-deck">{note.data.deck}</p>

    <div class="post-byline">
      <div class="post-byline-avatar">D</div>
      <div class="post-byline-text">
        <div class="post-byline-by">From the office</div>
        <div class="post-byline-name">— David, <em>at sunrise</em></div>
      </div>
      <div class="post-byline-time">07:01</div>
    </div>

    <div class="post-prose">
      <Content />
      <div class="post-end">
        <div class="post-end-mark"><span>7:01 ✦ 701am</span></div>
      </div>
    </div>

    <!-- CTA inset — proclamation-style -->
    <div class="post-cta">
      <p class="post-cta-stamp">★ The work begins at 7:01 ★</p>
      <h3 class="post-cta-h">Want to find <em>your angle?</em></h3>
      <div class="post-cta-row">
        <a class="btn-primary" href="/discovery">
          Book a sunrise call
          <span class="btn-icon" aria-hidden="true">→</span>
        </a>
        <a class="btn-link" href="/legend-maker">
          Or read the scroll
          <span class="arrow" aria-hidden="true">↓</span>
        </a>
      </div>
    </div>

    <footer class="post-foot">
      {note.data.tags.length > 0 && (
        <div class="post-foot-tags">
          {note.data.tags.map((tag) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      )}
      <div class="post-foot-nav">
        {prev ? (
          <a href={`/notes/${prev.id}`} class="prev">
            <div class="post-foot-nav-label">← Previous dispatch</div>
            <div class="post-foot-nav-title">{prev.data.title}</div>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={`/notes/${next.id}`} class="next">
            <div class="post-foot-nav-label">Next dispatch →</div>
            <div class="post-foot-nav-title">{next.data.title}</div>
          </a>
        ) : <div></div>}
      </div>
    </footer>
  </article>

</BaseLayout>

<style is:global>
  /* ─────── EYEBROW STRIP ─────── */
  .post-eyebrow-strip {
    padding: var(--x3) var(--x1);
    border-bottom: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--x3);
    flex-wrap: wrap;
  }
  .post-back {
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--ink-faint);
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-back::before {
    content: "← ";
    color: var(--claret);
  }
  .post-back:hover { color: var(--ink); }
  .post-meta-strip {
    display: flex;
    gap: var(--x2);
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    flex-wrap: wrap;
  }
  .post-meta-strip strong {
    color: var(--claret);
    font-weight: 500;
  }

  /* ─────── ARTICLE ─────── */
  .post-article {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 4rem var(--x1) 5rem;
  }

  .post-num {
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
    font-size: var(--f7-size);
    letter-spacing: 0.34em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x2);
    font-weight: 500;
  }
  .post-num::before, .post-num::after {
    content: "";
    display: inline-block;
    width: 28px; height: 1px;
    background: rgba(153, 15, 61, 0.5);
  }

  .post-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.028em;
    color: var(--ink);
    margin: 0 0 var(--x2);
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
    text-wrap: balance;
    max-width: 18ch;
  }
  .post-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--claret);
  }

  .post-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: var(--f5-size);
    line-height: 1.4;
    color: var(--ink-faint);
    max-width: 32ch;
    margin: 0 0 var(--x1);
    text-wrap: pretty;
  }

  .post-byline {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: var(--x3) 0;
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    margin: 0 0 var(--x1);
  }
  .post-byline-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--claret) 0%, var(--coral) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 18px;
    color: var(--ink);
    flex-shrink: 0;
  }
  .post-byline-text { line-height: 1.3; }
  .post-byline-by {
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    font-weight: 500;
  }
  .post-byline-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f6-size);
    color: var(--ink);
  }
  .post-byline-name em {
    font-style: italic;
    color: var(--claret);
  }
  .post-byline-time {
    margin-left: auto;
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
  }

  /* ─────── PROSE ─────── */
  .post-prose {
    font-size: var(--f6-size);
    line-height: var(--f6-lh);
    color: var(--ink-soft);
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    hanging-punctuation: first last;
  }
  .post-prose > p {
    margin: 0 0 var(--x2);
    text-wrap: pretty;
  }
  .post-prose > p:first-of-type::first-letter {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 400;
    float: left;
    font-size: 5.2em;
    line-height: 0.82;
    padding: 0.05em 0.12em 0 0;
    margin-top: 0.04em;
    color: var(--claret);
    font-style: italic;
  }
  .post-prose strong {
    color: var(--ink);
    font-weight: 500;
  }
  .post-prose em {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .post-prose h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f4-size);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: var(--x1) 0 var(--x2);
    text-wrap: balance;
  }
  .post-prose h2 em {
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .post-prose h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f5-size);
    font-weight: 500;
    line-height: 1.25;
    color: var(--ink);
    margin: var(--x2) 0 var(--x3);
    font-style: italic;
  }
  .post-prose a {
    color: var(--claret);
    text-decoration: none;
    border-bottom: 1px solid rgba(153, 15, 61, 0.4);
    transition: color 0.2s, border-color 0.2s;
  }
  .post-prose a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* Aphorism — use blockquote with .aphorism class, or hr */
  .post-prose hr {
    border: none;
    margin: var(--x1) auto;
    height: 1px;
    background: var(--rule-strong);
    max-width: 200px;
  }

  /* Pullquote — use blockquote with .pullquote attribute */
  .post-prose blockquote {
    margin: var(--x2) 0;
    padding: var(--x4) 0 var(--x4) var(--x3);
    border-left: 2px solid var(--claret);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f5-size);
    line-height: 1.55;
    color: var(--ink-faint);
  }
  .post-prose blockquote cite {
    display: block;
    margin-top: var(--x5);
    font-family: 'Instrument Sans', sans-serif;
    font-style: normal;
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
  }
  .post-prose blockquote em {
    font-style: italic;
    color: var(--claret);
  }

  .post-prose ul, .post-prose ol {
    padding: 0 0 0 1.5rem;
    margin: 0 0 var(--x2);
  }
  .post-prose li {
    margin: 0 0 var(--x4);
    padding-left: var(--x5);
  }
  .post-prose li::marker { color: var(--claret); }

  .post-prose code {
    font-family: ui-monospace, 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 0.92em;
    background: var(--paper-soft);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--claret);
  }
  .post-prose pre {
    background: rgba(248, 212, 184, 0.6);
    border: 1px solid var(--rule-strong);
    padding: var(--x3) var(--x2);
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.55;
    margin: var(--x2) 0;
  }
  .post-prose pre code {
    background: none;
    padding: 0;
    color: inherit;
  }

  .post-prose img {
    max-width: 100%;
    height: auto;
    margin: var(--x2) 0;
    border: 1px solid var(--rule-strong);
  }

  /* End mark */
  .post-end {
    text-align: center;
    margin: var(--x1) 0;
  }
  .post-end-mark {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .post-end-mark span {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
  }
  .post-end-mark::before, .post-end-mark::after {
    content: "";
    width: 50px; height: 1px;
    background: var(--rule-strong);
  }

  /* CTA inset */
  .post-cta {
    background: var(--paper-soft);
    border: 1px solid var(--rule-strong);
    padding: var(--x1) var(--x2);
    margin: var(--x1) 0;
    text-align: center;
    position: relative;
  }
  .post-cta::before, .post-cta::after {
    content: "";
    position: absolute;
    width: 16px; height: 16px;
    border: 1px solid var(--claret);
  }
  .post-cta::before {
    top: -1px; left: -1px;
    border-right: none;
    border-bottom: none;
  }
  .post-cta::after {
    bottom: -1px; right: -1px;
    border-left: none;
    border-top: none;
  }
  .post-cta-stamp {
    font-size: 9px;
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x4);
    font-weight: 500;
  }
  .post-cta-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f4-size);
    font-weight: 500;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 var(--x3);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }
  .post-cta-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .post-cta-row {
    display: flex;
    gap: var(--x2);
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
    margin-top: var(--x3);
  }

  /* Footer of article */
  .post-foot {
    padding: var(--x1) 0 0;
    border-top: 1px solid var(--rule);
    margin-top: var(--x1);
  }
  .post-foot-tags {
    display: flex;
    gap: var(--x4);
    flex-wrap: wrap;
    margin-bottom: var(--x1);
  }
  .post-tag {
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-faint);
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid rgba(153, 15, 61, 0.25);
  }
  .post-foot-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x3);
    margin-top: var(--x2);
  }
  .post-foot-nav a {
    display: block;
    text-decoration: none;
    padding: var(--x3);
    border: 1px solid var(--rule-strong);
    transition: border-color 0.2s, background 0.2s;
    color: inherit;
  }
  .post-foot-nav a:hover {
    border-color: var(--claret);
    background: var(--paper-soft);
  }
  .post-foot-nav-label {
    font-size: 9px;
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 500;
  }
  .post-foot-nav-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f6-size);
    line-height: 1.3;
    color: var(--ink);
  }
  .post-foot-nav .next { text-align: right; }

  @media (max-width: 600px) {
    .post-article { padding: 2.5rem var(--x3) 3.5rem; }
    .post-eyebrow-strip { padding: var(--x3); }
    .post-prose { font-size: var(--f6-size); }
    .post-prose > p:first-of-type::first-letter { font-size: 4.2em; }
    .post-foot-nav { grid-template-columns: 1fr; }
    .post-foot-nav .next { text-align: left; }
    .post-cta-row { flex-direction: column; gap: var(--x4); }
  }
</style>
