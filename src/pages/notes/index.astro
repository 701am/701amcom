---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const byYear = allNotes.reduce<Record<number, typeof allNotes>>((acc, note) => {
  const year = note.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(note);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

// Group by topic (top 3 per topic)
const topics = [
  'The angle',
  'The pitch',
  'Authority',
  'The trade',
  'Field notes',
  'The reading list',
] as const;
const byTopic: Record<string, typeof allNotes> = {};
for (const topic of topics) {
  byTopic[topic] = allNotes.filter((n) => n.data.topic === topic).slice(0, 3);
}

const totalCount = allNotes.length;
const dateFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' });
const countWords = (n: number): string => {
  if (n === 0) return 'No dispatches';
  if (n === 1) return 'One dispatch';
  if (n === 2) return 'Two dispatches';
  if (n === 3) return 'Three dispatches';
  return `${n} dispatches`;
};
---
<BaseLayout
  title="Dispatches from 701am — the archive"
  description="The complete archive of what we have written about earned media, big ideas, and the work of becoming impossible to ignore."
  pageType="collectionPage"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Dispatches' },
  ]}
>

  <header class="archive-masthead">
    <p class="archive-eyebrow">The morning record</p>
    <h1 class="archive-title">Dispatches <em>from 701am.</em></h1>
    <p class="archive-deck">
      The complete archive of what we have written about earned media, big ideas, and the work of becoming impossible to ignore.
    </p>
    <div class="archive-issue">
      <span><strong>№</strong> {String(totalCount).padStart(3, '0')} Issues</span>
      <span><strong>Est.</strong> at sunrise</span>
      <span><strong>Filed</strong> in perpetuity</span>
    </div>
  </header>

  <nav class="archive-nav">
    <a href="#by-topic">By topic</a>
    <a href="#by-date">By date</a>
  </nav>

  {totalCount === 0 && (
    <div class="archive-empty">
      <p>The record is still being filed. Check back at sunrise.</p>
    </div>
  )}

  {totalCount > 0 && (
    <>
      <section class="archive-section" id="by-topic">
        <div class="archive-section-label">
          <h2>Dispatches by <em>topic</em></h2>
          <span class="archive-count">§ I · Six categories</span>
        </div>
        <div class="archive-topics">
          {topics.map((topic) => (
            byTopic[topic].length > 0 && (
              <div class="archive-topic">
                <h3 class="archive-topic-name">{topic}</h3>
                <ul>
                  {byTopic[topic].map((note) => (
                    <li><a href={`/notes/${note.id}`}>{note.data.title}</a></li>
                  ))}
                </ul>
              </div>
            )
          ))}
        </div>
      </section>

      <section class="archive-section" id="by-date">
        <div class="archive-section-label">
          <h2>Dispatches by <em>date</em></h2>
          <span class="archive-count">§ II · The ledger</span>
        </div>

        {years.map((year) => (
          <div class="archive-year">
            <div class="archive-year-h">
              <div class="archive-year-num">{year}</div>
              <div class="archive-year-rule"></div>
              <div class="archive-year-count">{countWords(byYear[year].length)}</div>
            </div>
            <ul class="archive-entries">
              {byYear[year].map((note) => (
                <li class="archive-entry">
                  <div class="archive-entry-date">{dateFormatter.format(note.data.date)}</div>
                  <div class="archive-entry-title">
                    <a href={`/notes/${note.id}`}>{note.data.title}</a>
                  </div>
                  <div class="archive-entry-num">№ {String(note.data.number).padStart(3, '0')}</div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    </>
  )}

  <div class="archive-coda">
    <p>The record continues at sunrise.</p>
  </div>

</BaseLayout>

<style>
  .archive-masthead {
    padding: 4rem var(--x1) 2.5rem;
    text-align: center;
    border-bottom: 1px double var(--rule-strong);
    position: relative;
  }
  .archive-masthead::after {
    content: "";
    position: absolute;
    left: 50%; bottom: -3px;
    transform: translateX(-50%);
    width: 60px; height: 1px;
    background: var(--claret);
  }
  .archive-eyebrow {
    font-size: var(--f7-size);
    letter-spacing: 0.34em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x3);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
  }
  .archive-eyebrow::before, .archive-eyebrow::after {
    content: "";
    display: inline-block;
    width: 24px; height: 1px;
    background: rgba(153, 15, 61, 0.5);
  }
  .archive-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.8rem, 7vw, 4rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
  }
  .archive-title em { font-style: italic; font-weight: 400; color: var(--claret); }
  .archive-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: var(--f5-size);
    line-height: 1.5;
    color: var(--ink-faint);
    max-width: 32em;
    margin: 0 auto;
  }
  .archive-issue {
    display: flex;
    gap: var(--x2);
    justify-content: center;
    margin-top: var(--x2);
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    flex-wrap: wrap;
  }
  .archive-issue strong {
    color: var(--claret);
    font-weight: 500;
    margin-right: 6px;
  }

  .archive-nav {
    padding: var(--x3) var(--x1);
    text-align: center;
    border-bottom: 1px solid var(--rule);
    display: flex;
    justify-content: center;
    gap: var(--x2);
    flex-wrap: wrap;
  }
  .archive-nav a {
    color: var(--ink-faint);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 4px 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .archive-nav a:hover {
    color: var(--ink);
    border-bottom-color: var(--claret);
  }

  .archive-section {
    padding: var(--x1) var(--x1) calc(var(--x1) + var(--x3));
    border-bottom: 1px solid rgba(153, 15, 61, 0.12);
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .archive-section-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--x2);
    gap: var(--x3);
    flex-wrap: wrap;
  }
  .archive-section-label h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f3-size);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }
  .archive-section-label h2 em {
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .archive-count {
    font-size: var(--f7-size);
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 500;
  }

  /* by topic */
  .archive-topics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--x2) var(--x1);
  }
  .archive-topic {
    border-top: 1px solid var(--rule-strong);
    padding-top: var(--x3);
  }
  .archive-topic-name {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--f5-size);
    color: var(--claret);
    margin: 0 0 var(--x3);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .archive-topic ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .archive-topic li {
    padding: var(--x5) 0;
  }
  .archive-topic li a {
    color: var(--ink);
    text-decoration: none;
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f6-size);
    line-height: 1.4;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .archive-topic li a:hover {
    color: var(--claret);
    border-bottom-color: rgba(153, 15, 61, 0.4);
  }

  /* by date */
  .archive-year {
    padding: var(--x2) 0 var(--x3);
    border-bottom: 1px solid rgba(153, 15, 61, 0.12);
  }
  .archive-year:last-child { border-bottom: none; }
  .archive-year-h {
    display: flex;
    align-items: baseline;
    gap: var(--x3);
    margin-bottom: var(--x3);
  }
  .archive-year-num {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f2-size);
    font-weight: 400;
    font-style: italic;
    color: var(--claret);
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-variant-numeric: oldstyle-nums;
  }
  .archive-year-rule {
    flex: 1;
    height: 1px;
    background: rgba(153, 15, 61, 0.25);
  }
  .archive-year-count {
    font-size: var(--f7-size);
    letter-spacing: 0.32em;
    color: var(--ink-fainter);
    text-transform: uppercase;
  }
  .archive-entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .archive-entry {
    display: grid;
    grid-template-columns: 90px 1fr 80px;
    gap: var(--x3);
    padding: 9px 0;
    align-items: baseline;
    border-bottom: 1px dotted rgba(153, 15, 61, 0.1);
  }
  .archive-entry:last-child { border-bottom: none; }
  .archive-entry-date {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }
  .archive-entry-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f6-size);
    line-height: 1.4;
  }
  .archive-entry-title a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .archive-entry-title a:hover {
    color: var(--claret);
    border-bottom-color: rgba(153, 15, 61, 0.4);
  }
  .archive-entry-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: #5F6B85;
    text-align: right;
    font-variant-numeric: oldstyle-nums;
    letter-spacing: 0.02em;
  }

  .archive-empty {
    padding: var(--x1);
    text-align: center;
    color: var(--ink-faint);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f5-size);
  }

  .archive-coda {
    padding: var(--x1);
    text-align: center;
    border-top: 1px solid var(--rule);
  }
  .archive-coda p {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: var(--ink-fainter);
    margin: 0;
  }

  @media (max-width: 600px) {
    .archive-masthead { padding: 3rem var(--x3) 2rem; }
    .archive-section { padding: var(--x3) var(--x3) var(--x1); }
    .archive-topics { grid-template-columns: 1fr; gap: var(--x2); }
    .archive-entry { grid-template-columns: 70px 1fr; }
    .archive-entry-num { display: none; }
    .archive-year-num { font-size: 2.25rem; }
  }
</style>
