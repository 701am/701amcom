---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Agencies — Narrative Attraction Agency for Higher Education" description="White-label narrative attraction for agencies. Run earned media, AI visibility, and social campaigns for higher-ed clients without the headcount.">
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Agencies</div>
      <h1>White-label narrative attraction <em class="grad">for agencies</em>.</h1>
      <p class="lede">Add a narrative attraction arm for your higher-ed clients overnight. Earned media, AI visibility, and social campaigns. You keep the relationship; we deliver the results.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <aside class="contact-side" style="grid-column:1">
      <div class="cs-block">
        <h4>Our services for agencies</h4>
        <p>White-label narrative attraction for your higher-ed clients — earned media, AI search visibility, social & new media campaigns. Per-client, isolated, always on.</p>
        <a class="cs-link" href="/studio">See all services <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Narrative Attraction Session</h4>
        <p>Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer to write?</h4>
        <p>Send us a note and we'll follow up.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
    </aside>
  </div>
</Layout>

