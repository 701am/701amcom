---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Agencies — Digital PR for Higher Education" description="White-label earned media for agencies. Run earned media for higher-ed clients without the headcount. Book a discovery call with 701am.">
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Agencies</div>
      <h1>White-label earned media <em class="grad">for agencies</em>.</h1>
      <p class="lede">Add an earned media arm for your higher-ed clients overnight. You keep the relationship; we deliver the placements. Per-client, isolated, always on.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <div class="contact-form" id="contact-card">
      <div class="calendly-inline-widget" data-url="https://cal.com/davidkrug/discovery?overlayCalendar=true" style="min-width:320px;height:630px;border-radius:14px;overflow:hidden"></div>
    </div>

    <aside class="contact-side">
      <div class="cs-block">
        <h4>Our services for agencies</h4>
        <p>White-label earned media for your higher-ed clients. Per-client, isolated, always on.</p>
        <a class="cs-link" href="/studio">See all services <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Earned Media Session</h4>
        <p>Start with a $500 session — 90 minutes, data audit, reporter list. No obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer to write?</h4>
        <p>Send us a note and we'll follow up.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
    </aside>
  </div>
</Layout>

<script src="https://assets.cal.com/embed.js" async></script>