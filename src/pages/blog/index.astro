---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Founder Notes" description="Field notes on narrative attraction, earned media, AI visibility, and enrollment — from the team building 701am.">
<div class="ph">
  <p class="ey">Founder Notes</p>
  <h1>Field notes on <span class="g">narrative attraction</span>.</h1>
  <p>Bits worth not forgetting — earned media, AI visibility, and how higher-ed brands get found. Written while building 701am.</p>
</div>

<div class="bl">
  {posts.map((p) => (
    <a href={`/blog/${p.id}`}>
      <span class="bd">{fmt(p.data.date)}</span>
      <span class="bt">{p.data.title} →</span>
    </a>
  ))}
  {posts.length === 0 && (<p style="text-align:center;color:var(--txm);padding:40px 0">No notes yet — the first ones are on the way.</p>)}
</div>
</Layout>
