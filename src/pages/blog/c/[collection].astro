---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  const collections = [...new Set(posts.map((p) => p.data.collection))];
  return collections.map((c) => ({ params: { collection: c }, props: { collection: c, posts: posts.filter((p) => p.data.collection === c).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) } }));
}

const { collection, posts } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={`${collection} — Founder Notes`} description={`Collection: ${collection} — field notes on narrative attraction, earned media, AI visibility, and enrollment.`}>
<div class="ph">
  <p class="ey">Collection / {collection}</p>
  <h1><span class="g">{collection}</span></h1>
  <p>Notes in this collection.</p>
</div>

<div class="bl">
  {posts.map((p) => (
    <a href={`/blog/${p.id}`}>
      <span class="bd">{fmt(p.data.date)}</span>
      <span class="bt">{p.data.title} →</span>
    </a>
  ))}
</div>
</Layout>
