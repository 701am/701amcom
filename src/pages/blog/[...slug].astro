---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const subject = encodeURIComponent(`Re: ${post.data.title}`);

const allPosts = (await getCollection('blog')).filter((p) => !p.data.draft && p.id !== post.id);
const relatedPosts = allPosts
  .filter((p) => p.data.collection === post.data.collection)
  .slice(0, 3);
---
<Layout title={post.data.title} description={post.data.dek} ogType="article">
  <div class="back-link">
    <a href="/blog"><i class="ti ti-arrow-left"></i>Founder Notes</a>
  </div>

  <article class="post">
    <div class="post-meta-top">
      <div class="blog-author">
        <span class="av">D</span>
        <span class="ai">
          <span class="an">{post.data.author}</span>
          <span class="ad">{fmt(post.data.date)}</span>
        </span>
      </div>
    </div>

    <header class="blog-head" style="padding-top:24px">
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.dek}</p>
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((t) => <a href={`/blog/c/${post.data.collection}`}>{t}</a>)}
        </div>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>

    <div class="post-foot">
      <span class="share">
        Got thoughts on this post? Reply via
        <a href={`mailto:hello@701am.com?subject=${subject}`}>email</a>.
      </span>
    </div>

    {relatedPosts.length > 0 && (
      <div class="related-posts">
        <h4>More from this collection</h4>
        <div class="related-row">
          {relatedPosts.map((rp) => (
            <a href={`/blog/${rp.id}`} class="related-card">
              <div class="rt">{rp.data.title}</div>
              <div class="rd">{rp.data.dek}</div>
              <div class="rmeta">
                {rp.data.tags.slice(0, 2).map((t) => <span class="rtag">{t}</span>)}
                <span class="rdate">{fmt(rp.data.date)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="subscribe" id="sub-box">
      <h4>Get the next note at sunrise.</h4>
      <p>Occasional field notes on earned media and AI visibility for higher ed. No spam.</p>
      <form class="sub-row" id="sub-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="newsletter" />
        <input type="hidden" name="source" value="blog" />
        <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
        <input type="email" name="email" id="sub-email" placeholder="you@institution.edu" required />
        <button type="submit" id="sub-btn">Subscribe</button>
      </form>
      <div class="sub-done" id="sub-done" style="display:none;font-size:14px;color:var(--green-deep);margin-top:6px"><i class="ti ti-check"></i> You're subscribed. The next note arrives at sunrise.</div>
    </div>

    <script is:inline>
      (function () {
        var form = document.getElementById('sub-form');
        if (!form) return;
        function enc(d){return Object.keys(d).map(function(k){return encodeURIComponent(k)+'='+encodeURIComponent(d[k])}).join('&')}
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var emailEl = document.getElementById('sub-email');
          var btn = document.getElementById('sub-btn');
          var email = (emailEl && emailEl.value || '').trim();
          if (!/.+@.+\..+/.test(email)) { emailEl && emailEl.focus(); return; }
          btn.disabled = true; btn.textContent = 'Subscribing…';
          fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: enc({ 'form-name': 'newsletter', email: email, source: 'blog', 'bot-field': '' })
          }).then(function () {
            form.style.display = 'none';
            var done = document.getElementById('sub-done');
            if (done) done.style.display = 'block';
          }).catch(function () {
            btn.disabled = false; btn.textContent = 'Subscribe';
          });
        });
      })();
    </script>

    <div class="author-bio">
      <span class="av">D</span>
      <div class="bt">
        <h5>David Krug</h5>
        <p>Building 701am — the earned-media engine for higher education. Sometimes I share what I learn while building it.</p>
      </div>
    </div>
  </article>

  <style is:global>
    /* in-content CTA card */
    .cta-card{position:relative;max-width:62ch;margin:44px auto 20px;border-radius:var(--r-xl);overflow:hidden;background:var(--night);color:#fff}
    .cta-card::before{content:"";position:absolute;inset:0;border-radius:var(--r-xl);padding:1px;background:var(--sunrise);-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none}
    .cta-bg{position:absolute;inset:0;pointer-events:none}
    .cta-bg .cg{position:absolute;border-radius:50%;filter:blur(50px)}
    .cta-bg .cg1{width:340px;height:340px;right:-80px;top:-120px;background:radial-gradient(circle,rgba(238,106,76,.35),transparent 70%)}
    .cta-bg .cg2{width:260px;height:260px;left:-60px;bottom:-80px;background:radial-gradient(circle,rgba(90,87,200,.35),transparent 70%)}
    .cta-body{position:relative;z-index:1;padding:32px 30px}
    .cta-label{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--amber);margin-bottom:12px}
    .cta-label i{font-size:14px}
    .cta-body h3{font-family:var(--serif);font-weight:500;font-size:clamp(20px,2.8vw,24px);line-height:1.2;letter-spacing:-.016em;color:#fff;margin-bottom:10px}
    .cta-body p{font-size:14.5px;color:var(--night-txt-2);line-height:1.55;margin-bottom:18px;max-width:48ch}
    .cta-btn{display:inline-flex;align-items:center;gap:8px;height:44px;padding:0 22px;border-radius:11px;background:var(--sunrise);color:#fff;font-weight:600;font-size:14.5px;transition:.14s}
    .cta-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px -4px rgba(238,106,76,.55)}
    .cta-btn i{font-size:17px;transition:transform .14s}
    .cta-btn:hover i{transform:translateX(3px)}

    /* related posts */
    .related-posts{margin:48px auto 0;max-width:62ch}
    .related-posts h4{font-family:var(--serif);font-size:18px;font-weight:500;color:var(--ink);margin-bottom:18px;text-wrap:balance}
    .related-row{display:flex;flex-direction:column;gap:10px}
    .related-card{display:block;background:var(--paper);border:1px solid var(--line-2);border-radius:var(--r-lg);padding:18px 20px;transition:.14s}
    .related-card:hover{border-color:var(--line-3);box-shadow:var(--sh);transform:translateY(-2px)}
    .related-card .rt{font-size:15px;font-weight:600;color:var(--ink);letter-spacing:-.01em;margin-bottom:5px;line-height:1.3}
    .related-card:hover .rt{color:var(--coral-deep)}
    .related-card .rd{font-size:13px;color:var(--ink-2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .related-card .rmeta{display:flex;gap:8px;margin-top:8px}
    .related-card .rmeta .rtag{font-family:var(--mono);font-size:10px;font-weight:600;color:var(--coral-deep);background:var(--coral-soft);border-radius:5px;padding:2px 7px}
    .related-card .rmeta .rdate{font-family:var(--mono);font-size:10px;color:var(--ink-4)}
    @media(max-width:560px){
      .cta-body{padding:26px 22px}
      .cta-body h3{font-size:20px}
      .cta-body p{font-size:14px}
      .related-card{padding:16px 18px}
      .related-card .rt{font-size:14.5px}
    }
  </style>
</Layout>
