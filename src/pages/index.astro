---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="701am · Narrative Attraction Agency for Higher Ed">
<div class="hp">

<section class="hp-hero">
  <div class="hp-h-bg"></div>
  <div class="hp-h-deco">
    <svg class="hp-h-d1" width="260" height="260" viewBox="0 0 260 260"><circle cx="130" cy="130" r="110" stroke="#DD5A38" stroke-width="1" stroke-dasharray="6 16" fill="none" opacity=".15"/><circle cx="130" cy="130" r="70" fill="#DD5A38" opacity=".04"/></svg>
    <svg class="hp-h-d2" width="180" height="180" viewBox="0 0 180 180"><rect x="15" y="15" width="150" height="150" rx="22" stroke="#EFA23C" stroke-width="1" stroke-dasharray="5 12" fill="none" opacity=".15"/></svg>
    <svg class="hp-h-d3" width="100" height="100" viewBox="0 0 100 100"><path d="M50 4L54 37L85 50L54 63L50 96L46 63L15 50L46 37Z" fill="#CE5286" opacity=".05"/></svg>
  </div>
  <div class="hp-h-side">
    <div class="hp-h-sline"></div>
    <span class="hp-h-stxt">P R E S S · A I · S O C I A L</span>
    <div class="hp-h-sline"></div>
  </div>
  <div class="hp-h-in">
    <h1 class="hp-h-h">The enrollment cliff is <span class="hp-g">real</span>.</h1>
    <h2 class="hp-h-sh">Your story is your shield.</h2>
    <p class="hp-h-p">We put higher ed brand stories in the media, in AI search results, and in the feeds your future students actually scroll — so you fill seats instead of fighting for scraps.</p>
    <div class="hp-h-acts">
      <a href="#hp-price" class="hp-btn">Book a discovery call</a>
      <a href="/studio" class="hp-btn-o">See how it works →</a>
    </div>
    <p class="hp-h-meta">$6,500 per engagement · Up to 50 placements · No retainers</p>
  </div>
</section>

<section class="hp-mq">
  <p class="hp-mq-l">Trusted by</p>
  <div class="hp-mq-t">
    <div class="hp-mq-i">
      <a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a><span class="hp-mq-d"></span>
      <a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a><span class="hp-mq-d"></span>
      <a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a><span class="hp-mq-d"></span>
      <a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a><span class="hp-mq-d"></span>
      <a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a><span class="hp-mq-d"></span>
      <a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a><span class="hp-mq-d"></span>
      <a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a><span class="hp-mq-d"></span>
      <a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a><span class="hp-mq-d"></span>
      <a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a><span class="hp-mq-d"></span>
      <a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a><span class="hp-mq-d"></span>
      <a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a><span class="hp-mq-d"></span>
      <a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a><span class="hp-mq-d"></span>
    </div>
  </div>
</section>

<section class="hp-sec" id="approach">
  <div class="hp-w">
    <div class="hp-sh">
      <h2>Higher ed is facing a <span class="hp-g">convergence</span></h2>
      <p>Three threats reshaping the landscape. We help you meet each one head-on.</p>
    </div>
    <div class="hp-grid3">
      <article class="hp-c">
        <div class="hp-ci">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 16L7 9L11 13L18 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M18 9V4H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3>The enrollment cliff</h3>
        <p>High school graduating classes peaked in 2011. By 2027 there will be 200,000 fewer college-age students. The institutions with the strongest narratives will absorb the decline.</p>
      </article>
      <article class="hp-c">
        <div class="hp-ci">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="2"/></svg>
        </div>
        <h3>AI doesn&rsquo;t see you</h3>
        <p>When a student asks ChatGPT &ldquo;which college should I go to?&rdquo; your name isn&rsquo;t in the answer. We earn the authority that trains AI to recommend you.</p>
      </article>
      <article class="hp-c">
        <div class="hp-ci">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="2" width="16" height="16" rx="4" stroke="currentColor" stroke-width="2"/><path d="M6 10H14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M10 6V14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3>Students moved on</h3>
        <p>They&rsquo;re on TikTok, Instagram, YouTube, and Reddit. Traditional PR alone doesn&rsquo;t reach them. We create content that shows up where your applicants actually spend their time.</p>
      </article>
    </div>
  </div>
</section>

<section class="hp-dark">
  <div class="hp-dark-bg"></div>
  <div class="hp-w">
    <div class="hp-ag">
      <p class="hp-ag-l">The agency we always wanted</p>
      <h2>We know what it&rsquo;s like to hire an agency that overpromises and underdelivers. We built this one to <span class="hp-g">fix that</span>.</h2>
      <p class="hp-ag-p">We&rsquo;re intentionally boutique. We never take on more than 10 institutions at a time. We all have time to obsess over your success — and we do.</p>
      <div class="hp-ag-stats">
        <div class="hp-ag-s"><span class="hp-ag-n hp-g">20+</span><span class="hp-ag-lb">Years in higher ed</span></div>
        <div class="hp-ag-s"><span class="hp-ag-n hp-g">50+</span><span class="hp-ag-lb">Publications covered</span></div>
        <div class="hp-ag-s"><span class="hp-ag-n hp-g">50</span><span class="hp-ag-lb">Placements per engagement</span></div>
      </div>
    </div>
  </div>
</section>

<section class="hp-sec" id="services">
  <div class="hp-w">
    <div class="hp-sh">
      <h2>What we <span class="hp-g">do</span></h2>
      <p>Narrative Attraction — earning your institution visibility across every channel that influences enrollment.</p>
    </div>
    <div class="hp-grid3">
      <article class="hp-c">
        <p class="hp-c-step">01</p>
        <h3>Earned Media</h3>
        <p>We pitch your story to journalists covering higher ed and place it in outlets that families, faculty, and donors actually read. Relationships, not spray-and-pray.</p>
      </article>
      <article class="hp-c">
        <p class="hp-c-step">02</p>
        <h3>AI Search Visibility</h3>
        <p>We earn the citations, coverage, and authority signals that train ChatGPT, Perplexity, and Google AI to recommend your institution when it matters most.</p>
      </article>
      <article class="hp-c">
        <p class="hp-c-step">03</p>
        <h3>Social &amp; New Media</h3>
        <p>Platform-native content for TikTok, Instagram, YouTube, and Reddit — meeting prospective students where they actually discover, research, and decide.</p>
      </article>
    </div>
  </div>
</section>

<section class="hp-dark">
  <div class="hp-dark-bg"></div>
  <div class="hp-w">
    <div class="hp-sh">
      <h2>How we <span class="hp-g">work</span></h2>
      <p>From strategy to placement in 8–12 weeks. Every engagement follows the same proven process.</p>
    </div>
    <div class="hp-steps">
      <div class="hp-st">
        <p class="hp-st-n">01</p>
        <h3>Audit</h3>
        <p>We review your data, identify the stories you&rsquo;re not telling, and assess your visibility across press, AI, and social channels.</p>
      </div>
      <div class="hp-st">
        <p class="hp-st-n">02</p>
        <h3>Develop</h3>
        <p>We frame the narrative, write the pitches, build the reporter list, and create platform-specific content for each channel.</p>
      </div>
      <div class="hp-st">
        <p class="hp-st-n">03</p>
        <h3>Place</h3>
        <p>Human outreach to journalists, AI training data seeding, and social amplification. We work relationships, not databases.</p>
      </div>
      <div class="hp-st">
        <p class="hp-st-n">04</p>
        <h3>Report</h3>
        <p>Every placement tracked and correlated to enrollment metrics, search visibility, and AI citation share. You&rsquo;ll know exactly what&rsquo;s working.</p>
      </div>
    </div>
  </div>
</section>

<section class="hp-sec" id="hp-price">
  <div class="hp-w">
    <div class="hp-sh">
      <h2>Simple <span class="hp-g">pricing</span></h2>
      <p>No retainers. No long-term contracts.</p>
    </div>
    <div class="hp-price">
      <div class="hp-pc">
        <p class="hp-pc-l">Narrative Attraction Session</p>
        <div class="hp-pc-pr">$500</div>
        <p class="hp-pc-prd">one-time</p>
        <p class="hp-pc-d">90 minutes with our team. Strategy session, data audit, channel plan.</p>
        <ul class="hp-pc-f">
          <li><span class="hp-chk">✓</span>90-minute strategy session</li>
          <li><span class="hp-chk">✓</span>Data audit — find the stories</li>
          <li><span class="hp-chk">✓</span>Channel plan — press, AI, social</li>
          <li><span class="hp-chk">✓</span>No obligation to continue</li>
        </ul>
        <a href="#contact" class="hp-btn-o" style="width:100%;justify-content:center">Book your session</a>
      </div>
      <div class="hp-pc hp-pc-f">
        <p class="hp-pc-l" style="color:#EE6A4C">Narrative Attraction Engagement</p>
        <div class="hp-pc-pr hp-g">$6,500</div>
        <p class="hp-pc-prd" style="color:#B8A89C">per engagement</p>
        <p class="hp-pc-d" style="color:#B8A89C">Full campaign — research, narrative development, multi-channel outreach, reporting. Up to 50 placements.</p>
        <ul class="hp-pc-f" style="color:#B8A89C">
          <li><span class="hp-chk" style="color:#EE6A4C">✓</span>All services included</li>
          <li><span class="hp-chk" style="color:#EE6A4C">✓</span>Up to 50 placements</li>
          <li><span class="hp-chk" style="color:#EE6A4C">✓</span>AI citation tracking</li>
          <li><span class="hp-chk" style="color:#EE6A4C">✓</span>Monthly reporting + review</li>
          <li><span class="hp-chk" style="color:#EE6A4C">✓</span>No long-term contract</li>
        </ul>
        <a href="#contact" class="hp-btn" style="width:100%;justify-content:center">Book discovery call</a>
        <p class="hp-pc-n">Most engagements finish in 8–12 weeks</p>
      </div>
    </div>
  </div>
</section>

<section class="hp-sec" style="padding-top:0">
  <div class="hp-w">
    <div class="hp-clients">
      <a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a>
      <a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a>
      <a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a>
      <a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a>
      <a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a>
      <a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a>
    </div>
  </div>
</section>

{posts.length > 0 && (<section class="hp-sec" style="padding-top:0" id="notes">
  <div class="hp-w">
    <div class="hp-sh">
      <h2>Founder <span class="hp-g">Notes</span></h2>
      <p>Field notes on narrative attraction, earned media, and higher ed visibility.</p>
    </div>
    <div class="hp-notes">
      {posts.map((p) => (<a class="hp-ni" href={`/blog/${p.id}`}><span class="hp-nd">{fmt(p.data.date)}</span><span class="hp-nt">{p.data.title} →</span></a>))}
    </div>
    <div class="hp-nc"><a href="/blog" class="hp-btn-o">All notes →</a></div>
  </div>
</section>)}

<section class="hp-end" id="contact">
  <div class="hp-w">
    <div class="hp-end-in">
      <p class="hp-end-b">Narrative Attraction Agency for Higher Education</p>
      <h2>Ready to own your <span class="hp-g">story</span>?</h2>
      <p>The enrollment cliff won&rsquo;t wait. Neither should you. Let&rsquo;s talk.</p>
      <a href="#contact" class="hp-btn">Book a discovery call</a>
    </div>
  </div>
</section>

</div>
</Layout>

<style>
.hp {
  --cr: #F5EDE4;
  --dk: #2A1510;
  --dkc: #361D16;
  --dkb: #4A2820;
  --tx: #1E1412;
  --txm: #8B7E74;
  --txd: #EDE4DC;
  --txdm: #B8A89C;
  --co: #DD5A38;
  --am: #EFA23C;
  --bl: #E0D4C8;
}
.hp-g{background:linear-gradient(100deg,#EFA23C 0%,#EE6A4C 38%,#CE5286 68%,#5A57C8 110%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}

.hp-w{max-width:1120px;margin:0 auto;padding:0 28px;position:relative;z-index:2}
.hp-sh{text-align:center;max-width:620px;margin:0 auto 52px}
.hp-sh h2{font-family:'Newsreader',Georgia,serif;font-size:clamp(34px,4.5vw,52px);font-weight:500;letter-spacing:-.025em;line-height:1.08;margin-bottom:14px;color:var(--tx)}
.hp-sh p{font-size:17px;color:var(--txm);line-height:1.65}

.hp-hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:var(--cr)}
.hp-h-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 40% at 60% 20%,rgba(221,90,56,.06),transparent),radial-gradient(ellipse 50% 50% at 30% 80%,rgba(239,162,60,.05),transparent)}
.hp-h-deco{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.hp-h-deco svg{position:absolute}
.hp-h-d1{right:4%;top:6%}
.hp-h-d2{left:2%;bottom:18%}
.hp-h-d3{right:45%;bottom:8%}
.hp-h-side{position:absolute;left:24px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;align-items:center;gap:16px;z-index:3;pointer-events:none}
.hp-h-sline{width:1px;height:60px;background:var(--bl)}
.hp-h-stxt{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.3em;color:var(--txm);writing-mode:vertical-rl;text-orientation:mixed}
@media(max-width:900px){.hp-h-side{display:none}}
.hp-h-in{position:relative;z-index:2;text-align:center;max-width:780px;padding:100px 20px 80px}
.hp-h-h{font-family:'Newsreader',Georgia,serif;font-size:clamp(52px,8vw,96px);font-weight:500;letter-spacing:-.04em;line-height:.88;margin-bottom:12px;color:var(--tx)}
.hp-h-sh{font-family:'Newsreader',Georgia,serif;font-size:clamp(28px,4vw,48px);font-weight:400;letter-spacing:-.02em;line-height:1;color:var(--txm);margin-bottom:28px}
.hp-h-p{font-size:clamp(16px,1.5vw,19px);color:var(--txm);line-height:1.7;max-width:600px;margin:0 auto 36px}
.hp-h-acts{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:16px}
.hp-h-meta{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--txm);letter-spacing:.02em}
.hp-btn{display:inline-flex;align-items:center;height:54px;padding:0 32px;border-radius:100px;font-size:16px;font-weight:600;background:var(--co);color:#fff;transition:.12s;text-decoration:none}
.hp-btn:hover{background:#C84B2B;transform:translateY(-2px)}
.hp-btn-o{display:inline-flex;align-items:center;height:54px;padding:0 32px;border-radius:100px;font-size:16px;font-weight:600;color:var(--tx);border:1.5px solid var(--bl);background:rgba(255,255,255,.6);transition:.12s;text-decoration:none}
.hp-btn-o:hover{border-color:var(--co);color:var(--co);transform:translateY(-2px)}

.hp-mq{background:var(--dk);padding:32px 0 28px;overflow:hidden}
.hp-mq-l{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;text-align:center;color:var(--txdm);margin-bottom:18px;text-transform:uppercase}
.hp-mq-t{position:relative;overflow:hidden}
.hp-mq-t::before,.hp-mq-t::after{content:"";position:absolute;inset:0;width:100px;z-index:2;pointer-events:none}
.hp-mq-t::before{left:0;background:linear-gradient(90deg,var(--dk),transparent)}
.hp-mq-t::after{right:0;background:linear-gradient(270deg,var(--dk),transparent)}
.hp-mq-i{display:flex;align-items:center;gap:0;animation:hpmq 50s linear infinite;white-space:nowrap;width:max-content}
.hp-mq-i a{color:var(--txdm);font-size:13px;font-weight:500;padding:0 28px;flex-shrink:0;transition:color .15s;text-decoration:none}
.hp-mq-i a:hover{color:#fff}
.hp-mq-d{width:4px;height:4px;border-radius:50%;background:var(--co);flex-shrink:0}
@keyframes hpmq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

.hp-sec{padding:90px 0;position:relative;background:var(--cr)}
.hp-dark{padding:90px 0;position:relative;background:var(--dk);color:var(--txd);overflow:hidden}
.hp-dark-bg{position:absolute;inset:0;pointer-events:none}
.hp-dark-bg::before{content:"";position:absolute;left:20%;top:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(221,90,56,.08),rgba(239,162,60,.05),transparent 70%);border-radius:50%;filter:blur(100px)}
.hp-dark .hp-sh h2{color:#fff}
.hp-dark .hp-sh p{color:var(--txdm)}

.hp-grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1040px;margin:0 auto}
.hp-c{background:rgba(255,255,255,.7);border:1px solid var(--bl);border-radius:20px;padding:30px 28px;transition:.15s}
.hp-c:hover{border-color:#D0C4B8;transform:translateY(-4px)}
.hp-ci{width:44px;height:44px;border-radius:12px;background:rgba(221,90,56,.1);color:var(--co);display:flex;align-items:center;justify-content:center;margin-bottom:18px}
.hp-c-step{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--co);margin-bottom:14px}
.hp-c h3{font-size:18px;font-weight:600;margin-bottom:12px;color:var(--tx)}
.hp-c p{font-size:14.5px;color:var(--txm);line-height:1.65}

.hp-ag{text-align:center;max-width:720px;margin:0 auto;padding:20px 0;position:relative;z-index:2}
.hp-ag-l{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--am);margin-bottom:20px}
.hp-ag h2{font-family:'Newsreader',Georgia,serif;font-size:clamp(30px,4vw,44px);font-weight:500;letter-spacing:-.025em;line-height:1.12;margin-bottom:20px;color:#fff}
.hp-ag-p{font-size:18px;color:var(--txdm);line-height:1.7;max-width:540px;margin:0 auto 44px}
.hp-ag-stats{display:flex;justify-content:center;gap:44px;flex-wrap:wrap}
.hp-ag-s{text-align:center}
.hp-ag-n{font-family:'Newsreader',Georgia,serif;font-size:46px;font-weight:500;line-height:1;display:block}
.hp-ag-lb{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.06em;color:var(--txdm);display:block;margin-top:6px;text-transform:uppercase}

.hp-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1040px;margin:0 auto;position:relative;z-index:2}
.hp-st{background:var(--dkc);border:1px solid var(--dkb);border-radius:18px;padding:28px 24px;transition:.15s}
.hp-st:hover{border-color:rgba(221,90,56,.3);transform:translateY(-3px)}
.hp-st-n{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--am);margin-bottom:14px}
.hp-st h3{font-size:17px;font-weight:600;color:#fff;margin-bottom:10px}
.hp-st p{font-size:14px;color:var(--txdm);line-height:1.6}

.hp-price{display:grid;grid-template-columns:1fr 1fr;gap:28px;max-width:800px;margin:0 auto}
.hp-pc{background:rgba(255,255,255,.7);border:1px solid var(--bl);border-radius:24px;padding:36px 32px}
.hp-pc-f{background:var(--dk);border-color:var(--dkb);color:#fff}
.hp-pc-l{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--txm);margin-bottom:18px}
.hp-pc-pr{font-family:'Newsreader',Georgia,serif;font-size:52px;font-weight:500;letter-spacing:-.03em;line-height:1;color:var(--tx);margin-bottom:4px}
.hp-pc-f .hp-pc-pr{color:#fff}
.hp-pc-prd{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--txm);margin-bottom:22px}
.hp-pc-d{font-size:14.5px;color:var(--txm);line-height:1.65;margin-bottom:28px}
.hp-pc-f{list-style:none;padding:0;margin:0 0 30px;display:flex;flex-direction:column;gap:12px}
.hp-pc-f li{font-size:15px;color:var(--tx);display:flex;align-items:flex-start;gap:10px}
.hp-pc-f .hp-pc-f li{color:var(--txd)}
.hp-chk{color:#2F9468;font-weight:700;font-size:16px;flex-shrink:0;margin-top:1px}
.hp-pc-n{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--txdm);text-align:center;display:block;margin-top:16px}

.hp-clients{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;max-width:800px;margin:0 auto}
