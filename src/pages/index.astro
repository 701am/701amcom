---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout
  title="Digital PR Agency for Higher Education"
  description="701am is a digital PR agency for higher education. Earned media campaigns that get your institution in Inside Higher Ed and the press — up to 50 placements per engagement."
>
<!-- HERO -->
<header class="hero" id="top">
  <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-txt">
        <div class="pill-badge"><span class="tagm">Digital PR for Higher Education</span></div>
        <h1 class="hero-h">The PR agency that <em class="grad">higher education trusts</em>.</h1>
        <p class="hero-sub">We earn coverage in Inside Higher Ed, regional press, and the publications your applicants read — through data-driven campaigns that build credibility season after season. <b>Scoped engagements. No retainers.</b></p>
        <div class="hero-ctas">
          <a href="#contact" class="btn btn-primary btn-lg"><i class="ti ti-calendar"></i>Book a discovery call</a>
          <a href="#pricing" class="btn btn-soft btn-lg"><i class="ti ti-arrow-right"></i>See pricing</a>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- CREDIBILITY STRIP -->
<section class="band wrap" style="padding-top:0;padding-bottom:0">
  <div style="display:flex;justify-content:center;flex-wrap:wrap;gap:40px;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:28px 0;margin-top:-20px">
    <div style="text-align:center">
      <div style="font-family:var(--serif);font-size:32px;font-weight:500;letter-spacing:-.02em;color:var(--ink)">20+</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.04em">Years in higher ed visibility</div>
    </div>
    <div style="width:1px;background:var(--line)"></div>
    <div style="text-align:center">
      <div style="font-family:var(--serif);font-size:32px;font-weight:500;letter-spacing:-.02em;color:var(--ink)">50+</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.04em">Publications covered</div>
    </div>
    <div style="width:1px;background:var(--line)"></div>
    <div style="text-align:center">
      <div style="font-family:var(--serif);font-size:32px;font-weight:500;letter-spacing:-.02em;color:var(--ink)">$6,500</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.04em">Per engagement</div>
    </div>
    <div style="width:1px;background:var(--line)"></div>
    <div style="text-align:center">
      <div style="font-family:var(--serif);font-size:32px;font-weight:500;letter-spacing:-.02em;color:var(--ink)">50</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.04em">Placements per engagement</div>
    </div>
  </div>
</section>

<!-- THE PROBLEM -->
<section class="band wrap" id="problem">
  <div class="problem" style="max-width:720px;margin:0 auto">
    <div class="problem-eyebrow">The earned media problem</div>
    <h2 class="problem-h">Most institutions have the data. <br>None of it gets <em class="grad">covered</em>.</h2>
    <p class="problem-p">Your enrollment team knows the story — online grads who out-earn campus peers, programs with completion rates that beat the regional average, outcomes that should be headlines. But turning institutional data into press coverage requires bandwidth your team doesn't have. And traditional PR agencies charge $10K–$30K/month to produce a fraction of what we deliver in a single scoped engagement.</p>
  </div>
</section>

<!-- WHAT WE DO -->
<section class="band wrap" id="services">
  <div class="sec-head">
    <div class="sec-eyebrow">How we help</div>
    <h2>Full-cycle earned media for <em class="grad">higher education</em>.</h2>
    <p>From data audit to journalist outreach — every campaign scoped, staffed, and managed to deliver real placements in the outlets your applicants read.</p>
  </div>
  <div class="feat">
    <div class="feat-in">
      <div class="feat-txt">
        <div class="feat-eyebrow">Data-story campaigns</div>
        <h2>We find the story <em class="grad">in your data</em>.</h2>
        <p>Enrollment outcomes. Salary lift. Completion rates by region. Most institutions have the data for a story that gets covered — they just don't have the team to find the angle, write the pitch, and work the reporter list. We do all three.</p>
      </div>
      <div class="frag"><div class="frag-glow"></div><div class="frag-wrap">
        <div class="frag-h"><div class="ci"><i class="ti ti-chart-bar"></i></div><div class="ft">Example campaign</div></div>
        <div class="frag-b">
          <div class="cmd"><div class="cl">Institution</div><div class="cv">Online RN-to-BSN program, Midwest</div></div>
          <div class="cmd"><div class="cl">Data angle</div><div class="cv">Graduates out-earned regional avg by 19%</div></div>
          <div class="cmd"><div class="cl">Hook</div><div class="cv">Counter-intuitive: online grads, higher salaries</div></div>
          <div class="cmd"><div class="cl">Placements</div><div class="cv" style="color:var(--green-deep)"><i class="ti ti-circle-check"></i> Inside Higher Ed + 4 regional outlets</div></div>
        </div>
      </div></div>
    </div>
  </div>
  <div class="feat rev">
    <div class="feat-in">
      <div class="feat-txt">
        <div class="feat-eyebrow">Earned media that compounds</div>
        <h2>Every placement feeds <em class="grad">the next campaign</em>.</h2>
        <p>The mistake is treating earned media as a one-time event. We build coverage that compounds — a placement in Inside Higher Ed feeds search authority. A data study earns AI citations. Coverage from this cycle becomes the credibility foundation for the next.</p>
      </div>
      <div class="feat-txt">
        <div class="feat-eyebrow">AI citation strategy</div>
        <h2>Get named in <em class="grad">ChatGPT's answer</em>.</h2>
        <p>When prospective students ask an AI which program is best, your institution needs to be in the answer. We earn the signals — coverage, data, rankings — that AI models learn from and cite.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="layer-sec">
  <div class="atmos"><div class="dg dg1"></div><div class="dg dg2"></div></div>
  <div class="inner">
    <div class="wrap">
      <div class="layer-head">
        <div class="eb">Simple process</div>
        <h2>From story to <em class="grad">placement</em> in 8–12 weeks.</h2>
        <p>Every engagement follows the same repeatable process — adapted to your institution, your programs, and your market.</p>
      </div>
      <div class="layers">
        <div class="layer"><div class="num">01</div><h3><i class="ti ti-search"></i>Audit</h3><p>We review your institutional data, identify the stories you're not telling, and assess your current coverage position.</p></div>
        <div class="layer"><div class="num">02</div><h3><i class="ti ti-pencil"></i>Develop</h3><p>We frame the data, write the pitches, and build the reporter list for your strongest angles.</p></div>
        <div class="layer"><div class="num">03</div><h3><i class="ti ti-send"></i>Place</h3><p>Human outreach to journalists who cover your space. No mass emails. We work the relationships.</p></div>
        <div class="layer"><div class="num">04</div><h3><i class="ti ti-report-analytics"></i>Report</h3><p>Every placement tracked, correlated to search and AI visibility, and reported with the numbers that matter to enrollment leadership.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- WHO WE SERVE -->
<section class="band wrap">
  <div class="sec-head">
    <div class="sec-eyebrow">Who we work with</div>
    <h2>Higher ed is <em class="grad">all we do</em>.</h2>
    <p>We don't serve every industry. We've spent 20 years in education visibility — and it shows in how we think about your programs.</p>
  </div>
  <div class="forind" style="grid-template-columns:repeat(3,1fr)">
    <a class="ficard" href="/contact">
      <div class="fi" style="background:var(--gold-soft);color:var(--gold-deep)"><i class="ti ti-school"></i></div>
      <h3>Universities & Colleges</h3>
      <p>Full-cycle earned media for enrollment — placements in Inside Higher Ed, regional press, and the outlets your applicants read.</p>
      <span class="more">Get covered <i class="ti ti-arrow-right"></i></span>
    </a>
    <a class="ficard" href="/contact">
      <div class="fi" style="background:var(--indigo-soft);color:var(--indigo-deep)"><i class="ti ti-device-laptop"></i></div>
      <h3>Edtech & OPMs</h3>
      <p>Category authority through trade press, data studies, and thought leadership. Be the default choice because the coverage says so.</p>
      <span class="more">Get covered <i class="ti ti-arrow-right"></i></span>
    </a>
    <a class="ficard" href="/contact">
      <div class="fi" style="background:var(--coral-soft);color:var(--coral-deep)"><i class="ti ti-briefcase"></i></div>
      <h3>Agencies</h3>
      <p>White-label earned media for your higher-ed clients. You keep the relationship; we deliver the placements.</p>
      <span class="more">Get covered <i class="ti ti-arrow-right"></i></span>
    </a>
  </div>
</section>

<!-- PRICING -->
<section class="band wrap" id="pricing">
  <div class="sec-head">
    <div class="sec-eyebrow">Pricing</div>
    <h2>No retainers. <em class="grad">Scoped engagements.</em></h2>
    <p>Every engagement delivers a specific number of placements. Start with a low-commitment session — or book a discovery call to scope your campaign.</p>
  </div>
  <div class="pricing-cmp" style="max-width:760px;margin:0 auto">
    <div class="pcard">
      <div class="pc-head">
        <div class="pc-icon" style="background:var(--amber-soft);color:var(--amber-deep)"><i class="ti ti-calendar"></i></div>
        <div>
          <div class="pc-label">Earned Media Session</div>
          <div class="pc-sub">90-minute strategy session</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt">$500</span>
        <span class="pc-per">one-time</span>
      </div>
      <ul class="pc-feat">
        <li><i class="ti ti-check"></i>90-minute strategy session with our team</li>
        <li><i class="ti ti-check"></i>Data audit — find stories you're not telling</li>
        <li><i class="ti ti-check"></i>Reporter list for your top 3 angles</li>
        <li><i class="ti ti-check"></i>Credibility gap analysis</li>
        <li><i class="ti ti-check"></i>No obligation to continue</li>
      </ul>
      <a href="/contact" class="btn btn-soft btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book your session</a>
    </div>
    <div class="pcard pcard-701">
      <div class="pc-launch"><span class="pc-dot"></span>Most common engagement</div>
      <div class="pc-head">
        <div class="pc-icon pc-icon-grad"><i class="ti ti-rocket"></i></div>
        <div>
          <div class="pc-label" style="color:#fff">Earned Media Engagement</div>
          <div class="pc-sub" style="color:var(--night-txt)">Up to 50 placements</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt pc-amt-grad">$6,500</span>
        <span class="pc-per" style="color:var(--night-txt)">per engagement</span>
      </div>
      <ul class="pc-feat pc-feat-dark">
        <li><i class="ti ti-check"></i>Full campaign — research, narrative, outreach</li>
        <li><i class="ti ti-check"></i>Up to 50 placements in target outlets</li>
        <li><i class="ti ti-check"></i>AI citation tracking</li>
        <li><i class="ti ti-check"></i>Monthly reporting & strategy review</li>
        <li><i class="ti ti-check"></i>No long-term contract</li>
      </ul>
      <a href="/contact" class="btn btn-primary btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book a discovery call</a>
      <div class="pc-fine">Most engagements complete in 8–12 weeks.</div>
    </div>
  </div>
</section>

<!-- CONTACT SECTION -->
<section class="band wrap" id="contact">
  <div class="sec-head">
    <div class="sec-eyebrow">Get started</div>
    <h2>Ready to get <em class="grad">covered</em>?</h2>
    <p>Book a discovery call or send us a message. We'll respond within one business day.</p>
  </div>
  <div style="max-width:600px;margin:0 auto">
    <div style="background:var(--paper);border:1px solid var(--line-2);border-radius:16px;box-shadow:var(--sh-lg);overflow:hidden">
      <div style="padding:20px 24px;border-bottom:1px solid var(--line);font-family:var(--mono);font-size:12px;font-weight:600;color:var(--ink-3)">Book a discovery call — 30 minutes</div>
      <iframe src="https://cal.com/davidkrug/discovery?embed" width="100%" height="480" frameborder="0" style="border:none;display:block"></iframe>
    </div>
  </div>
</section>

<!-- FOUNDER NOTES PREVIEW -->
{posts.length > 0 && (
<section class="band wrap">
  <div class="sec-head">
    <div class="sec-eyebrow">Founder Notes</div>
    <h2>Field notes on earned media & <em class="grad">higher ed</em>.</h2>
  </div>
  <div class="notes" style="max-width:720px;margin:0 auto">
    {posts.map((p) => (
      <a class="note-row" href={`/blog/${p.id}`}>
        <span class="date">{fmt(p.data.date)}</span>
        <div class="nt">{p.data.title} <span class="arrow">→</span></div>
        <div class="nd">{p.data.dek}</div>
      </a>
    ))}
  </div>
  <div style="text-align:center;margin-top:28px">
    <a href="/blog" class="btn btn-soft btn-lg"><i class="ti ti-arrow-right"></i>All Founder Notes</a>
  </div>
</section>
)}

<!-- CLOSING -->
<section class="closing">
  <div class="catmos"><div class="cg"></div></div>
  <div class="wrap">
    <div class="pill-badge"><span class="tagm">Higher ed is all we do</span></div>
    <h2>Let's get your institution <em class="grad">covered</em>.</h2>
    <p>No long-term contracts. No retainer required. Just earned media that works.</p>
    <a href="#contact" class="btn btn-primary btn-lg"><i class="ti ti-calendar"></i>Book a discovery call</a>
  </div>
</section>
</Layout>