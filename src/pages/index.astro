---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout
  title="Digital PR Agency for Higher Education"
  description="701am is a digital PR agency for higher education. Earned media campaigns that get your institution in the press — up to 50 placements per engagement."
>
<!-- HERO -->
<header class="hero" id="top">
  <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-txt">
        <div class="pill-badge"><span class="tagm">Digital PR for Higher Education</span></div>
        <h1 class="hero-h">Your institution in the press — <em class="grad">consistently</em>.</h1>
        <p class="hero-sub">Earned media campaigns that get your university, college, or education brand covered — in Inside Higher Ed, regional outlets, and the publications your applicants already read. <b>Up to 50 placements per engagement.</b></p>
        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-lg"><i class="ti ti-calendar"></i>Book a discovery call</a>
          <a href="/studio" class="btn btn-soft btn-lg"><i class="ti ti-arrow-right"></i>See our services</a>
        </div>
        <div class="hero-ctas-meta">$500 intro session &nbsp;·&nbsp; $6,500 per engagement &nbsp;·&nbsp; No long-term contracts</div>
      </div>
      <div>
        <div class="cal-wrap">
          <div class="calendly-inline-widget" data-url="https://cal.com/davidkrug/discovery?overlayCalendar=true" style="min-width:320px;height:700px;"></div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- WHAT WE DO -->
<section class="band wrap" id="services">
  <div class="sec-head">
    <div class="sec-eyebrow">What we do</div>
    <h2>Full-funnel earned media for <em class="grad">higher education</em>.</h2>
    <p>From data-story research to journalist outreach to AI citation tracking — every campaign is scoped to get your institution covered in the outlets that matter to your applicants.</p>
  </div>
  <div class="feat">
    <div class="feat-in">
      <div class="feat-txt">
        <div class="feat-eyebrow">Data-driven pitches</div>
        <h2>We find the story <em class="grad">before you pitch it</em>.</h2>
        <p>Most institutions have the data for a great story — enrollment patterns, salary outcomes, completion rates, regional comparisons. The question is whether anyone ever turns it into a pitch. We do. We find the angle, write the story, and work the reporter list so your data actually earns coverage.</p>
      </div>
      <div class="frag"><div class="frag-glow"></div><div class="frag-wrap">
        <div class="frag-h"><div class="ci"><i class="ti ti-chart-bar"></i></div><div class="ft">Data story brief</div></div>
        <div class="frag-b">
          <div class="cmd"><div class="cl">Angle</div><div class="cv">Online grads out-earned campus peers by 14% — strongest in rural markets</div></div>
          <div class="cmd"><div class="cl">Hook</div><div class="cv">Counter-intuitive: online grads earn more than their on-campus counterparts</div></div>
          <div class="cmd"><div class="cl">Outlets</div><div class="cv">Inside Higher Ed, EdSurge, 3 regional business journals</div></div>
          <div class="cmd"><div class="cl">Status</div><div class="cv" style="color:var(--green-deep)"><i class="ti ti-circle-check"></i> Pitches sent</div></div>
        </div>
      </div></div>
    </div>
  </div>
  <div class="feat rev">
    <div class="feat-in">
      <div class="feat-txt">
        <div class="feat-eyebrow">Earned media that compounds</div>
        <h2>Every placement feeds <em class="grad">the next one</em>.</h2>
        <p>The mistake most institutions make is treating earned media as a campaign — a burst of effort that resets when the next cycle starts. We build an earned-media engine: every placement builds search authority, earns AI citations, and creates the relationships that make the next placement easier.</p>
      </div>
      <div class="feat-txt">
        <div class="feat-eyebrow">AI visibility</div>
        <h2>Get cited by <em class="grad">ChatGPT and Perplexity</em>.</h2>
        <p>AI assistants surface recommendations based on the same signals that have always mattered — rankings, outcomes data, and press coverage. We earn the signals that make you the answer when prospective students ask an AI which program is best.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHO WE SERVE -->
<section class="layer-sec">
  <div class="atmos"><div class="dg dg1"></div><div class="dg dg2"></div></div>
  <div class="inner">
    <div class="wrap">
      <div class="layer-head">
        <div class="eb">Who we serve</div>
        <h2>Earned media for every corner of <em class="grad">higher ed</em>.</h2>
        <p>Universities, colleges, edtech companies, and the agencies that serve them.</p>
      </div>
      <div class="layers">
        <div class="layer"><div class="num">01</div><h3><i class="ti ti-school"></i> Universities & Colleges</h3><p>Full-cycle earned media campaigns — from outcomes data studies to journalist outreach to regional press. Every placement tied to enrollment goals.</p></div>
        <div class="layer"><div class="num">02</div><h3><i class="ti ti-device-laptop"></i> Edtech & OPMs</h3><p>Category authority through trade press, data studies, and thought leadership. Be the platform institutions trust because the coverage says so.</p></div>
        <div class="layer"><div class="num">03</div><h3><i class="ti ti-briefcase"></i> Agencies</h3><p>White-label earned media for your higher-ed clients. You keep the relationship; we deliver the placements. Per-client, isolated, always on.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING PREVIEW -->
<section class="band wrap" id="pricing">
  <div class="sec-head">
    <div class="sec-eyebrow">Simple pricing</div>
    <h2>No retainers. <em class="grad">Scoped engagements.</em></h2>
    <p>Every engagement is scoped to deliver a specific number of placements — typically up to 50. Start with a $500 Earned Media Session to find your story.</p>
  </div>
  <div class="pricing-cmp" style="max-width:720px;margin:0 auto">
    <div class="pcard">
      <div class="pc-head">
        <div class="pc-icon" style="background:var(--amber-soft);color:var(--amber-deep)"><i class="ti ti-sparkles"></i></div>
        <div>
          <div class="pc-label">Earned Media Session</div>
          <div class="pc-sub">The intro — 90 minutes</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt">$500</span>
        <span class="pc-per">one-time</span>
      </div>
      <ul class="pc-feat">
        <li><i class="ti ti-check"></i>90-minute strategy session with our team</li>
        <li><i class="ti ti-check"></i>Data audit — find the stories you're not telling</li>
        <li><i class="ti ti-check"></i>Reporter list for your top 3 story angles</li>
        <li><i class="ti ti-check"></i>Credibility gap analysis</li>
        <li><i class="ti ti-check"></i>No obligation to continue</li>
      </ul>
      <a href="/contact" class="btn btn-soft btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book your session</a>
    </div>
    <div class="pcard pcard-701">
      <div class="pc-launch"><span class="pc-dot"></span>Our most common engagement</div>
      <div class="pc-head">
        <div class="pc-icon pc-icon-grad"><i class="ti ti-rocket"></i></div>
        <div>
          <div class="pc-label" style="color:#fff">Earned Media Engagement</div>
          <div class="pc-sub" style="color:var(--night-txt)">Up to 50 placements</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt pc-amt-grad">$6,500</span>
        <span class="pc-per" style="color:var(--night-txt)">per engagement</span>
      </div>
      <ul class="pc-feat pc-feat-dark">
        <li><i class="ti ti-check"></i>Full campaign — data research, narrative, pitches</li>
        <li><i class="ti ti-check"></i>Up to 50 placements in target outlets</li>
        <li><i class="ti ti-check"></i>AI citation tracking & optimization</li>
        <li><i class="ti ti-check"></i">Monthly reporting & strategy review</li>
        <li><i class="ti ti-check"></i>No long-term contract required</li>
      </ul>
      <a href="/contact" class="btn btn-primary btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book a discovery call</a>
      <div class="pc-fine">Most engagements complete in 8–12 weeks. Extensions available.</div>
    </div>
  </div>
</section>

<!-- RECENT FOUNDER NOTES -->
{posts.length > 0 && (
<section class="band wrap">
  <div class="sec-head">
    <div class="sec-eyebrow">Founder Notes</div>
    <h2>Field notes on earned media & <em class="grad">higher ed visibility</em>.</h2>
    <p>From the team building 701am — what we're learning about earned media, AI, and enrollment.</p>
  </div>
  <div class="notes" style="max-width:720px;margin:0 auto">
    {posts.map((p) => (
      <a class="note-row" href={`/blog/${p.id}`}>
        <span class="date">{fmt(p.data.date)}</span>
        <div class="nt">{p.data.title} <span class="arrow">→</span></div>
        <div class="nd">{p.data.dek}</div>
      </a>
    ))}
  </div>
  <div style="text-align:center;margin-top:28px">
    <a href="/blog" class="btn btn-soft btn-lg"><i class="ti ti-arrow-right"></i>All Founder Notes</a>
  </div>
</section>
)}

<!-- CLOSING -->
<section class="closing">
  <div class="catmos"><div class="cg"></div></div>
  <div class="wrap">
    <div class="pill-badge"><span class="tagm">Filed at sunrise</span></div>
    <h2>Get your institution <em class="grad">covered</em>.</h2>
    <p>Start with a $500 Earned Media Session — or book a discovery call to scope your campaign.</p>
    <a href="/contact" class="btn btn-primary btn-lg"><i class="ti ti-calendar"></i>Book a discovery call</a>
  </div>
</section>
</Layout>

<style>
.cal-wrap {
  background: var(--paper);
  border: 1px solid var(--line-2);
  border-radius: var(--r-xl);
  box-shadow: var(--sh-xl);
  overflow: hidden;
}
</style>

<script src="https://assets.cal.com/embed.js" async></script>