.pricing-note{font-family:var(--font-mono);font-size:11px;color:var(--text-dark-muted);text-align:center;display:block;margin-top:16px}

/* ===== CLIENTS ===== */
.client-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;max-width:800px;margin:0 auto}
.client-grid a{background:rgba(255,255,255,.7);backdrop-filter:blur(8px);border:1px solid var(--border-light);border-radius:12px;padding:12px 20px;font-size:14px;font-weight:500;color:var(--text);transition:.12s}
.client-grid a:hover{border-color:var(--coral);color:var(--coral);transform:translateY(-2px)}

/* ===== NOTES ===== */
.notes-list{max-width:640px;margin:0 auto;display:flex;flex-direction:column}
.note-item{display:flex;flex-direction:column;gap:4px;padding:22px 0;border-bottom:1px solid var(--border-light);transition:.12s}
.note-item:first-child{border-top:1px solid var(--border-light)}
.note-item:hover{padding-left:8px}
.note-date{font-family:var(--font-mono);font-size:11px;color:#A89A8E;text-transform:uppercase;letter-spacing:.03em}
.note-title{font-family:var(--font-serif);font-size:21px;font-weight:500;color:var(--text);transition:color .12s}
.note-item:hover .note-title{color:var(--coral)}
.notes-cta{text-align:center;margin-top:32px}

/* ===== CLOSING ===== */
.closing{text-align:center;padding:100px 0;background:var(--cream)}
.closing-inner{max-width:620px;margin:0 auto}
.closing-badge{display:inline-block;font-family:var(--font-mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--coral);border:1px solid var(--border-light);border-radius:100px;padding:7px 18px;margin-bottom:28px;background:rgba(255,255,255,.7)}
.closing h2{font-family:var(--font-serif);font-size:clamp(36px,5vw,56px);font-weight:500;letter-spacing:-.03em;line-height:1.06;margin-bottom:20px;color:var(--text)}
.closing p{font-size:18px;color:var(--text-muted);line-height:1.65;max-width:520px;margin:0 auto 36px}

/* ===== RESPONSIVE ===== */
@media(max-width:1000px){
  .grid-3{grid-template-columns:1fr;max-width:520px}
