---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="The earned-media engine for Higher Education"
  description="701am runs a swarm of agents that makes your institution the answer in AI, the result in Google, and the name in the press — built for universities, edtech, and the agencies that serve them."
>
<!-- gradient defs -->
<!-- HERO -->
<header class="hero" id="top">
  <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-txt">
        <div class="pill-badge"><span class="tagm">The earned-media engine for Higher Ed</span><span class="chip2">NOW IN BUILD</span></div>
        <h1 class="hero-h">Higher-ed visibility that <em class="grad">compounds</em>.</h1>
        <p class="hero-sub">A swarm of agents that makes your institution the answer when students ask AI, the result they find in Google, and the name they see in the press — turning every placement into a <b>visibility asset that compounds</b> through every enrollment cycle. For a fraction of a PR retainer.</p>
        <div class="hero-ctas">
          <button class="btn btn-primary btn-lg js-soon"><i class="ti ti-sparkles"></i>Get early access</button>
          <button class="btn btn-soft btn-lg js-soon"><i class="ti ti-player-play"></i>See it work</button>
        </div>
        </div>
      <!-- HERO FRAGMENT: swarm running -->
      <div class="frag"><div class="frag-glow"></div><div class="frag-wrap">
        <div class="frag-h"><div class="ci"><i class="ti ti-sparkles"></i></div><div class="ft">The Desk</div><div class="live"><i class="ti ti-circle-filled"></i>Working</div></div>
        <div class="frag-b">
          <div class="cmd"><div><div class="cl">Goal, in plain English</div><div class="cv">"Make us the program AI recommends for online nursing degrees."</div></div></div>
          <div class="swarm">
            <span class="ad" style="left:30%;top:18%;animation-delay:0s"></span>
            <span class="ad c" style="left:64%;top:12%;animation-delay:.5s"></span>
            <span class="ad a" style="left:72%;top:54%;animation-delay:1s"></span>
            <span class="ad" style="left:22%;top:60%;animation-delay:1.5s"></span>
            <span class="ad c" style="left:46%;top:6%;animation-delay:.8s"></span>
            <span class="ad a" style="left:56%;top:70%;animation-delay:1.3s"></span>
            <div class="core">7</div>
            <div class="lbl"><span class="sp"></span>a swarm of agents, working your goal</div>
          </div>
        </div>
      </div></div>
    </div>
  </div>
</header>

<!-- WORKS WITH -->
<section class="works wrap">
  <div class="wl">Working everywhere students and decision-makers now look</div>
  <div class="works-row">
    <div class="it"><i class="ti ti-message-chatbot"></i>ChatGPT</div>
    <div class="it"><i class="ti ti-search"></i>Perplexity</div>
    <div class="it"><i class="ti ti-sparkles"></i>Claude</div>
    <div class="it"><i class="ti ti-stars"></i>Gemini</div>
    <div class="it"><i class="ti ti-brand-google"></i>Google</div>
    <div class="it"><i class="ti ti-news"></i>The press</div>
  </div>
</section>

<!-- NAMED PROBLEM -->
<section class="band wrap">
  <div class="problem">
    <div class="problem-eyebrow">The discovery problem</div>
    <h2 class="problem-h">Every enrollment cycle still starts from <em class="grad">zero</em>.<br><span class="problem-until">Until 701am.</span></h2>
    <p class="problem-p">Your visibility is scattered — a ranking here, a mention there, a campaign that resets when the cycle ends. Meanwhile applicants have stopped Googling and started asking AI which program is best, months before they ever inquire. The institutions that show up in those answers are winning enrollment quietly. 701am makes every placement, ranking, and citation compound into the next.</p>
  </div>
</section>

<!-- FEATURE ROW 1: AI visibility — channels fragment -->
<section class="feat wrap" id="how">
  <div class="feat-in">
    <div class="feat-txt">
      <div class="feat-eyebrow">Be the answer</div>
      <h2>Show up when students ask <em class="grad">the AI</em>.</h2>
      <p>Your next applicant asks ChatGPT, Perplexity, or Claude which program is best long before they reach your site. 701am earns the rankings, outcomes data, and coverage those models learn from — so your institution is the name that comes back.</p>
      <div class="fmini"><span class="m">ChatGPT</span><span class="m">Perplexity</span><span class="m">Claude</span><span class="m">Gemini</span><span class="m">AI Overviews</span></div>
    </div>
    <div class="frag" id="fragChannels"><div class="frag-glow"></div><div class="frag-wrap">
      <div class="frag-h"><div class="ci"><i class="ti ti-broadcast"></i></div><div class="ft">Visibility — all channels</div><div class="live"><i class="ti ti-circle-filled"></i>Live</div></div>
      <div class="frag-b"><div class="chans">
        <div class="chrow"><div class="chi" style="background:var(--indigo-soft);color:var(--indigo-deep)"><i class="ti ti-message-chatbot"></i></div><div class="chn">ChatGPT</div><div class="chr cite"><i class="ti ti-quote"></i>Cited</div></div>
        <div class="chrow"><div class="chi" style="background:var(--indigo-soft);color:var(--indigo-deep)"><i class="ti ti-search"></i></div><div class="chn">Perplexity</div><div class="chr cite"><i class="ti ti-quote"></i>Sourced</div></div>
        <div class="chrow"><div class="chi" style="background:var(--green-soft);color:var(--green-deep)"><i class="ti ti-brand-google"></i></div><div class="chn">Google</div><div class="chr up"><i class="ti ti-trending-up"></i>+18</div></div>
        <div class="chrow"><div class="chi" style="background:var(--coral-soft);color:var(--coral-deep)"><i class="ti ti-news"></i></div><div class="chn">Earned media</div><div class="chr place"><i class="ti ti-circle-check"></i>12 placed</div></div>
      </div></div>
    </div></div>
  </div>
</section>

<!-- FEATURE ROW 2: autopilot — slack fragment (reversed) -->
<section class="feat wrap" id="autopilot">
  <div class="feat-in">
    <div class="feat-txt">
      <div class="feat-eyebrow">Set it once</div>
      <h2>It runs at <em class="grad">sunrise</em>, every day.</h2>
      <p>Connect your tools, set a cadence, and the swarm works in the background — finding opportunities, earning coverage, watching the news cycle, and reporting back. Tag it, schedule it, or let it run proactively.</p>
      <div class="fmini"><span class="m">Schedules</span><span class="m">Slack</span><span class="m">Email</span><span class="m">CRM</span><span class="m">Always-on</span></div>
    </div>
    <div class="frag"><div class="frag-glow"></div><div class="frag-wrap">
      <div class="frag-h"><div class="ci"><i class="ti ti-brand-slack"></i></div><div class="ft">#press-room</div><div class="live"><i class="ti ti-circle-filled"></i>Auto</div></div>
      <div class="frag-b"><div class="slack">
        <div class="sk-msg"><div class="sk-av usr">DK</div><div class="sk-b"><div class="sk-nm">David</div><div class="sk-tx">@701am any angles on the new grad-outcomes data for our nursing program?</div></div></div>
        <div class="sk-msg"><div class="sk-av bot">7</div><div class="sk-b"><div class="sk-nm">701am <span class="tag">AGENT</span></div><div class="sk-tx">Found one. Your online nursing grads out-earned the regional average by <b>14%</b> — strongest in rural placements. Drafted 9 pitches to higher-ed and regional reporters.</div>
          <div class="sk-card"><i class="ti ti-circle-check"></i>9 pitches staged · awaiting your approval</div>
        </div></div>
      </div></div>
    </div></div>
  </div>
</section>

<!-- FEATURE ROW 3: measurable — dashboard fragment -->
<section class="feat wrap">
  <div class="feat-in">
    <div class="feat-txt">
      <div class="feat-eyebrow">You watch it climb</div>
      <h2>Visibility you can finally <em class="grad">measure</em>.</h2>
      <p>No vague "impressions." Live visibility into exactly where you're showing up — across AI, search, and the press — with every number traced back to a real placement, citation, or ranking. No vanity metrics.</p>
      <div class="fmini"><span class="m">AI citations</span><span class="m">Rankings</span><span class="m">Placements</span><span class="m">Reach</span></div>
    </div>
    <div class="frag"><div class="frag-glow"></div><div class="frag-wrap">
      <div class="frag-h"><div class="ci"><i class="ti ti-chart-arcs"></i></div><div class="ft">Dashboard · last 30 days</div><div class="live"><i class="ti ti-circle-filled"></i>Live</div></div>
      <div class="frag-b"><div class="dboard">
        <div class="dcell"><div class="dl"><i class="ti ti-robot"></i>AI citations</div><div class="dv">47</div><div class="dd"><i class="ti ti-trending-up"></i>+31</div></div>
        <div class="dcell"><div class="dl"><i class="ti ti-brand-google"></i>Avg. rank</div><div class="dv">#6</div><div class="dd"><i class="ti ti-trending-up"></i>+18</div></div>
        <div class="dcell"><div class="dl"><i class="ti ti-news"></i>Placements</div><div class="dv">12</div><div class="dd"><i class="ti ti-trending-up"></i>+9</div></div>
        <div class="dcell"><div class="dl"><i class="ti ti-broadcast"></i>Reach</div><div class="dv">4.2M</div><div class="dd"><i class="ti ti-trending-up"></i>+22%</div></div>
      </div></div>
    </div></div>
  </div>
</section>

<!-- CAPABILITY GRID (Runtime "every layer") -->
<section class="layer-sec">
  <div class="atmos"><div class="dg dg1"></div><div class="dg dg2"></div></div>
  <div class="inner">
    <div class="wrap">
      <div class="layer-head">
        <div class="eb">One engine</div>
        <h2>Everything earned media needs. Built in.</h2>
        <p>Research, outreach, monitoring, measurement — the work an agency charges a retainer for, running continuously and compounding.</p>
      </div>
      <div class="layers">
        <div class="layer"><div class="num">01</div><h3><i class="ti ti-search"></i>Research</h3><p>Finds the angle, the data, and the right reporters before a word is written.</p></div>
        <div class="layer"><div class="num">02</div><h3><i class="ti ti-mail-forward"></i>Outreach</h3><p>Writes and sends pitches that sound human — and stages everything for your approval.</p></div>
        <div class="layer"><div class="num">03</div><h3><i class="ti ti-radar"></i>Monitoring</h3><p>Watches the news cycle and your coverage, and jumps on the moment it breaks.</p></div>
        <div class="layer"><div class="num">04</div><h3><i class="ti ti-robot"></i>AI visibility</h3><p>Earns the signals that make you the answer in ChatGPT, Perplexity, and Claude.</p></div>
        <div class="layer"><div class="num">05</div><h3><i class="ti ti-chart-bar"></i>Measurement</h3><p>Tracks citations, rankings, and placements — every number traced to a source.</p></div>
        <div class="layer"><div class="num">06</div><h3><i class="ti ti-shield-check"></i>Quality gate</h3><p>Nothing goes out that the brand can't stand behind. You stay in control.</p></div>
      </div>
      <div class="layer-foot">Hire an agency for all of this — or skip the retainer.</div>
    </div>
  </div>
</section>

<!-- FOR EVERY INDUSTRY (Runtime "for every team") -->
<section class="band wrap">
  <div class="sec-head">
    <div class="sec-eyebrow">Who we serve</div>
    <h2>One engine, tuned to <em class="grad">your corner of higher ed</em>.</h2>
    <p>Universities, edtech, and the agencies who serve them. Same compounding visibility — pointed at your goals.</p>
  </div>
  <div class="forind" style="grid-template-columns:repeat(3,1fr)">
    <a class="ficard" href="universities.html">
      <div class="fi" style="background:var(--gold-soft);color:var(--gold-deep)"><i class="ti ti-school"></i></div>
      <h3>Universities</h3><p>Be the program students find first. Rankings, outcomes data, and the coverage that drives enrollment.</p>
      <span class="more">For enrollment teams <i class="ti ti-arrow-right"></i></span>
    </a>
    <a class="ficard" href="edtech.html">
      <div class="fi" style="background:var(--indigo-soft);color:var(--indigo-deep)"><i class="ti ti-device-laptop"></i></div>
      <h3>Edtech &amp; OPMs</h3><p>Be the platform institutions trust. Trade press, sector data studies, and category authority.</p>
      <span class="more">For edtech companies <i class="ti ti-arrow-right"></i></span>
    </a>
    <a class="ficard" href="agencies.html">
      <div class="fi" style="background:var(--coral-soft);color:var(--coral-deep)"><i class="ti ti-briefcase"></i></div>
      <h3>Agencies</h3><p>Run earned media for every client without the headcount. Scoped, isolated, always on.</p>
      <span class="more">For agencies <i class="ti ti-arrow-right"></i></span>
    </a>
  </div>
</section>

<!-- PRICING TEASER / VS -->
<section class="band wrap" id="pricing">
  <div class="sec-head">
    <div class="sec-eyebrow">The math</div>
    <h2>Everything a PR agency does. <em class="grad">None of the retainer.</em></h2>
    <p>Traditional PR is slow, opaque, and priced for enterprises. 701am does more, continuously, for a fraction.</p>
  </div>
  <div class="forind" style="grid-template-columns:1fr 1fr;max-width:880px;margin:0 auto">
    <div class="ficard" style="cursor:default">
      <div class="fi" style="background:var(--canvas-2);color:var(--ink-3)"><i class="ti ti-building-bank"></i></div>
      <h3 style="color:var(--ink-2)">A PR agency</h3>
      <p><b style="font-family:var(--mono);color:var(--ink-2)">$8k–20k/mo</b> retainer · weeks to a first placement · opaque reporting · media only, blind to AI &amp; search.</p>
    </div>
    <div class="ficard" style="cursor:default;background:var(--night)">
      <div class="fi" style="background:rgba(255,255,255,.08);color:#E89B7E"><i class="ti ti-sparkles"></i></div>
      <h3 style="color:#fff">701am</h3>
      <p style="color:var(--night-txt-2)"><b style="font-family:var(--mono);color:#fff">A fraction</b> · days to a first placement · measurable across AI, search &amp; media · a swarm that scales without hiring.</p>
      <span class="more js-soon" style="color:#E89B7E">See pricing <i class="ti ti-arrow-right"></i></span>
    </div>
  </div>
</section>

<!-- CLOSING -->
<section class="closing">
  <div class="catmos"><div class="cg"></div></div>
  <div class="wrap">
    <div class="pill-badge"><span class="tagm">Filed at sunrise</span></div>
    <h2>Be impossible to <em class="grad">miss</em>.</h2>
    <p>701am is opening to a first group of higher-ed teams. Put your name down.</p>
    <button class="btn btn-primary btn-lg js-soon"><i class="ti ti-sparkles"></i>Get early access</button>
  </div>
</section>

</div>
</Layout>

<script is:inline>
function wait(ms){return new Promise(r=>setTimeout(r,ms));}
  async function lightRows(){const rows=[...document.querySelectorAll('#fragChannels .chrow')];for(const r of rows){r.classList.add('lit');await wait(360);}}
  const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){lightRows();io.disconnect();}});},{threshold:.4});
  const fc=document.getElementById('fragChannels');if(fc)io.observe(fc);
</script>
