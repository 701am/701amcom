---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout
  title="Narrative Attraction Agency for Higher Education"
  description="701am is a narrative attraction agency for higher education. We put brand stories in the media and increase enrollment while fending off the enrollment cliff."
>
<!-- HERO -->
<header class="hero">
  <div class="hero-atmos">
    <div class="grid"></div>
    <div class="deco deco-1"><svg width="200" height="200" viewBox="0 0 200 200" fill="none"><circle cx="100" cy="100" r="90" stroke="url(#sunGrad)" stroke-width="1.5" stroke-dasharray="6 10"/><circle cx="100" cy="100" r="60" stroke="url(#sunGrad)" stroke-width="1" stroke-dasharray="3 7"/><circle cx="100" cy="100" r="30" fill="url(#sunGrad)" opacity=".06"/></svg></div>
    <div class="deco deco-2"><svg width="140" height="140" viewBox="0 0 140 140" fill="none" style="transform:rotate(30deg)"><rect x="10" y="10" width="120" height="120" rx="16" stroke="url(#sunGrad)" stroke-width="1.5" stroke-dasharray="5 9"/><rect x="30" y="30" width="80" height="80" rx="10" fill="url(#sunGrad)" opacity=".05"/></svg></div>
    <div class="deco deco-3"><svg width="100" height="100" viewBox="0 0 100 100" fill="none"><path d="M50 10L55 40L85 50L55 60L50 90L45 60L15 50L45 40Z" fill="url(#sunGrad)" opacity=".08"/></svg></div>
  </div>
  <div class="wrap">
    <div class="hero-flex">
      <div class="hero-txt">
        <div class="badge">Narrative Attraction Agency for Higher Education</div>
        <h1 class="hero-title">The enrollment cliff is real.<br>Your story is your <em class="grad">shield</em>.</h1>
        <p class="hero-sub">We put higher ed brand stories in the media, in AI search results, and in the feeds your future students actually scroll — so you fill seats instead of fighting for scraps.</p>
        <div class="hero-actions">
          <a href="#pricing" class="btn btn-primary btn-lg btn-studio"><i class="ti ti-calendar"></i>Book a discovery call</a>
          <a href="#how" class="btn btn-soft btn-lg"><i class="ti ti-arrow-right"></i>How it works</a>
        </div>
        <p class="hero-meta">$6,500 per engagement · Up to 50 placements · No retainers</p>
      </div>
      <div class="hero-right">
        <div class="stat-card"><span class="num">50+</span><span class="lbl">Publications</span></div>
        <div class="stat-card"><span class="num">20+</span><span class="lbl">Years in higher ed</span></div>
        <div class="stat-card"><span class="num">$6,500</span><span class="lbl">Per engagement</span></div>
        <div class="stat-card dark"><span class="num">50</span><span class="lbl">Placements guaranteed</span></div>
      </div>
    </div>
  </div>
</header>

<!-- CLIENT MARQUEE -->
<section class="marquee-wrap">
  <p class="marquee-label">Trusted by leading higher ed platforms</p>
  <div class="marquee-track">
    <div class="marquee-inner">
      <a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a><span class="dot"></span>
      <a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a><span class="dot"></span>
      <a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a><span class="dot"></span>
      <a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a><span class="dot"></span>
      <a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a><span class="dot"></span>
      <a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a><span class="dot"></span>
      <a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a><span class="dot"></span>
      <a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a><span class="dot"></span>
      <a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a><span class="dot"></span>
      <a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a><span class="dot"></span>
      <a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a><span class="dot"></span>
      <a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a><span class="dot"></span>
    </div>
  </div>
</section>

<!-- PROBLEMS -->
<section class="section light" id="approach">
  <div class="wrap">
    <div class="sec-head">
      <h2>The stakes are <em class="grad">higher</em> than ever</h2>
      <p>Higher ed is facing three converging threats. We help you turn all three into advantages.</p>
    </div>
    <div class="grid-3">
      <div class="card">
        <div class="card-icon"><i class="ti ti-graph-down-arrow"></i></div>
        <h3>The enrollment cliff is here</h3>
        <p>High school graduating classes peaked in 2011. By 2027 there will be 200,000 fewer college-age students. The institutions with the strongest brand narratives will absorb the decline. Everyone else fights for what's left.</p>
      </div>
      <div class="card">
        <div class="card-icon"><i class="ti ti-robot"></i></div>
        <h3>AI doesn't recommend you</h3>
        <p>When prospective students ask ChatGPT, Perplexity, or Google AI which school is best, your institution isn't in the answer. We earn the media coverage that trains AI models to cite you instead of your competitors.</p>
      </div>
      <div class="card">
        <div class="card-icon"><i class="ti ti-device-mobile"></i></div>
        <h3>Students aren't reading press releases</h3>
        <p>They're on TikTok, Instagram, YouTube, and Reddit. Traditional PR alone doesn't reach them. We create content and earn placements that show up where your applicants actually spend their time.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<section class="section dark" id="services">
  <div class="wrap">
    <div class="sec-head">
      <h2>What we <em class="grad">do</em></h2>
      <p>We call it Narrative Attraction — earning your institution visibility across every channel that influences enrollment decisions.</p>
    </div>
    <div class="grid-3 svc-grid">
      <div class="svc-card">
        <div class="svc-num">01</div>
        <div class="svc-icon"><i class="ti ti-newspaper"></i></div>
        <h3>Earned Media</h3>
        <p>We pitch and place your story in Inside Higher Ed, The Chronicle, regional outlets, and national education press — reaching the faculty, families, and journalists who shape institutional reputation.</p>
        <div class="svc-tags">
          <span>Press placements</span><span>Thought leadership</span><span>Data stories</span>
        </div>
      </div>
      <div class="svc-card">
        <div class="svc-num">02</div>
        <div class="svc-icon"><i class="ti ti-bolt"></i></div>
        <h3>AI Search Visibility</h3>
        <p>We earn the coverage, citations, and authority signals that train ChatGPT, Perplexity, and other AI models to recommend your institution when prospective students ask which school to choose.</p>
        <div class="svc-tags">
          <span>AI citations</span><span>LLM training signals</span><span>Generative engine optimization</span>
        </div>
      </div>
      <div class="svc-card">
        <div class="svc-num">03</div>
        <div class="svc-icon"><i class="ti ti-video"></i></div>
        <h3>Social & New Media</h3>
        <p>We create and amplify content for TikTok, Instagram, YouTube, and Reddit — meeting prospective students on the platforms where they actually discover, research, and choose their institutions.</p>
        <div class="svc-tags">
          <span>Social storytelling</span><span>Creator partnerships</span><span>Platform-native content</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section light" id="how">
  <div class="wrap">
    <div class="sec-head">
      <h2>How we <em class="grad">work</em></h2>
      <p>From strategy to placement in 8–12 weeks. Every engagement follows the same proven process.</p>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>Audit</h3>
          <p>We review your institutional data, identify the stories hiding in plain sight, and assess your current visibility across press, AI, and social channels.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>Develop</h3>
          <p>We frame the narrative, write the pitches, build the reporter list, and create platform-specific content for each channel in your strategy.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>Place</h3>
          <p>Human outreach to journalists, AI training data seeding, and social amplification. No mass emails. We work relationships, not databases.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">04</div>
        <div class="step-body">
          <h3>Report</h3>
          <p>Every placement tracked and correlated to enrollment metrics, search visibility, and AI citation share. You'll know exactly what moved the needle.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TRUSTED BY -->
<section class="section cream">
  <div class="wrap">
    <div class="sec-head">
      <h2>Trusted by leading <em class="grad">higher ed platforms</em></h2>
      <p>We've earned coverage and built brand narratives for the institutions that help students make decisions.</p>
    </div>
    <div class="client-grid">
      <div class="client-item"><a href="https://collegechoice.net" target="_blank">CollegeChoice.net</a></div>
      <div class="client-item"><a href="https://thebestschools.org" target="_blank">TheBestSchools.org</a></div>
      <div class="client-item"><a href="https://affordableschools.net" target="_blank">AffordableSchools.net</a></div>
      <div class="client-item"><a href="https://onlineschoolscenter.com" target="_blank">OnlineSchoolsCenter.com</a></div>
      <div class="client-item"><a href="https://collegevaluesonline.com" target="_blank">CollegeValuesOnline.com</a></div>
      <div class="client-item"><a href="https://collegeconsensus.com" target="_blank">CollegeConsensus.com</a></div>
      <div class="client-item" style="background:transparent;border:1px dashed var(--line-3);color:var(--ink-3);font-size:14px;font-weight:500;">and many more</div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section light" id="pricing">
  <div class="wrap">
    <div class="sec-head">
      <h2>Simple <em class="grad">pricing</em></h2>
      <p>No retainers. No long-term contracts. Every engagement scoped to deliver a specific number of placements.</p>
    </div>
    <div class="pricing-grid">
      <div class="pricing-card">
        <div class="pc-tag">Earned Media Session</div>
        <div class="pc-price">$500</div>
        <p class="pc-per">one-time</p>
        <p class="pc-desc">90 minutes with our team. Strategy session, data audit, story identification, reporter list. No obligation to continue.</p>
        <ul class="pc-features">
          <li><i class="ti ti-check"></i>90-minute strategy session</li>
          <li><i class="ti ti-check"></i>Data audit — find the stories</li>
          <li><i class="ti ti-check"></i>Reporter list for top 3 angles</li>
          <li><i class="ti ti-check"></i>Credibility gap analysis</li>
          <li><i class="ti ti-check"></i>No obligation to continue</li>
        </ul>
        <a href="#contact" class="btn btn-soft btn-lg" style="width:100%"><i class="ti ti-calendar"></i>Book your session</a>
      </div>
      <div class="pricing-card featured">
        <div class="pc-tag">Earned Media Engagement</div>
        <div class="pc-price grad">$6,500</div>
        <p class="pc-per">per engagement</p>
        <p class="pc-desc">Full campaign — research, narrative development, outreach, and reporting. Up to 50 placements in target outlets.</p>
        <ul class="pc-features">
          <li><i class="ti ti-check"></i>Full campaign — all services included</li>
          <li><i class="ti ti-check"></i>Up to 50 placements</li>
          <li><i class="ti ti-check"></i>AI citation tracking</li>
          <li><i class="ti ti-check"></i>Monthly reporting</li>
          <li><i class="ti ti-check"></i>No long-term contract</li>
        </ul>
        <a href="#contact" class="btn btn-primary btn-lg" style="width:100%"><i class="ti ti-calendar"></i>Book discovery call</a>
        <p class="pc-note">Most engagements complete in 8–12 weeks</p>
      </div>
    </div>
  </div>
</section>

<!-- FOUNDER NOTES -->
{posts.length > 0 && (
<section class="section cream" id="notes">
  <div class="wrap">
    <div class="sec-head">
      <h2>Founder <em class="grad">Notes</em></h2>
      <p>Field notes on earned media, higher ed visibility, and what we're learning.</p>
    </div>
    <div class="notes-list">
      {posts.map((p) => (
        <a class="note-item" href={`/blog/${p.id}`}>
          <span class="note-date">{fmt(p.data.date)}</span>
          <span class="note-title">{p.data.title} →</span>
        </a>
      ))}
    </div>
    <div class="notes-cta">
      <a href="/blog" class="btn btn-soft">All notes <i class="ti ti-arrow-right"></i></a>
    </div>
  </div>
</section>
)}

<!-- CLOSING -->
<section class="section closing" id="contact">
  <div class="wrap">
    <div class="badge">Narrative Attraction Agency for Higher Education</div>
    <h2>Ready to own your <em class="grad">story</em>?</h2>
    <p>The enrollment cliff won't wait. Let's talk about where your institution stands and how we can build a narrative that protects your future.</p>
    <a href="#contact" class="btn btn-primary btn-lg btn-studio"><i class="ti ti-calendar"></i>Book a discovery call</a>
  </div>
</section>
</Layout>

<style>
/* ===== HERO ===== */
.hero { position:relative; padding:90px 0 70px; overflow:hidden; background: var(--canvas); }
.hero-atmos { position:absolute; inset:0; pointer-events:none; overflow:hidden; }
.hero-atmos .grid { position:absolute; inset:0; background-image: linear-gradient(var(--line) 1px,transparent 1px), linear-gradient(90deg,var(--line) 1px,transparent 1px); background-size:46px 46px; mask:radial-gradient(circle at 40% 30%,#000 0%,transparent 62%); opacity:.4; }
.deco { position:absolute; pointer-events:none; }
.deco-1 { right:3%; top:8%; opacity:.4; }
.deco-2 { left:2%; bottom:10%; opacity:.3; }
.deco-3 { right:40%; bottom:5%; opacity:.2; }
.hero-flex { display:grid; grid-template-columns:1.1fr .9fr; gap:50px; align-items:center; }
.hero-txt .badge { display:inline-block; font-family:var(--mono); font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.06em; color:var(--coral); border:1px solid var(--line-2); border-radius:30px; padding:6px 16px; margin-bottom:22px; background:rgba(255,255,255,.7); }
.hero-title { font-family:var(--serif); font-size:clamp(42px,6vw,68px); font-weight:500; letter-spacing:-.03em; line-height:.95; margin-bottom:22px; }
.hero-sub { font-size:18px; color:var(--ink-2); max-width:46ch; margin-bottom:28px; line-height:1.6; }
.hero-actions { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:18px; }
.hero-meta { font-size:13px; color:var(--ink-3); font-family:var(--mono); letter-spacing:.02em; }
.hero-right { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.stat-card { background:var(--paper); border:1px solid var(--line-2); border-radius:14px; padding:22px; }
.stat-card.dark { background:var(--night); border-color:var(--night-line); }
.stat-card .num { display:block; font-family:var(--serif); font-size:30px; font-weight:500; letter-spacing:-.02em; color:var(--ink); line-height:1; margin-bottom:5px; background:var(--sunrise); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.stat-card.dark .num { background:var(--sunrise); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.stat-card .lbl { display:block; font-family:var(--mono); font-size:10.5px; text-transform:uppercase; letter-spacing:.05em; color:var(--ink-3); }
.stat-card.dark .lbl { color:var(--night-txt); }

/* ===== MARQUEE ===== */
.marquee-wrap { background:var(--night); padding:30px 0; overflow:hidden; }
.marquee-label { font-family:var(--mono); font-size:10.5px; text-transform:uppercase; letter-spacing:.08em; color:var(--night-txt); text-align:center; margin-bottom:18px; }
.marquee-track { position:relative; overflow:hidden; }
.marquee-track::before,.marquee-track::after { content:""; position:absolute; inset:0; width:100px; z-index:2; pointer-events:none; }
.marquee-track::before { left:0; background:linear-gradient(90deg,var(--night),transparent); }
.marquee-track::after { right:0; background:linear-gradient(270deg,var(--night),transparent); }
.marquee-inner { display:flex; align-items:center; gap:0; animation:marquee 40s linear infinite; white-space:nowrap; }
.marquee-inner a { color:var(--night-txt-2); font-size:13px; font-weight:500; letter-spacing:.02em; padding:0 28px; flex-shrink:0; text-decoration:none; transition:color .12s; }
.marquee-inner a:hover { color:#fff; }
.marquee-inner .dot { width:3px; height:3px; border-radius:50%; background:var(--coral); flex-shrink:0; }
@keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ===== SECTIONS ===== */
.section { padding:80px 0; position:relative; }
.section.light { background:var(--canvas); }
.section.dark { background:var(--night); color:#fff; position:relative; overflow:hidden; }
.section.dark .sec-head h2 { color:#fff; }
.section.dark .sec-head p { color:var(--night-txt); }
.section.dark::before { content:""; position:absolute; inset:0; background:radial-gradient(ellipse at 30% 30%,rgba(239,162,60,.18),rgba(206,82,134,.12),transparent 70%); pointer-events:none; }
.section.cream { background:var(--paper-2); }
.sec-head { text-align:center; max-width:620px; margin:0 auto 48px; position:relative; z-index:1; }
.sec-head h2 { font-family:var(--serif); font-size:clamp(34px,4.5vw,48px); font-weight:500; letter-spacing:-.025em; line-height:1.05; margin-bottom:14px; }
.sec-head p { font-size:17px; color:var(--ink-2); line-height:1.6; }

/* ===== GRID 3 ===== */
.grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; max-width:1040px; margin:0 auto; position:relative; z-index:1; }
.card { background:var(--paper); border:1px solid var(--line-2); border-radius:18px; padding:28px 26px; transition:.15s; }
.card:hover { border-color:var(--line-3); box-shadow:var(--sh-lg); transform:translateY(-3px); }
.card-icon { width:44px; height:44px; border-radius:11px; background:var(--coral-soft); color:var(--coral); display:flex; align-items:center; justify-content:center; font-size:20px; margin-bottom:14px; }
.card h3 { font-size:17px; font-weight:600; margin-bottom:10px; }
.card p { font-size:14px; color:var(--ink-2); line-height:1.6; }

/* ===== SERVICES ===== */
.svc-grid { gap:20px; }
.svc-card { background:rgba(30,32,66,.5); border:1px solid var(--night-line); border-radius:18px; padding:30px 28px; position:relative; backdrop-filter:blur(6px); transition:.15s; }
.svc-card:hover { border-color:rgba(239,162,60,.4); background:rgba(30,32,66,.7); transform:translateY(-2px); }
.svc-num { font-family:var(--mono); font-size:11px; font-weight:700; letter-spacing:.05em; color:var(--amber); margin-bottom:14px; }
.svc-icon { width:44px; height:44px; border-radius:11px; background:rgba(239,162,60,.15); color:var(--amber); display:flex; align-items:center; justify-content:center; font-size:20px; margin-bottom:14px; }
.svc-card h3 { font-size:18px; font-weight:600; color:#fff; margin-bottom:10px; }
.svc-card p { font-size:13.5px; color:var(--night-txt-2); line-height:1.6; margin-bottom:18px; }
.svc-tags { display:flex; flex-wrap:wrap; gap:6px; }
.svc-tags span { font-family:var(--mono); font-size:10px; color:var(--night-txt); background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.06); border-radius:6px; padding:3px 8px; }

/* ===== STEPS ===== */
.steps { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; max-width:1040px; margin:0 auto; }
.step { background:var(--paper); border:1px solid var(--line-2); border-radius:16px; padding:26px; }
.step-num { font-family:var(--mono); font-size:11px; font-weight:700; letter-spacing:.06em; color:var(--coral); margin-bottom:14px; }
.step-body h3 { font-size:16px; font-weight:600; margin-bottom:8px; }
.step-body p { font-size:13.5px; color:var(--ink-2); line-height:1.6; }

/* ===== CLIENTS ===== */
.client-grid { display:flex; flex-wrap:wrap; justify-content:center; gap:16px; max-width:800px; margin:0 auto; }
.client-item { background:var(--paper); border:1px solid var(--line-2); border-radius:12px; padding:14px 22px; transition:.12s; }
.client-item:hover { border-color:var(--line-3); box-shadow:var(--sh-sm); }
.client-item a { font-size:15px; font-weight:500; color:var(--ink); text-decoration:none; }

/* ===== PRICING ===== */
.pricing-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:800px; margin:0 auto; }
.pricing-card { background:var(--paper); border:1px solid var(--line-2); border-radius:20px; padding:32px; box-shadow:var(--sh); }
.pricing-card.featured { background:var(--night); border-color:var(--night-line); box-shadow:var(--sh-lg); }
.pc-tag { font-family:var(--mono); font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--ink-3); margin-bottom:16px; }
.featured .pc-tag { color:var(--amber); }
.pc-price { font-family:var(--serif); font-size:48px; font-weight:500; letter-spacing:-.03em; line-height:1; color:var(--ink); margin-bottom:4px; }
.featured .pc-price { background:var(--sunrise); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.pc-per { font-family:var(--mono); font-size:12px; color:var(--ink-3); margin-bottom:20px; }
.featured .pc-per { color:var(--night-txt); }
.pc-desc { font-size:14px; color:var(--ink-2); line-height:1.6; margin-bottom:24px; }
.featured .pc-desc { color:var(--night-txt-2); }
.pc-features { list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:10px; }
.pc-features li { font-size:14px; color:var(--ink); display:flex; align-items:flex-start; gap:10px; }
.pc-features li i { color:var(--green); font-size:17px; flex-shrink:0; margin-top:1px; }
.featured .pc-features li { color:var(--night-txt-2); }
.featured .pc-features li i { color:var(--amber); }
.pc-note { font-family:var(--mono); font-size:11px; color:var(--night-txt); text-align:center; margin-top:16px; }

/* ===== NOTES ===== */
.notes-list { max-width:640px; margin:0 auto; display:flex; flex-direction:column; }
.note-item { display:flex; flex-direction:column; gap:4px; padding:20px 0; border-bottom:1px solid var(--line); transition:.12s; text-decoration:none; }
.note-item:first-child { border-top:1px solid var(--line); }
