---
import BaseLayout from '../layouts/BaseLayout.astro';
import LatestDispatches from '../components/LatestDispatches.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaBanner from '../components/CtaBanner.astro';
---
<BaseLayout
  title="701am — Earn what you cannot buy."
  description="The morning record. Book a sunrise call or read the scroll."
>

  <!-- ════ HERO ════ -->
  <section class="hero" id="top">
    <div class="hero-grain" aria-hidden="true"></div>
    <div class="hero-rays" aria-hidden="true"></div>
    <div class="hero-sun" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-overline">
        <span class="hero-overline-rule"></span>
        Filed at 7:01 a.m. · From the desk
        <span class="hero-overline-rule"></span>
      </p>

      <h1 class="hero-headline">
        A quiet game is being<br />
        played for your industry's <em>attention.</em>
      </h1>

      <p class="hero-deck">
        You will never see it on a media plan or a Gantt chart. It happens in inboxes, before nine, between operators who know which reporter cares about which story. <em>Most companies do not know they are losing it.</em>
      </p>

      <div class="cta-cluster">
        <a class="btn-primary" href="/discovery">
          See how it works
          <span class="btn-icon" aria-hidden="true">→</span>
        </a>
        <a class="btn-link" href="/legend-maker">
          Or read the field manual
          <span class="arrow" aria-hidden="true">↓</span>
        </a>
      </div>

      <p class="cta-fine">Thirty minutes. No deck. No pitch. No charge.</p>
    </div>
  </section>

  <!-- ════ § 00 — PRESS STRIP (move A) ════ -->
  <section class="press-strip" aria-label="Press placements">
    <div class="press-inner">
      <p class="press-label">
        <span class="press-star">★</span>
        As placed and earned in
        <span class="press-star">★</span>
      </p>
      <div class="press-logos">
        <span class="press-logo press-italic">Forbes</span>
        <span class="press-logo press-condensed">THE WALL STREET JOURNAL</span>
        <span class="press-logo press-roman">Inc.</span>
        <span class="press-logo press-italic">Fast Company</span>
        <span class="press-logo press-condensed">TECHCRUNCH</span>
      </div>
    </div>
  </section>

  <!-- ════ § 01 — THE TRUTH ════ -->
  <section class="section section-navy">
    <div class="container reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ 01 · The first truth</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2">Attention is rented.<br /><em>Authority is earned.</em></h2>
      <div class="body">
        <p class="dropcap">
          There are two ways to enter a room. You can shout, and be heard for a moment. Or you can be the one the others turn to look at, and be remembered for a lifetime. The first way is expensive and forgettable. The second way is harder, and it lasts.
        </p>

        <div class="aphorism">This is the difference between noise and name</div>

        <p>
          The brands you envy did not buy their place in your mind. They earned it — one editor, one story, one un-ignorable angle at a time. They understood what most never will: <em>the world does not remember the loudest. It remembers the one it could not look away from.</em>
        </p>

        <p>
          That moment of attention has a time. It is <strong>7:01am</strong> — the minute after the alarm, when a hundred million people pick up the phone and decide, again, what matters today. The office is named for that minute. We work backward from it.
        </p>
      </div>
    </div>
  </section>

  <!-- ════ § 02 — THE LEDGER (move B) ════ -->
  <section class="section section-navy ledger-section">
    <div class="container-wide reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ 02 · The ledger</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2">A recent <em>placement.</em></h2>

      <div class="ledger-grid">
        <div class="ledger-cell">
          <div class="ledger-num">20</div>
          <div class="ledger-cap">Placements earned</div>
          <div class="ledger-sub">In sixty days</div>
        </div>
        <div class="ledger-divider" aria-hidden="true"></div>
        <div class="ledger-cell">
          <div class="ledger-num">7</div>
          <div class="ledger-cap">Tier 1 outlets</div>
          <div class="ledger-sub">WSJ, Forbes, Inc., others</div>
        </div>
        <div class="ledger-divider" aria-hidden="true"></div>
        <div class="ledger-cell">
          <div class="ledger-num">1</div>
          <div class="ledger-cap">Un-ignorable angle</div>
          <div class="ledger-sub">Found in the second call</div>
        </div>
      </div>

      <div class="ledger-prose">
        <p>
          In the spring of 2026, we ran a campaign for a higher-education company most reporters had never heard of. <em>The founder had been pitching the same press list for eighteen months with no answer.</em> We spent the first two weeks finding the angle no one had noticed — a federal data point that put his company on the right side of a national story.
        </p>
        <p>
          Sixty days later, his name appeared in the <em>Wall Street Journal</em>, <em>Forbes</em>, and <em>Inc.</em> He fielded inbound from three buyers he had been chasing for a year, and closed the largest contract in the company's history before the campaign ended.
        </p>
      </div>

      <p class="ledger-coda">★ Client confidential. The numbers are not. ★</p>
    </div>
  </section>

  <!-- ════ § 03 — THE METHOD (with hinge — move E) ════ -->
  <section class="section section-cream">
    <div class="container reveal">
      <p class="proclamation-hinge">
        And so the office adopted, on the morning it opened, two articles —
      </p>

      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ 03 · The method</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2 h2-dark">Two things. Done <em>without compromise.</em></h2>
      <div class="body body-dark body-center">
        <p>
          We do not ship deliverables. We do not run campaigns. We build the conditions under which a business becomes <em>impossible to ignore.</em> The method is small enough to fit on a single page, and it has not changed since the office opened.
        </p>
      </div>

      <article class="doc">
        <header class="doc-header">
          <div class="doc-stamp">★ Tenets of the office ★</div>
          <h3 class="doc-title">The Two Articles of Earned Authority</h3>
          <p class="doc-sub">Adopted at sunrise. Held in perpetuity.</p>
        </header>

        <div class="tenet">
          <div class="tenet-mark">Art. i</div>
          <div>
            <h4 class="tenet-h">Find the un-ignorable angle.</h4>
            <p class="tenet-p">
              Inside every business there is one true sentence — one fact, one fight, one figure — that an editor cannot refuse and a competitor cannot copy. <em>It is almost never the thing you would put in the deck.</em> We sit with you until we find it, and then we sharpen it until it cuts.
            </p>
          </div>
        </div>
        <div class="tenet">
          <div class="tenet-mark">Art. ii</div>
          <div>
            <h4 class="tenet-h">Place it where it cannot be denied.</h4>
            <p class="tenet-p">
              An idea on a napkin is still a napkin. We do the unglamorous work — the research, the pitch, the follow-up, the proof — until the right reporter at the right outlet runs the right story. <em>Then we do it again. And again. Until your name is the answer to the question.</em>
            </p>
          </div>
        </div>

        <div class="doc-sig">
          <p class="doc-sig-line">— 701am, est. at sunrise</p>
          <div class="doc-sig-title">Office of Earned Media</div>
        </div>
        <div class="doc-wax">7:01</div>
      </article>
    </div>
  </section>

  <!-- ════ FOUNDER NOTE (move D) ════ -->
  <section class="founder-note">
    <div class="founder-inner reveal">
      <p class="founder-eyebrow">
        <span class="founder-rule"></span>
        A note from the office
        <span class="founder-rule"></span>
      </p>
      <blockquote class="founder-quote">
        There are perhaps fifty agencies in the world that promise earned media. We are not the largest. We may not be the cheapest. We are the one that will sit with you for an hour and find the angle no one else will, and then prove we can place it. <em>If that is what you are looking for, the sunrise call is free.</em>
      </blockquote>
      <p class="founder-sig">
        <span class="founder-name">— David</span>
        <span class="founder-time">at 7:01</span>
      </p>
    </div>
  </section>

  <!-- ════ § 04 — THE TOOLS ════ -->
  <section class="section section-navy" id="tools">
    <div class="container-wide reveal">
      <div class="section-label">
        <div class="label-bar"></div>
        <div class="label-text">§ 04 · The tools</div>
        <div class="label-bar"></div>
      </div>
      <h2 class="h2">Three tools.<br /><em>Built behind the masthead.</em></h2>
      <div class="body body-center">
        <p>
          Three tools we built because the work demanded them. <em>Each is free.</em> Each does one thing well. Pick the one that fits the morning you are in.
        </p>
      </div>

      <div class="stamp-rule">
        <div class="stamp-rule-bar"></div>
        <div class="stamp-rule-time">7:01</div>
        <div class="stamp-rule-bar"></div>
      </div>

      <div class="offers offers--three">

        <!-- Tool I — Kraken (featured) -->
        <article class="offer offer--featured">
          <div class="offer-frame" aria-hidden="true"></div>
          <div class="offer-numeral">i.</div>
          <p class="offer-label">Tool I · Newest</p>
          <h3 class="offer-h">Predict <em>the coverage.</em></h3>
          <p class="offer-desc">
            <em>Kraken</em> — the Newsroom Prediction Engine. Drop a dataset, organization, or trend. <em>50 framings through 5 lenses, clustered into 10 attractors, ranked by editorial success.</em>
          </p>
          <ul class="offer-meta">
            <li><span>i.</span> Six-section predictive report</li>
            <li><span>ii.</span> Stories · pitches · headlines</li>
            <li><span>iii.</span> ~25 seconds · free</li>
          </ul>
          <a class="btn-primary offer-cta" href="/kraken">
            Release the Kraken
            <span class="btn-icon" aria-hidden="true">→</span>
          </a>
          <p class="offer-fine">★ No signup. Yours to keep.</p>
          <div class="offer-seal" aria-hidden="true">
            <span class="offer-seal-time">7:01</span>
          </div>
        </article>

        <!-- Tool II — Build a Data Story -->
        <article class="offer">
          <div class="offer-frame" aria-hidden="true"></div>
          <div class="offer-numeral">ii.</div>
          <p class="offer-label">Tool II · The workshop</p>
          <h3 class="offer-h">Build a <em>Data Story.</em></h3>
          <p class="offer-desc">
            A guided 3-minute workshop. Five questions about your business, two public datasets, <em>one headline you did not have yesterday.</em>
          </p>
          <ul class="offer-meta">
            <li><span>i.</span> Strategy memo on screen</li>
            <li><span>ii.</span> Pitch · reporters · roadmap</li>
            <li><span>iii.</span> Print-friendly</li>
          </ul>
          <a class="btn-primary btn-primary--ghost offer-cta" href="/build">
            Open the workshop
            <span class="btn-icon" aria-hidden="true">→</span>
          </a>
          <p class="offer-fine">★ Free. No signup.</p>
        </article>

        <!-- Tool III — Earned Media Skills -->
        <article class="offer">
          <div class="offer-frame" aria-hidden="true"></div>
          <div class="offer-numeral">iii.</div>
          <p class="offer-label">Tool III · For your AI</p>
          <h3 class="offer-h">Arm your <em>AI agent.</em></h3>
          <p class="offer-desc">
            Twenty-eight earned-media skills your AI agent can read. <em>Pitch craft, journalist research, the humanizer.</em> Plain markdown. MIT licensed.
          </p>
          <ul class="offer-meta">
            <li><span>i.</span> 28 skills, 1 rule</li>
            <li><span>ii.</span> MIT, open source</li>
            <li><span>iii.</span> Claude Code or Cowork</li>
          </ul>
          <a class="btn-primary btn-primary--ghost offer-cta" href="/skills">
            Clone the repo
            <span class="btn-icon" aria-hidden="true">→</span>
          </a>
          <p class="offer-fine">★ Cloned by anyone. Stolen by no one.</p>
        </article>

      </div>

      <p class="tools-allcta">
        <a class="tools-allcta-link" href="/tools">
          View the full tool gallery <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>
  </section>

  <!-- ════ § — TESTIMONIALS ════ -->
  <Testimonials />

  <!-- ════ § 05 — LATEST DISPATCHES (move C) ════ -->
  <LatestDispatches />

  <!-- ════ FINAL CTA BANNER ════ -->
  <CtaBanner
    eyebrow="The work begins at 7:01"
    heading="Ready to <em>begin?</em>"
    body="Thirty minutes. No deck, no pitch, no charge. We listen, find the angle, and tell you straight whether we can help you become impossible to ignore."
  />

</BaseLayout>

<style>
  /* ─────── HERO — warm sunrise gradient, no navy ─────── */
  .hero {
    position: relative;
    background: linear-gradient(180deg,
      var(--paper)      0%,
      var(--paper-warm) 30%,
      var(--paper-deep) 55%,
      var(--coral)      80%,
      var(--amber)      100%);
    padding: var(--hero-y-top) var(--x1) var(--hero-y-bot);
    text-align: center;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }
  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.08;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  }
  .hero-rays {
    position: absolute;
    bottom: -200px; left: 0; right: 0; height: 360px;
    background: repeating-conic-gradient(from 0deg at 50% 100%,
      rgba(255, 233, 168, 0.18) 0deg 3deg,
      transparent 3deg 11deg);
    pointer-events: none;
    animation: rays-pulse 10s ease-in-out infinite;
  }
  @keyframes rays-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }
  .hero-sun {
    position: absolute;
    bottom: -90px; left: 50%;
    transform: translateX(-50%);
    width: 400px; height: 400px;
    border-radius: 50%;
    background:
      radial-gradient(circle at center,
        rgba(255, 233, 168, 0.0) 49%,
        rgba(255, 233, 168, 0.28) 50%,
        rgba(255, 233, 168, 0.0) 52%),
      radial-gradient(circle at center,
        var(--sun-glow) 0%,
        var(--amber-light) 28%,
        var(--coral) 52%,
        rgba(201, 122, 63, 0) 75%);
    pointer-events: none;
    animation: sun-rise 1.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes sun-rise {
    from { transform: translate(-50%, 120px); opacity: 0; }
    to { transform: translate(-50%, 0); opacity: 1; }
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .hero-overline {
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    letter-spacing: 0.34em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x2);
    font-weight: 600;
    animation: fade-up 0.9s ease 0.2s both;
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
  }
  .hero-overline-rule {
    display: inline-block;
    width: 30px; height: 1px;
    background: var(--claret);
  }
  .hero-headline {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
    font-size: clamp(2.6rem, 7.5vw, 5.75rem);
    line-height: 1.02;
    font-weight: 400;
    letter-spacing: -0.032em;
    color: var(--ink);
    margin: 0 0 var(--x1);
    max-width: 22ch;
    margin-left: auto;
    margin-right: auto;
    animation: fade-up 1.1s ease 0.4s both;
    text-wrap: balance;
  }
  .hero-headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--claret);
  }
  .hero-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    font-style: italic;
    font-weight: 300;
    font-size: var(--f4-size);
    line-height: var(--f4-lh);
    color: var(--ink-soft);
    max-width: 32ch;
    margin: 0 auto var(--x1);
    animation: fade-up 1.1s ease 0.6s both;
  }
  .cta-cluster { animation: fade-up 1.1s ease 0.8s both; }
  .cta-fine { animation: fade-up 1.1s ease 1s both; }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─────── PRESS STRIP ─────── */
  .press-strip {
    background: var(--paper-soft);
    color: var(--ink);
    padding: var(--x2) var(--x1);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .press-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
    text-align: center;
  }
  .press-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x3);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
  }
  .press-star { color: var(--claret); font-size: 11px; }
  .press-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: var(--x3) var(--x2);
  }
  .press-logo {
    color: var(--ink);
    opacity: 0.75;
    transition: opacity 0.2s ease;
    line-height: 1;
    font-family: 'Newsreader', Georgia, serif;
  }
  .press-logo:hover { opacity: 1; }
  .press-italic { font-style: italic; font-size: 22px; font-weight: 500; }
  .press-roman { font-style: normal; font-size: 22px; font-weight: 500; }
  .press-condensed {
    font-style: normal;
    font-weight: 600;
    font-size: 16px;
    font-stretch: condensed;
    letter-spacing: 0.04em;
  }

  /* ═══════════════════════════════════════════════
     WORKSHOP CALLOUT — promote /build
     Sits between press strip and § 01
     ═══════════════════════════════════════════════ */
  .workshop-callout {
    background: var(--paper-warm);
    padding: calc(var(--x1) + var(--x4)) var(--x1) calc(var(--x1) + var(--x4));
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
  }
  .workshop-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 var(--x3);
  }
  .workshop-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--x1);
    align-items: stretch;
  }

  .workshop-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .workshop-stamp {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x3);
    font-weight: 600;
    align-self: flex-start;
  }
  .workshop-rule {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: var(--claret);
    opacity: 0.55;
  }
  .workshop-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.038em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    max-width: 16ch;
    text-wrap: balance;
  }
  .workshop-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 300;
  }
  .workshop-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.125rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 var(--x3);
    max-width: 38ch;
  }
  .workshop-deck em {
    color: var(--claret);
    font-style: italic;
  }
  .workshop-body {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-faint);
    margin: 0 0 var(--x2);
    max-width: 42ch;
  }
  .workshop-body em {
    font-style: italic;
    color: var(--claret);
  }
  .workshop-cta-row {
    display: flex;
    align-items: center;
    gap: var(--x3);
    flex-wrap: wrap;
    margin-top: var(--x4);
  }
  .workshop-cta-star {
    display: inline-block;
    font-size: 12px;
    color: var(--paper-soft);
    margin-right: 2px;
  }
  .workshop-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-fainter);
    margin: 0;
  }
  .workshop-fine em {
    color: var(--claret);
    font-style: italic;
  }

  /* The preview card — sample memo */
  .workshop-preview {
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    box-shadow: 0 22px 50px rgba(15, 14, 14, 0.12),
                0 2px 4px rgba(15, 14, 14, 0.06);
    position: relative;
    display: flex;
    flex-direction: column;
    transform: rotate(-1deg);                /* tactile, like a memo on a desk */
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .workshop-preview:hover {
    transform: rotate(0deg) translateY(-3px);
  }
  .workshop-preview::before {
    content: "";
    position: absolute;
    top: 10px; left: 10px; right: 10px; bottom: 10px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  .workshop-preview-head {
    display: flex;
    align-items: center;
    gap: var(--x4);
    padding: var(--x4) var(--x3);
    border-bottom: 1px solid var(--rule-strong);
    background: var(--paper);
    position: relative;
    z-index: 1;
  }
  .workshop-preview-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--claret);
    box-shadow: 0 0 0 2px rgba(153, 15, 61, 0.18);
  }
  .workshop-preview-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 600;
    flex: 1;
  }
  .workshop-preview-time {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    color: var(--ink-fainter);
    font-variant-numeric: oldstyle-nums;
  }
  .workshop-preview-body {
    padding: var(--x3);
    position: relative;
    z-index: 1;
  }
  .workshop-preview-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    margin: 0 0 var(--x5);
  }
  .workshop-preview-headline {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 var(--x5);
    font-weight: 400;
    max-width: 22ch;
  }
  .workshop-preview-meta {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    color: var(--ink-fainter);
    margin: 0 0 var(--x4);
    letter-spacing: 0.04em;
  }
  .workshop-preview-rule {
    height: 1px;
    background: var(--rule);
    margin: var(--x4) 0;
  }
  .workshop-preview-pitch-subj {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink);
    margin: 0 0 var(--x5);
    line-height: 1.3;
  }
  .workshop-preview-pitch-body {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 var(--x4);
  }
  .workshop-preview-road {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 14px;
  }
  .workshop-preview-road li {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.8125rem;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: 6px;
    line-height: 1.3;
  }
  .workshop-preview-road li span {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    min-width: 1.5em;
  }

  @media (max-width: 880px) {
    .workshop-grid {
      grid-template-columns: 1fr;
      gap: var(--x2);
    }
    .workshop-preview {
      transform: rotate(0);
      max-width: 28rem;
    }
  }
  @media (max-width: 560px) {
    .workshop-h { font-size: clamp(2rem, 8vw, 2.75rem); }
    .workshop-preview-road { grid-template-columns: 1fr; }
  }

  /* ─────── LEDGER ─────── */
  .ledger-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .ledger-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0;
    margin: var(--x1) 0;
    max-width: 56rem;
    margin-left: auto;
    margin-right: auto;
  }
  .ledger-cell {
    text-align: center;
    padding: var(--x3) var(--x4);
  }
  .ledger-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(4.5rem, 10vw, 7rem);
    line-height: 0.9;
    color: var(--claret);
    letter-spacing: -0.04em;
    font-variant-numeric: oldstyle-nums;
    margin-bottom: var(--x4);
  }
  .ledger-cap {
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f5-size);
    font-weight: 500;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: var(--x5);
    letter-spacing: -0.01em;
  }
  .ledger-sub {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    font-weight: 600;
  }
  .ledger-divider {
    width: 1px;
    height: 80px;
    background: linear-gradient(180deg,
      transparent 0%,
      var(--rule-strong) 50%,
      transparent 100%);
  }
  .ledger-prose {
    max-width: var(--measure-narrow);
    margin: var(--x1) auto 0;
    font-family: 'Newsreader', Georgia, serif;
    font-size: var(--f5-size);
    line-height: 1.5;
    color: var(--ink-soft);
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    text-align: center;
  }
  .ledger-prose p { margin: 0 0 var(--x3); text-wrap: pretty; }
  .ledger-prose p:last-child { margin-bottom: 0; }
  .ledger-prose em {
    font-style: italic;
    color: var(--claret);
  }
  .ledger-coda {
    text-align: center;
    margin: var(--x1) 0 0;
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    letter-spacing: 0.30em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ─────── PROCLAMATION HINGE ─────── */
  .proclamation-hinge {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--f5-size);
    line-height: 1.4;
    color: var(--claret);
    text-align: center;
    max-width: 38ch;
    margin: 0 auto calc(var(--x1) + var(--x3));
    padding: 0 var(--x3);
    position: relative;
  }
  .proclamation-hinge::before,
  .proclamation-hinge::after {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    background: var(--claret);
    opacity: 0.4;
    margin: 0 auto;
  }
  .proclamation-hinge::before { margin-bottom: var(--x3); }
  .proclamation-hinge::after { margin-top: var(--x3); }

  /* ─────── DROPCAP, APHORISM, STAMP RULE ─────── */
  .dropcap::first-letter {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 300;
    float: left;
    font-size: calc(var(--f6-size) * 5.2);
    line-height: 0.82;
    padding: 0.05em 0.12em 0 0;
    margin-top: 0.04em;
    color: var(--claret);
    font-style: italic;
  }
  .aphorism {
    font-family: 'Instrument Sans', sans-serif;
    text-align: center;
    font-size: var(--f7-size);
    line-height: 1.5;
    letter-spacing: 0.34em;
    color: var(--claret);
    text-transform: uppercase;
    margin: var(--x1) auto;
    font-weight: 600;
    position: relative;
    padding: 0 var(--x1);
    max-width: 38ch;
  }
  .aphorism::before, .aphorism::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 36px;
    height: 1px;
    background: var(--claret);
    opacity: 0.4;
  }
  .aphorism::before { left: 0; }
  .aphorism::after { right: 0; }
  .stamp-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--x3);
    margin: var(--x1) 0;
  }
  .stamp-rule-bar { width: 80px; height: 1px; background: var(--rule-strong); }
  .stamp-rule-time {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f5-size);
    line-height: 1;
    color: var(--claret);
    letter-spacing: 0.04em;
    font-variant-numeric: oldstyle-nums;
  }

  /* ─────── PROCLAMATION DOC ─────── */
  .doc {
    background: var(--paper-deep);
    padding: var(--x1) calc(var(--x1) + var(--x4));
    border: 1px solid var(--rule-strong);
    position: relative;
    box-shadow: 0 20px 50px rgba(15, 14, 14, 0.12);
    margin: var(--x1) auto 0;
    max-width: var(--measure);
  }
  .doc::before {
    content: "";
    position: absolute;
    top: 14px; left: 14px; right: 14px; bottom: 14px;
    border: 1px solid rgba(15, 14, 14, 0.10);
    pointer-events: none;
  }
  .doc > * { position: relative; z-index: 1; }
  .doc-header {
    text-align: center;
    padding-bottom: var(--x2);
    border-bottom: 1px solid rgba(15, 14, 14, 0.15);
    margin-bottom: var(--x2);
  }
  .doc-stamp {
    display: inline-block;
    padding: var(--x6) var(--x3);
    border: 1px solid var(--ink);
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    line-height: 1.4;
    letter-spacing: 0.34em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: var(--x3);
    font-weight: 600;
    background: var(--paper-soft);
  }
  .doc-title {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
    font-size: var(--f3-size);
    line-height: 1.08;
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.018em;
    max-width: 22ch;
    margin-left: auto;
    margin-right: auto;
  }
  .doc-sub {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: var(--f6-size);
    line-height: var(--f6-lh);
    color: var(--claret);
    margin-top: var(--x5);
    letter-spacing: 0.01em;
  }
  .tenet {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: var(--x3);
    padding: var(--x2) 0;
    border-bottom: 1px solid rgba(15, 14, 14, 0.08);
  }
  .tenet:last-of-type { border-bottom: none; }
  .tenet-mark {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f5-size);
    line-height: 1;
    color: var(--claret);
    padding-top: 0.35em;
    font-variant-numeric: oldstyle-nums;
  }
  .tenet-h {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1;
    font-size: var(--f4-size);
    line-height: 1.2;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 var(--x5);
    letter-spacing: -0.012em;
    text-wrap: balance;
  }
  .tenet-p {
    font-family: 'Newsreader', Georgia, serif;
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    font-size: var(--f6-size);
    line-height: 1.55;
    font-weight: 400;
    color: var(--ink-soft);
    margin: 0;
    max-width: 56ch;
  }
  .tenet-p em { font-style: italic; color: var(--claret); }
  .doc-sig {
    text-align: center;
    margin-top: var(--x2);
    padding-top: var(--x2);
    border-top: 1px solid rgba(15, 14, 14, 0.15);
  }
  .doc-sig-line {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--f4-size);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
    transform: rotate(-1.5deg);
    display: inline-block;
  }
  .doc-sig-title {
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    line-height: 1.4;
    letter-spacing: 0.34em;
    color: var(--claret);
    text-transform: uppercase;
    margin-top: var(--x4);
    font-weight: 600;
  }
  .doc-wax {
    position: absolute;
    bottom: -22px;
    right: var(--x1);
    width: 68px; height: 68px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%,
      #C8334F 0%, var(--claret) 35%, var(--claret-dark) 80%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: var(--f5-size);
    line-height: 1;
    color: var(--paper-soft);
    box-shadow: 0 6px 14px rgba(15, 14, 14, 0.3),
                inset 0 -4px 8px rgba(0, 0, 0, 0.25),
                inset 0 4px 8px rgba(255, 255, 255, 0.15);
    transform: rotate(-8deg);
    z-index: 2;
    font-variant-numeric: oldstyle-nums;
  }
  .doc-wax::before {
    content: "";
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    border: 1px dashed rgba(255, 241, 224, 0.4);
  }

  /* ─────── FOUNDER NOTE ─────── */
  .founder-note {
    background: var(--paper-deep);
    padding: calc(var(--x1) + var(--x3)) var(--x1);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
  }
  .founder-inner {
    max-width: 32rem;
    margin: 0 auto;
  }
  .founder-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    letter-spacing: 0.32em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x2);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--x3);
  }
  .founder-rule {
    display: inline-block;
    width: 24px; height: 1px;
    background: var(--claret);
    opacity: 0.5;
  }
  .founder-quote {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--f5-size);
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 var(--x2);
    font-feature-settings: "kern" 1, "liga" 1, "dlig" 1, "onum" 1;
    text-wrap: pretty;
  }
  .founder-quote em {
    font-style: italic;
    color: var(--claret);
  }
  .founder-sig {
    font-family: 'Newsreader', Georgia, serif;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: var(--x3);
  }
  .founder-name {
    font-style: italic;
    font-size: var(--f5-size);
    color: var(--ink);
  }
  .founder-time {
    font-family: 'Instrument Sans', sans-serif;
    font-size: var(--f7-size);
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ─────── SKILLS CALLOUT ─────── */
  .skills-callout {
    background: var(--paper-warm);
    padding: var(--section-y) var(--x1);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .callout-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
  }
  .callout-stamp {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.30em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x1);
    font-weight: 600;
    padding-bottom: var(--x4);
    border-bottom: 1px solid var(--rule-strong);
    width: 100%;
    justify-content: center;
  }
  .callout-stamp-rule {
    display: inline-block;
    width: 40px;
    height: 1px;
    background: var(--claret);
    opacity: 0.6;
  }
  .callout-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--x1);
    align-items: center;
  }
  .callout-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.032em;
    color: var(--ink);
    margin: 0 0 var(--x3);
    max-width: 18ch;
  }
  .callout-h em {
    font-style: italic;
    font-weight: 300;
    color: var(--claret);
  }
  .callout-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.1875rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 var(--x3);
    font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    text-wrap: pretty;
    max-width: 38ch;
  }
  .callout-deck em {
    font-style: italic;
    color: var(--claret);
  }
  .callout-deck--quiet {
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-faint);
    border-left: 2px solid var(--claret);
    padding-left: var(--x3);
    margin-bottom: var(--x2);
  }
  .callout-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--x2);
    flex-wrap: wrap;
    margin-top: var(--x3);
  }

  /* Terminal mock — right column */
  .callout-terminal {
    background: var(--ink-deep);
    color: var(--paper-soft);
    border: 1px solid var(--ink-deep);
    box-shadow: 0 18px 40px rgba(15, 14, 14, 0.18);
    font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
    overflow: hidden;
  }
  .callout-terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255, 241, 224, 0.06);
    border-bottom: 1px solid rgba(255, 241, 224, 0.10);
  }
  .callout-terminal-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(255, 241, 224, 0.20);
  }
  .callout-terminal-dot:nth-child(1) { background: var(--coral); opacity: 0.6; }
  .callout-terminal-dot:nth-child(2) { background: var(--amber); opacity: 0.6; }
  .callout-terminal-dot:nth-child(3) { background: var(--paper-soft); opacity: 0.4; }
  .callout-terminal-name {
    margin-left: var(--x4);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255, 241, 224, 0.45);
  }
  .callout-terminal-body {
    padding: var(--x3);
    font-size: 13px;
    line-height: 1.85;
  }
  .callout-terminal-line {
    margin: 0 0 4px;
    color: var(--paper-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .callout-terminal-line--muted {
    color: rgba(255, 241, 224, 0.45);
    font-size: 12px;
  }
  .callout-terminal-line--cursor em {
    font-style: italic;
    color: var(--amber-light);
  }
  .callout-terminal-prompt {
    color: var(--claret);
    margin-right: 10px;
    font-weight: 600;
  }
  .callout-terminal-line--muted .callout-terminal-prompt { color: rgba(201, 122, 63, 0.4); }
  .callout-terminal-line--cursor .callout-terminal-prompt { color: var(--amber); }
  .callout-terminal-blink {
    color: var(--amber-light);
    animation: blink 1.1s steps(2) infinite;
    margin-left: 4px;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  /* Bottom meta strip */
  .callout-meta {
    list-style: none;
    margin: var(--x2) 0 0;
    padding: var(--x2) 0 0;
    border-top: 1px solid var(--rule-strong);
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: var(--x1);
    align-items: baseline;
    font-family: 'Newsreader', Georgia, serif;
    font-size: 15px;
    color: var(--ink-faint);
    font-style: italic;
  }
  .callout-meta li {
    display: inline-flex;
    align-items: baseline;
    gap: var(--x5);
  }
  .callout-meta strong {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 2rem;
    line-height: 1;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
    font-weight: 400;
  }
  .callout-meta li:last-child {
    color: var(--ink-soft);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .callout-grid {
      grid-template-columns: 1fr;
      gap: var(--x2);
    }
    .callout-meta {
      grid-template-columns: 1fr;
      gap: var(--x4);
    }
    .callout-meta li:last-child {
      border-top: 1px solid var(--rule);
      padding-top: var(--x4);
    }
  }
  @media (max-width: 720px) {
    .callout-deck--quiet {
      padding-left: var(--x4);
    }
    .callout-terminal-body {
      font-size: 12px;
      padding: var(--x4);
    }
  }

  /* ═══════════════════════════════════════════════
     OFFERS — three roads
     Each card is a small editorial document — numeral plate, inner frame,
     meta strip, bottom-aligned CTA. Featured card carries the wax seal.
     ═══════════════════════════════════════════════ */
  .offers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--x3);
    margin: var(--x1) auto 0;
    max-width: 72rem;
    align-items: stretch;
  }
  .offer {
    position: relative;
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    padding: calc(var(--x1) + var(--x3)) var(--x2) var(--x2);
    text-align: left;
    display: flex;
    flex-direction: column;
    box-shadow: 0 14px 30px rgba(15, 14, 14, 0.08);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.45s ease,
                border-color 0.45s ease;
  }
  .offer:hover {
    transform: translateY(-5px);
    box-shadow: 0 22px 44px rgba(15, 14, 14, 0.14);
