---
import Layout from '../layouts/Layout.astro';

const groups = [
  {
    label: 'Enrollment CRM',
    blurb: 'Read inquiry and funnel data to tie visibility to enrollment. Read-only — never written back.',
    items: [
      { name: 'Slate',      abbr: 'SL', color: '#1C4DA1', desc: 'Technolutions Slate — the enrollment CRM most institutions run on.', role: 'Read funnel data' },
      { name: 'Element451', abbr: 'E4', color: '#5B3DF5', desc: 'AI-native enrollment CRM and student engagement platform.',         role: 'Read funnel data' },
      { name: 'Salesforce', abbr: 'SF', color: '#00A1E0', desc: 'Education Cloud and standard Salesforce orgs.',                    role: 'Read funnel data' },
    ],
  },
  {
    label: 'Student information systems',
    blurb: 'Pull program and outcomes data to ground campaigns in real institutional facts.',
    items: [
      { name: 'Ellucian',        abbr: 'EL', color: '#0A7D6B', desc: 'Banner and Colleague — the higher-ed SIS / ERP standard.', role: 'Read program data' },
      { name: 'Workday Student', abbr: 'WD', color: '#F38B00', desc: 'Modern cloud SIS for program and enrollment records.',      role: 'Read program data' },
    ],
  },
  {
    label: 'Email & outreach',
    blurb: 'Send approved pitches from your own domain and monitor for replies — nothing sends without your approval.',
    items: [
      { name: 'Gmail',   abbr: 'GM', color: '#EA4335', desc: 'Send staged pitches from Google Workspace and track responses.', role: 'Send & monitor' },
      { name: 'Outlook', abbr: 'OL', color: '#0A66C2', desc: 'Send from Microsoft 365 and monitor journalist replies.',        role: 'Send & monitor' },
    ],
  },
  {
    label: 'Notifications',
    blurb: 'Route signals, approvals, and wins to where your team already works.',
    items: [
      { name: 'Slack',           abbr: 'SK', color: '#611F69', desc: 'Get signals and approval requests in the channels you choose.', role: 'Get notified' },
      { name: 'Microsoft Teams', abbr: 'MT', color: '#5059C9', desc: 'Notifications and approvals routed to Teams channels.',        role: 'Get notified' },
    ],
  },
];
---
<Layout title="Integrations — Narrative Attraction Agency for Higher Education" description="701am connects to your CRM, SIS, and outreach tools to support narrative attraction campaigns. Read-only integrations are optional — start without them.">
<div class="ph">
  <p class="ey">Integrations</p>
  <h1>Connects to the tools <span class="g">you already use</span>.</h1>
  <p>Connect your CRM, SIS, and outreach tools when you want to demonstrate narrative attraction impact across press, AI, and social media. <strong>Integrations are optional</strong> — start with a discovery call and we'll recommend what to connect based on your goals.</p>
</div>

<section class="sec sec-c">
  <div class="w" style="max-width:900px">
    <div class="sh">
      <p class="ey" style="font-family:var(--mono);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--co);margin-bottom:12px">Optional. Purpose-built. Private.</p>
      <h2>Integrate when you need to <span class="g">connect narrative to enrollment</span>.</h2>
    </div>
    <div class="g2" style="max-width:700px">
      <div class="cd">
        <div class="ic" style="width:42px;height:42px;border-radius:10px;background:rgba(221,90,56,.1);color:var(--co);display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:20px">🔔</div>
        <h3>Notify your team</h3>
        <p>Route visibility signals, pitch approvals, and coverage wins to Slack or Teams.</p>
      </div>
      <div class="cd">
        <div class="ic" style="width:42px;height:42px;border-radius:10px;background:rgba(221,90,56,.1);color:var(--co);display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:20px">📡</div>
        <h3>Monitor changes</h3>
        <p>Watch how position, presence, and sentiment shift across AI, search, and press.</p>
      </div>
      <div class="cd">
        <div class="ic" style="width:42px;height:42px;border-radius:10px;background:rgba(221,90,56,.1);color:var(--co);display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:20px">📊</div>
        <h3>Show stakeholder impact</h3>
        <p>Connect CRM funnel data to visibility movements for enrollment leadership.</p>
      </div>
      <div class="cd">
        <div class="ic" style="width:42px;height:42px;border-radius:10px;background:rgba(221,90,56,.1);color:var(--co);display:flex;align-items:center;justify-content:center;margin-bottom:14px;font-size:20px">📈</div>
        <h3>Establish ROI baselines</h3>
        <p>Ground every campaign in real institutional facts and enrollment benchmarks.</p>
      </div>
    </div>
  </div>
</section>

<section class="sec sec-d">
  <div class="w" style="max-width:900px">
    <div class="sh" style="max-width:100%">
      <h2 style="color:#fff">Integrations</h2>
    </div>
    {groups.map((g) => (
      <div style="margin-bottom:48px">
        <h3 style="font-family:var(--serif);font-size:22px;font-weight:500;color:#fff;margin-bottom:4px">{g.label}</h3>
        <p style="color:var(--txdm);margin-bottom:18px;font-size:15px">{g.blurb}</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px">
          {g.items.map((it) => (
            <div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:20px">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                <span style="width:34px;height:34px;border-radius:8px;background:{it.color};color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;flex-shrink:0">{it.abbr}</span>
                <span style="font-family:var(--mono);font-size:10px;color:#A89A8E;text-transform:uppercase;letter-spacing:.05em">{it.role}</span>
              </div>
              <div style="font-weight:600;color:#fff;margin-bottom:6px">{it.name}</div>
              <div style="font-size:13.5px;color:var(--txdm);line-height:1.55">{it.desc}</div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<section class="sec sec-c" style="text-align:center">
  <div class="w" style="max-width:600px">
    <h2 style="font-family:var(--serif);font-size:clamp(28px,4vw,42px);font-weight:500;letter-spacing:-.025em;margin-bottom:14px">Don't see your system?</h2>
    <p style="color:var(--txm);margin-bottom:28px">We add integrations as higher-ed teams ask for them. Tell us what you run and we'll prioritize it.</p>
    <a href="/contact" class="btn btn-p">Book a discovery call</a>
  </div>
</section>
</Layout>
