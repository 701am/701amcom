---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Universities — Narrative Attraction Agency for Higher Education" description="Narrative attraction for universities and colleges. Earned media, AI visibility, and social campaigns. Up to 50 placements per engagement.">
  <header class="contact-hero">
    <div class="hero-atmos"><div class="grid"></div><div class="glow g1"></div><div class="glow g2"></div><div class="glow g3"></div></div>
    <div class="wrap" style="position:relative;z-index:1">
      <div class="eyebrow">Universities & Colleges</div>
      <h1>Narrative attraction for <em class="grad">university enrollment</em>.</h1>
      <p class="lede">The enrollment cliff is real. AI is rewriting how students find you. We put your institution's story in the media, in AI search, and in the feeds future students scroll — so you fill seats instead of fighting for scraps.</p>
    </div>
  </header>

  <div class="contact-wrap">
    <aside class="contact-side" style="grid-column:1">
      <div class="cs-block">
        <h4>Our services for universities</h4>
        <p>Full-cycle narrative attraction — earned media in press and trade outlets, AI search visibility so your institution gets recommended, and social & new media campaigns that meet prospective students where they actually are.</p>
        <a class="cs-link" href="/studio">See all services <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Narrative Attraction Session</h4>
        <p>Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
        <a class="cs-link" href="/studio">See pricing <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="cs-block">
        <h4>Prefer to write?</h4>
        <p>Send us a note and we'll follow up.</p>
        <a class="cs-mail" href="mailto:hello@701am.com">hello@701am.com</a>
      </div>
    </aside>
  </div>
</Layout>

