---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Universities — Narrative Attraction Agency for Higher Education" description="Narrative attraction for universities and colleges. Earned media, AI visibility, and social campaigns. Up to 50 placements per engagement.">
<div class="ph">
  <p class="ey">Universities & Colleges</p>
  <h1>Narrative attraction for <span class="g">university enrollment</span>.</h1>
  <p>The enrollment cliff is real. AI is rewriting how students find you. We put your institution's story in the media, in AI search, and in the feeds future students scroll — so you fill seats instead of fighting for scraps.</p>
</div>

<div class="w">
  <div class="g2">
    <div class="cd">
      <h3>Our services for universities</h3>
      <p>Full-cycle narrative attraction — earned media in press and trade outlets, AI search visibility so your institution gets recommended, and social & new media campaigns that meet prospective students where they actually are.</p>
      <p><a href="/studio" style="color:var(--co);font-weight:600">See all services →</a></p>
    </div>
    <div class="cd">
      <h3>Narrative Attraction Session</h3>
      <p>Start with a $500 session — 90 minutes, data audit, story identification, no obligation.</p>
      <p><a href="/studio" style="color:var(--co);font-weight:600">See pricing →</a></p>
    </div>
  </div>
  <div style="text-align:center;margin-top:48px">
    <a href="#contact" class="btn btn-p">Book a strategy session</a>
  </div>
</div>

<section class="sec sec-d" style="margin-top:80px">
  <div class="w" style="text-align:center;max-width:600px;margin:0 auto">
    <h2 style="font-family:var(--serif);font-size:clamp(24px,3.5vw,36px);font-weight:500;color:#fff;margin-bottom:12px">Prefer to write?</h2>
    <p style="color:var(--txdm);margin-bottom:24px">Send us a note and we'll follow up.</p>
    <a href="mailto:hello@701am.com" style="color:var(--co);font-size:18px;font-weight:600">hello@701am.com</a>
  </div>
</section>
</Layout>
