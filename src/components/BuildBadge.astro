---
// BuildBadge.astro — floating bottom-right callout pointing to /build.
// Desktop only. Hidden on /build itself.
//
// Behavior:
// - Default: 64px wax seal. After ~6 seconds, auto-opens once per session
//   to introduce itself. Click anywhere outside or press Escape to close.
// - Click the seal to toggle the card open/closed.
// - Click the card's CTA (or the seal directly) to navigate to /build.
// - Dismiss (×) → hides for the session.
const path = Astro.url.pathname;
const isOnBuild = path.startsWith('/build');
---
{!isOnBuild && (
  <div class="bb" data-bb hidden>

    <!-- The expandable card. Default hidden; .is-open shows it. -->
    <div class="bb-card" data-bb-card role="dialog" aria-label="Build a Data Story workshop" aria-hidden="true">
      <button class="bb-close" type="button" data-bb-close aria-label="Close">
        <svg viewBox="0 0 12 12" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
          <line x1="2" y1="2" x2="10" y2="10"></line>
          <line x1="10" y1="2" x2="2" y2="10"></line>
        </svg>
      </button>

      <p class="bb-eyebrow">★ A 3-minute workshop · Free</p>
      <h3 class="bb-h">
        Find <em>the angle</em><br />
        your industry hasn't seen.
      </h3>
      <p class="bb-body">
        Five questions. Two public datasets. <em>One headline you did not have yesterday.</em>
      </p>
      <a class="bb-cta" href="/build">
        Build a Data Story
        <span class="bb-arrow" aria-hidden="true">→</span>
      </a>
      <p class="bb-fine"><em>No signup. Yours to keep or print.</em></p>
    </div>

    <!-- The seal. Acts as toggle. -->
    <button
      class="bb-seal"
      type="button"
      data-bb-seal
      aria-label="Open Build a Data Story workshop"
      aria-expanded="false"
      aria-controls="bb-card"
    >
      <span class="bb-seal-star" aria-hidden="true">★</span>
      <span class="bb-seal-time">7:01</span>
      <span class="bb-pulse" aria-hidden="true"></span>
    </button>

  </div>
)}

<style>
  /* ═══════════════════════════════════════════════════════════════════
     BUILD BADGE — floating bottom-right callout
     ═══════════════════════════════════════════════════════════════════ */

  /* Outer container — pinned bottom-right, flex layout */
  .bb {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 80;
    display: flex;
    align-items: flex-end;     /* anchor seal + card to the bottom of each other */
    gap: 14px;
    /* Important: the container has no hover trap. Pointer events pass through
       the empty space between card and seal because the container itself has
       no background and no interactive role. */
  }
  .bb[hidden] {
    display: none !important;
  }
  .bb.is-entering {
    animation: bb-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .bb.is-dismissed {
    opacity: 0;
    transform: translateY(12px) scale(0.92);
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes bb-enter {
    from { opacity: 0; transform: translateY(20px) scale(0.85); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ─────────── THE WAX SEAL ─────────── */
  .bb-seal {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border: none;
    padding: 0;
    cursor: pointer;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 32%,
      #C8334F 0%,
      var(--claret) 38%,
      var(--claret-dark) 90%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 10px 22px rgba(15, 14, 14, 0.32),
      0 2px 6px rgba(15, 14, 14, 0.18),
      inset 0 -4px 8px rgba(0, 0, 0, 0.28),
      inset 0 4px 8px rgba(255, 255, 255, 0.20);
    transform: rotate(-8deg);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s ease;
  }
  .bb-seal::before {
    content: "";
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px dashed rgba(255, 241, 224, 0.42);
    pointer-events: none;
  }
  .bb-seal:hover,
  .bb-seal:focus-visible,
  .bb.is-open .bb-seal {
    transform: rotate(0deg) scale(1.05);
    box-shadow:
      0 14px 32px rgba(153, 15, 61, 0.40),
      0 3px 8px rgba(15, 14, 14, 0.22),
      inset 0 -4px 8px rgba(0, 0, 0, 0.28),
      inset 0 4px 8px rgba(255, 255, 255, 0.22);
    outline: none;
  }
  .bb-seal:focus-visible {
    box-shadow:
      0 0 0 3px var(--paper),
      0 0 0 5px var(--claret),
      0 14px 32px rgba(153, 15, 61, 0.40);
  }

  .bb-seal-star {
    position: absolute;
    top: 9px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 9px;
    color: rgba(255, 241, 224, 0.7);
    line-height: 1;
  }
  .bb-seal-time {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    line-height: 1;
    color: var(--paper-soft);
    font-variant-numeric: oldstyle-nums;
    letter-spacing: -0.02em;
    margin-top: 4px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  /* Soft pulse — only shows when card is closed */
  .bb-pulse {
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1.5px solid var(--claret);
    opacity: 0;
    animation: bb-pulse 2.6s ease-out infinite;
    animation-delay: 3s;
    pointer-events: none;
  }
  @keyframes bb-pulse {
    0%   { opacity: 0; transform: scale(1); }
    25%  { opacity: 0.6; }
    100% { opacity: 0; transform: scale(1.6); }
  }
  .bb.is-open .bb-pulse,
  .bb-seal:hover .bb-pulse {
    animation: none;
    opacity: 0;
  }

  /* ─────────── THE CARD ─────────── */
  .bb-card {
    width: 340px;
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    border-top: 3px solid var(--claret);
    box-shadow:
      0 22px 48px rgba(15, 14, 14, 0.22),
      0 4px 12px rgba(15, 14, 14, 0.10);
    padding: 18px 20px 16px;
    position: relative;
    opacity: 0;
    visibility: hidden;        /* removes from accessibility tree when closed */
    transform: translateY(8px) translateX(12px) scale(0.96);
    transform-origin: bottom right;
    transition:
      opacity 0.35s ease,
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s linear 0.4s;   /* visibility hides AFTER fade-out */
  }
  .bb-card::before {
    content: "";
    position: absolute;
    top: 6px; left: 6px; right: 6px; bottom: 6px;
    border: 1px solid rgba(15, 14, 14, 0.08);
    pointer-events: none;
  }
  /* OPEN STATE */
  .bb.is-open .bb-card {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) translateX(0) scale(1);
    transition:
      opacity 0.35s ease,
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s linear 0s;    /* visibility shows immediately */
  }

  .bb-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9.5px;
    letter-spacing: 0.26em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 10px;
    position: relative;
    z-index: 1;
  }
  .bb-h {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.022em;
    color: var(--ink);
    margin: 0 0 10px;
    position: relative;
    z-index: 1;
  }
  .bb-h em {
    font-style: italic;
    color: var(--claret);
    font-weight: 400;
  }
  .bb-body {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 13.5px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 14px;
    position: relative;
    z-index: 1;
  }
  .bb-body em {
    color: var(--claret);
    font-style: italic;
  }
  .bb-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 18px;
    background: var(--ink-deep);
    color: var(--paper-soft);
    text-decoration: none;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: background 0.25s ease;
    position: relative;
    z-index: 1;
  }
  .bb-cta:hover {
    background: var(--claret);
  }
  .bb-cta:focus-visible {
    outline: 2px solid var(--claret);
    outline-offset: 2px;
  }
  .bb-arrow {
    transition: transform 0.25s ease;
  }
  .bb-cta:hover .bb-arrow {
    transform: translateX(3px);
  }
  .bb-fine {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 11.5px;
    color: var(--ink-fainter);
    text-align: center;
    margin: 10px 0 0;
    position: relative;
    z-index: 1;
  }
  .bb-fine em { font-style: italic; color: var(--claret); }

  /* Close button */
  .bb-close {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 24px;
    height: 24px;
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    border-radius: 50%;
    color: var(--ink-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    z-index: 5;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .bb-close:hover {
    color: var(--paper-soft);
    background: var(--claret);
    border-color: var(--claret);
  }
  .bb-close:focus-visible {
    outline: 2px solid var(--claret);
    outline-offset: 2px;
  }

  /* ─────────── DESKTOP ONLY ─────────── */
  @media (max-width: 960px) {
    .bb { display: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bb { animation: none; }
    .bb-pulse { animation: none; opacity: 0; }
    .bb-card { transition: opacity 0.2s ease; }
    .bb-seal { transition: none; }
  }
</style>

<script>
  // ═══════════════════════════════════════════════════════════════════
  // BUILD BADGE — state machine
  // States: hidden | closed | open | dismissed
  // ═══════════════════════════════════════════════════════════════════

  const STORAGE_KEY = 'bb-state';

  const badge = document.querySelector('[data-bb]') as HTMLElement | null;
  if (badge) {
    const seal = badge.querySelector('[data-bb-seal]') as HTMLButtonElement | null;
    const card = badge.querySelector('[data-bb-card]') as HTMLElement | null;
    const close = badge.querySelector('[data-bb-close]') as HTMLButtonElement | null;

    // Read prior state from sessionStorage
    let stored: string | null = null;
    try { stored = sessionStorage.getItem(STORAGE_KEY); } catch {}

    // If user previously dismissed, do nothing. Otherwise reveal.
    if (stored === 'dismissed') {
      badge.hidden = true;
    } else {
      // Reveal the badge after a brief delay so it doesn't compete with page load
      setTimeout(() => {
        badge.hidden = false;
        badge.classList.add('is-entering');
      }, 600);

      // Auto-open once per session, ~6 seconds after entrance
      if (stored !== 'auto-shown') {
        setTimeout(() => {
          if (!badge.classList.contains('is-dismissed')) {
            openCard();
            try { sessionStorage.setItem(STORAGE_KEY, 'auto-shown'); } catch {}
          }
        }, 6500);
      }
    }

    function openCard() {
      badge.classList.add('is-open');
      if (seal) seal.setAttribute('aria-expanded', 'true');
      if (card) card.setAttribute('aria-hidden', 'false');
    }
    function closeCard() {
      badge.classList.remove('is-open');
      if (seal) seal.setAttribute('aria-expanded', 'false');
      if (card) card.setAttribute('aria-hidden', 'true');
    }
    function toggleCard() {
      if (badge.classList.contains('is-open')) {
        closeCard();
      } else {
        openCard();
      }
    }
    function dismiss() {
      badge.classList.add('is-dismissed');
      try { sessionStorage.setItem(STORAGE_KEY, 'dismissed'); } catch {}
      setTimeout(() => { badge.hidden = true; }, 500);
    }

    // Seal click: toggle the card. Do NOT navigate; navigation happens
    // when the user clicks the CTA inside the card. This prevents the
    // accidental-click-to-/build problem.
    if (seal) {
      seal.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggleCard();
      });
    }

    // Close button
    if (close) {
      close.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        dismiss();
      });
    }

    // Close on outside click (but not on clicks inside the badge itself)
    document.addEventListener('click', (e) => {
      if (!badge.classList.contains('is-open')) return;
      const target = e.target as Node;
      if (badge.contains(target)) return;     // click is inside the badge — ignore
      closeCard();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && badge.classList.contains('is-open')) {
        closeCard();
        if (seal) seal.focus();
      }
    });

    // Prevent clicks inside the card from bubbling to document (so the
    // outside-click handler doesn't close it). Allow the CTA to navigate
    // normally — only stop propagation on non-anchor clicks.
    if (card) {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        // Allow links/buttons inside the card to work normally
        if (target.closest('a, button')) return;
        e.stopPropagation();
      });
    }
  }
</script>
