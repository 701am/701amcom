---
/**
 * Seo.astro — single source of truth for all <head> metadata.
 *
 * Builds a linked JSON-LD @graph with WebSite, Organization, Person,
 * WebPage (or BlogPosting for dispatches), and BreadcrumbList entities.
 * Reference between them via @id so an AI agent can walk the graph.
 *
 * Most pages just pass title + description. Dispatch pages pass
 * `article` with publishedTime / modifiedTime / topic / tags so we
 * emit BlogPosting schema. Other typed pages can pass `pageType`.
 */

interface ArticleData {
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  topic?: string;
  tags?: string[];
  number?: number;
  readingTime?: string;
}

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  pageType?: 'website' | 'article' | 'aboutPage' | 'contactPage' | 'collectionPage';
  article?: ArticleData;
  breadcrumbs?: BreadcrumbItem[];
  /** Markdown alternate URL for AI agents, if applicable */
  markdownAlternate?: string;
}

const {
  title = '701am — Earn what you cannot buy.',
  description = 'The morning record. Book a sunrise call or read the scroll.',
  ogImage = '/og-image.png',
  noIndex = false,
  pageType = 'website',
  article,
  breadcrumbs,
  markdownAlternate,
} = Astro.props;

const SITE = 'https://701am.com';
const path = Astro.url.pathname;
const canonical = new URL(path, SITE).toString();
const ogImageUrl = new URL(ogImage, SITE).toString();

// Strip "— 701am" suffix to derive a clean page-name for schema
const cleanTitle = title.replace(/\s*[—–|]\s*701am\s*$/i, '').trim();

// ─────────── JSON-LD Graph ───────────
// Build the linked graph piece by piece, then wire @id references.

const ID = {
  website: `${SITE}/#website`,
  organization: `${SITE}/#organization`,
  person: `${SITE}/#person`,
  webpage: `${canonical}#webpage`,
  article: `${canonical}#article`,
  breadcrumb: `${canonical}#breadcrumb`,
  logo: `${SITE}/#logo`,
};

const organization = {
  '@type': 'Organization',
  '@id': ID.organization,
  name: '701am',
  url: SITE,
  logo: {
    '@type': 'ImageObject',
    '@id': ID.logo,
    url: `${SITE}/favicon.svg`,
    contentUrl: `${SITE}/favicon.svg`,
    caption: '701am',
  },
  sameAs: [
    'https://github.com/701am',
  ],
  description: 'An earned-media office. We work backward from 7:01 a.m.',
  founder: { '@id': ID.person },
  publishingPrinciples: `${SITE}/about`,
};

const person = {
  '@type': 'Person',
  '@id': ID.person,
  name: 'David Krug',
  url: `${SITE}/about`,
  jobTitle: 'Founder',
  worksFor: { '@id': ID.organization },
  description: 'Founder of 701am. Works on earned media, data-driven press strategy, and the systems that make both repeatable.',
  knowsAbout: [
    'Earned media',
    'Public relations',
    'Data journalism',
    'Press strategy',
    'Content marketing',
  ],
};

const website = {
  '@type': 'WebSite',
  '@id': ID.website,
  url: SITE,
  name: '701am',
  description: 'The morning record. An earned-media office.',
  publisher: { '@id': ID.organization },
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

// ─────────── WebPage / BlogPosting ───────────
const isArticle = pageType === 'article' || !!article;

let webpage;
let blogPosting;

if (isArticle) {
  const published =
    article?.publishedTime instanceof Date
      ? article.publishedTime.toISOString()
      : article?.publishedTime;
  const modified =
    article?.modifiedTime instanceof Date
      ? article.modifiedTime.toISOString()
      : article?.modifiedTime || published;

  blogPosting = {
    '@type': 'BlogPosting',
    '@id': ID.article,
    isPartOf: { '@id': ID.website },
    mainEntityOfPage: { '@id': ID.webpage },
    headline: cleanTitle,
    name: cleanTitle,
    description: description,
    author: { '@id': ID.person },
    publisher: { '@id': ID.organization },
    inLanguage: 'en',
    url: canonical,
    image: {
      '@type': 'ImageObject',
      url: ogImageUrl,
      width: 1200,
      height: 630,
    },
    ...(published && { datePublished: published }),
    ...(modified && { dateModified: modified }),
    ...(article?.topic && { articleSection: article.topic }),
    ...(article?.tags && article.tags.length > 0 && { keywords: article.tags }),
  };

  webpage = {
    '@type': 'WebPage',
    '@id': ID.webpage,
    url: canonical,
    name: cleanTitle,
    description: description,
    isPartOf: { '@id': ID.website },
    primaryImageOfPage: { '@id': `${ID.article}-image` },
    breadcrumb: breadcrumbs && breadcrumbs.length > 0 ? { '@id': ID.breadcrumb } : undefined,
    inLanguage: 'en',
    mainEntity: { '@id': ID.article },
  };
} else {
  const type =
    pageType === 'aboutPage'
      ? 'AboutPage'
      : pageType === 'contactPage'
      ? 'ContactPage'
      : pageType === 'collectionPage'
      ? 'CollectionPage'
      : 'WebPage';

  webpage = {
    '@type': type,
    '@id': ID.webpage,
    url: canonical,
    name: cleanTitle,
    description: description,
    isPartOf: { '@id': ID.website },
    breadcrumb: breadcrumbs && breadcrumbs.length > 0 ? { '@id': ID.breadcrumb } : undefined,
    inLanguage: 'en',
    about: { '@id': ID.organization },
  };
}

// ─────────── Breadcrumbs ───────────
let breadcrumbList;
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbList = {
    '@type': 'BreadcrumbList',
    '@id': ID.breadcrumb,
    itemListElement: breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.name,
      ...(b.url && { item: new URL(b.url, SITE).toString() }),
    })),
  };
}

// ─────────── Assemble graph ───────────
const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    website,
    organization,
    person,
    webpage,
    ...(blogPosting ? [blogPosting] : []),
    ...(breadcrumbList ? [breadcrumbList] : []),
  ],
};

// Robots: max-snippet:-1 etc per Joost's guide
const robotsMeta = noIndex
  ? 'noindex, nofollow'
  : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';
---
<!-- Primary -->
<title>{title}</title>
<meta name="description" content={description} />
{!noIndex && <link rel="canonical" href={canonical} />}
<meta name="robots" content={robotsMeta} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={cleanTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:type" content={isArticle ? 'article' : 'website'} />
<meta property="og:site_name" content="701am" />
<meta property="og:locale" content="en_US" />

{isArticle && article?.publishedTime && (
  <meta property="article:published_time" content={
    article.publishedTime instanceof Date
      ? article.publishedTime.toISOString()
      : article.publishedTime
  } />
)}
{isArticle && article?.modifiedTime && (
  <meta property="article:modified_time" content={
    article.modifiedTime instanceof Date
      ? article.modifiedTime.toISOString()
      : article.modifiedTime
  } />
)}
{isArticle && article?.topic && (
  <meta property="article:section" content={article.topic} />
)}
{isArticle && article?.tags && article.tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
{isArticle && (
  <meta property="article:author" content="David Krug" />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<!-- og:title / og:description / og:image are used by Twitter automatically; no need to duplicate -->

<!-- Discovery -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="Dispatches from 701am" href="/rss.xml" />
{markdownAlternate && (
  <link rel="alternate" type="text/markdown" href={markdownAlternate} />
)}

<!-- JSON-LD graph -->
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
