---
// Pricing — $500 Narrative Attraction Session + $6,500 Engagement
interface Props { context?: 'home' | 'universities' | 'edtech' | 'agencies'; }
const { context = 'home' } = Astro.props;

const subs: Record<string, string> = {
  home: "Every engagement is scoped to deliver specific results. Start with a $500 Narrative Attraction Session — or book a discovery call to scope your campaign.",
  universities: "Narrative attraction for universities and colleges. Earned media, AI visibility, and social campaigns tied to enrollment goals.",
  edtech: "Category authority through earned media, AI visibility, and thought leadership for edtech companies and OPMs.",
  agencies: "White-label narrative attraction for your higher-ed clients. You keep the relationship; we deliver the results.",
};
const sub = subs[context] ?? subs.home;
---

<section class="band wrap" id="pricing">
  <div class="sec-head">
    <div class="sec-eyebrow">Pricing</div>
    <h2>Simple pricing. <em class="grad">No retainers.</em></h2>
    <p>{sub}</p>
  </div>
  <div class="pricing-cmp" style="max-width:760px;margin:0 auto">
    <div class="pcard">
      <div class="pc-head">
        <div class="pc-icon" style="background:var(--amber-soft);color:var(--amber-deep)"><i class="ti ti-calendar"></i></div>
        <div>
          <div class="pc-label">Narrative Attraction Session</div>
          <div class="pc-sub">90-minute strategy session</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt">$500</span>
        <span class="pc-per">one-time</span>
      </div>
      <ul class="pc-feat">
        <li><i class="ti ti-check"></i>90-minute strategy session with our team</li>
        <li><i class="ti ti-check"></i>Data audit — find the stories you're not telling</li>
        <li><i class="ti ti-check"></i>Reporter list for your top 3 angles</li>
        <li><i class="ti ti-check"></i>Credibility gap analysis</li>
        <li><i class="ti ti-check"></i>No obligation to continue</li>
      </ul>
      <a href="/contact" class="btn btn-soft btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book your session</a>
    </div>
    <div class="pcard pcard-701">
      <div class="pc-launch"><span class="pc-dot"></span>Most common engagement</div>
      <div class="pc-head">
        <div class="pc-icon pc-icon-grad"><i class="ti ti-rocket"></i></div>
        <div>
          <div class="pc-label" style="color:#fff">Narrative Attraction Engagement</div>
          <div class="pc-sub" style="color:var(--night-txt)">Up to 50 placements · Multi-channel</div>
        </div>
      </div>
      <div class="pc-price">
        <span class="pc-amt pc-amt-grad">$6,500</span>
        <span class="pc-per" style="color:var(--night-txt)">per engagement</span>
      </div>
      <ul class="pc-feat pc-feat-dark">
        <li><i class="ti ti-check"></i>Full campaign — research, narrative, pitches</li>
        <li><i class="ti ti-check"></i>Up to 50 placements in target outlets</li>
        <li><i class="ti ti-check"></i>AI citation tracking & optimization</li>
        <li><i class="ti ti-check"></i>Monthly reporting & strategy review</li>
        <li><i class="ti ti-check"></i>No long-term contract</li>
      </ul>
      <a href="/contact" class="btn btn-primary btn-lg" style="width:100%;margin-top:8px"><i class="ti ti-calendar"></i>Book a discovery call</a>
      <div class="pc-fine">Most engagements complete in 8–12 weeks.</div>
    </div>
  </div>
</section>