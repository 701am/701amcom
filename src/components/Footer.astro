---
import Mark from './Mark.astro';
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a class="footer-logo" href="/"><Mark /><span class="footer-name">701<span class="footer-am">am</span></span></a>
        <p class="footer-tagline">Narrative Attraction for Higher Education.</p>
        <div class="footer-socials">
          <a href="https://github.com/701am" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://x.com/701am" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com/company/701am" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer-cols">
        <div class="footer-col">
          <h5>Services</h5>
          <a href="/studio">Earned Media</a>
          <a href="/studio">AI Search Visibility</a>
          <a href="/studio">Social &amp; New Media</a>
          <a href="/studio">Thought Leadership</a>
        </div>
        <div class="footer-col">
          <h5>Company</h5>
          <a href="/about">About</a>
          <a href="/#contact">Contact</a>
          <a href="/blog">Founder Notes</a>
        </div>
        <div class="footer-col">
          <h5>Legal</h5>
          <a href="/privacy">Privacy</a>
          <a href="/agreement">Terms</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 701am &middot; filed at sunrise</span>
      <div class="footer-legal">
        <a href="/privacy">Privacy</a>
        <a href="/agreement">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
.footer{background:#2A1510;color:#B8A89C;border-top:1px solid #4A2820}
.footer-inner{max-width:1120px;margin:0 auto;padding:60px 28px 0}
.footer-top{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px}
.footer-logo{display:flex;align-items:center;gap:10px;text-decoration:none;margin-bottom:12px}
.footer-name{font-family:'Newsreader',Georgia,serif;font-size:20px;font-weight:500;letter-spacing:-.02em;color:#EDE4DC}
.footer-am{color:#DD5A38}
.footer-tagline{font-size:14px;color:#B8A89C;line-height:1.6;margin-bottom:20px}
.footer-socials{display:flex;gap:12px}
.footer-socials a{color:#B8A89C;transition:color .12s}
.footer-socials a:hover{color:#EDE4DC}
.footer-col h5{font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#DD5A38;margin-bottom:16px}
.footer-col{display:flex;flex-direction:column;gap:10px}
.footer-col a{font-size:14px;color:#B8A89C;text-decoration:none;transition:color .12s}
.footer-col a:hover{color:#EDE4DC}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding:30px 0;margin-top:40px;border-top:1px solid #4A2820;font-family:'JetBrains Mono',monospace;font-size:11px;color:#8B7A6E}
.footer-bottom a{color:#8B7A6E;text-decoration:none;transition:color .12s}
.footer-bottom a:hover{color:#EDE4DC}
.footer-legal{display:flex;gap:20px}
@media(max-width:768px){
  .footer-top{grid-template-columns:1fr;gap:32px}
  .footer-bottom{flex-direction:column;gap:12px;text-align:center}
  .footer-inner{padding:40px 28px 0}
}
</style>
