---
import Seal from './Seal.astro';
const year = new Date().getFullYear();
---
<footer class="foot">
  <div class="foot-inner">
    <div class="foot-top">
      <div class="foot-brand-col">
        <a class="foot-brand-link" href="/">
          <Seal size={36} ariaLabel="701am" />
          <span class="foot-brand-name">701am</span>
        </a>
        <p class="foot-tagline">Earned, <em>not bought.</em></p>
        <p class="foot-blurb">
          The morning record of an office that builds earned media for businesses that want to be remembered.
        </p>
      </div>

      <div class="foot-col">
        <h5>The office</h5>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="https://cal.com/davidkrug/discovery">Sunrise call</a>
      </div>
      <div class="foot-col">
        <h5>The record</h5>
        <a href="/notes">All dispatches</a>
        <a href="/legend-maker">The Scroll</a>
        <a href="/rss.xml">RSS feed</a>
      </div>
    </div>

    <div class="foot-rule"></div>

    <div class="foot-bottom">
      <p class="foot-copy">© {year} 701am · Filed at sunrise, in perpetuity</p>

      <ul class="foot-social" aria-label="Elsewhere">
        <li>
          <a href="mailto:dk@701am.com" aria-label="Email">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://github.com/701am" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="/rss.xml" aria-label="RSS">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <circle cx="5" cy="19" r="1.8"/>
              <path d="M4 11a9 9 0 0 1 9 9h-2.5a6.5 6.5 0 0 0-6.5-6.5z"/>
              <path d="M4 4a16 16 0 0 1 16 16h-2.5A13.5 13.5 0 0 0 4 6.5z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .foot {
    background: var(--paper);
    border-top: 2px solid var(--ink);
    padding: calc(var(--x1) + var(--x3)) var(--x1) var(--x1);
  }
  .foot-inner {
    max-width: var(--measure-wide);
    margin: 0 auto;
  }

  .foot-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: var(--x1);
    margin-bottom: var(--x1);
    align-items: start;
  }

  .foot-brand-col { max-width: 22rem; }
  .foot-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    margin-bottom: var(--x3);
  }
  .foot-brand-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.018em;
    font-feature-settings: "kern" 1, "onum" 1;
  }
  .foot-tagline {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 var(--x4);
  }
  .foot-tagline em {
    font-style: italic;
    color: var(--claret);
  }
  .foot-blurb {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-faint);
    margin: 0;
    font-style: italic;
    max-width: 28ch;
  }

  .foot-col h5 {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0 0 var(--x3);
    font-weight: 600;
  }
  .foot-col a {
    display: block;
    color: var(--ink);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    text-decoration: none;
    margin-bottom: var(--x4);
    transition: color 0.2s, padding 0.2s;
  }
  .foot-col a:hover {
    color: var(--claret);
    padding-left: 4px;
  }

  .foot-rule {
    height: 1px;
    background: var(--rule);
    margin: var(--x3) 0;
  }

  .foot-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--x3);
    flex-wrap: wrap;
  }
  .foot-copy {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    margin: 0;
  }

  .foot-social {
    display: flex;
    gap: var(--x4);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .foot-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--rule-strong);
    color: var(--ink);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .foot-social a:hover {
    border-color: var(--claret);
    color: var(--claret);
    background: var(--paper-soft);
  }

  @media (max-width: 720px) {
    .foot-top {
      grid-template-columns: 1fr 1fr;
      gap: var(--x2) var(--x1);
    }
    .foot-brand-col { grid-column: 1 / -1; }
    .foot-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
