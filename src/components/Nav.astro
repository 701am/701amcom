---
import Mark from './Mark.astro';
const { pathname } = Astro.url;
---
<nav id="nav">
  <div class="nv">
    <a class="lg" href="/">
      <Mark />
      <span class="nm">701<span class="am">am</span></span>
      <span class="tg">Narrative Attraction for Higher&nbsp;Ed</span>
    </a>
    <button class="tog" id="tog" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>
    </button>
    <div class="ln" id="ln">
      <a href="/#services">Services</a>
      <a href="/studio">Studio</a>
      <a href="/about">About</a>
      <a href="/#hp-price">Pricing</a>
      <a href="/#contact" class="cta">Book a call</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  const tog = document.getElementById('tog');
  if (tog) tog.addEventListener('click', (e) => { e.stopPropagation(); nav?.classList.toggle('menu-open'); });
  document.querySelectorAll('#ln a[href]').forEach((a) => a.addEventListener('click', () => nav?.classList.remove('menu-open')));
</script>
