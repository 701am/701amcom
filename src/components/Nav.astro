---
import Mark from './Mark.astro';
import { SITE } from '../config';
const { pathname } = Astro.url;
---
<div class="announce">
  <span class="ann-tag">$500 intro</span>
  <span>Narrative Attraction Session — 90 minutes, no obligation.</span>
  <a href="/contact">Book a discovery call <i class="ti ti-calendar"></i></a>
</div>

<nav id="nav">
  <div class="nav-in">
    <a class="logo" href="/">
      <Mark />
      <span class="wm">701<span class="am">am</span></span>
      <span class="tagline" set:html={SITE.tagline}></span>
    </a>

    <button class="navtoggle" id="navtoggle" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>
      </svg>
    </button>

    <div class="navlinks" id="navlinks">
      <a href="/#services" class={pathname === '/' ? 'active' : ''}>Services</a>
      <a href="/studio" class={pathname.startsWith('/studio') ? 'active' : ''}>Studio</a>
      <a href="/about" class={pathname.startsWith('/about') ? 'active' : ''}>About</a>
      <a href="/#pricing" class={pathname === '/' ? 'active' : ''}>Pricing</a>
    </div>

    <div class="nav-cta">
      <a href="/contact" class="btn btn-primary"><i class="ti ti-calendar"></i><span class="full">Book a discovery call</span><span class="short" style="display:none">Book call</span></a>
    </div>
  </div>
</nav>

<script>
  const navEl = document.getElementById('nav');
  const toggle = document.getElementById('navtoggle');
  // mobile hamburger
  toggle?.addEventListener('click', (e) => { e.stopPropagation(); navEl?.classList.toggle('menu-open'); });
  // close mobile menu when a real link is tapped
  document.querySelectorAll('#navlinks a[href]').forEach((a) =>
    a.addEventListener('click', () => navEl?.classList.remove('menu-open'))
  );
</script>