---
// The shared sunrise logomark. Render <Mark /> anywhere; the gradient defs
// are emitted once via <GradDefs /> in the Layout <body>.
interface Props { class?: string }
const { class: klass = '' } = Astro.props;
---
<svg class={`mark ${klass}`} viewBox="0 0 32 32" aria-label="701am">
  <rect width="32" height="32" rx="8" fill="#2A1510" />
  <g class="ray" stroke="url(#sunGrad)" stroke-width="2.4" stroke-linecap="round">
    <path d="M16 11 V6.5" /><path d="M9.7 12.7 L7.4 8.8" /><path d="M22.3 12.7 L24.6 8.8" />
  </g>
  <path d="M8.6 20.2 A7.4 7.4 0 0 1 23.4 20.2 Z" fill="url(#sunGrad)" />
  <rect x="5" y="21.4" width="22" height="2.6" rx="1.3" fill="url(#sunGrad)" />
</svg>
