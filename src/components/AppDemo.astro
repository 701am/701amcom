<script>
  (function() {
    const demo = document.currentScript?.closest('.app-demo');
    if (!demo) return;

    demo.querySelectorAll('.desk-mini-swarm .ad').forEach(function(d, i) {
      d.style.animationDelay = (i * 0.4) + 's';
    });

    const msgs = demo.querySelector('.rail-msgs');
    if (msgs) {
      requestAnimationFrame(function() { msgs.scrollTop = msgs.scrollHeight; });
    }

    var inp = demo.querySelector('.composer input');
    if (inp) {
      var placeholders = [
        'Ask the Desk, or describe what to launch…',
        'Compare LCSW position to last month',
        'Pull Slate inquiries that match best_of',
        'Draft a brief for the rural-MSW angle',
        'What journalists has Boston U been quoted in?',
        'Show me where we lost position this week'
      ];
      var pi = 0;
      setInterval(function() {
        if (document.activeElement === inp) return;
        pi = (pi + 1) % placeholders.length;
        inp.placeholder = placeholders[pi];
      }, 3800);

      var sendBtn = demo.querySelector('.composer .send');
      function handleSend() {
        if (inp.value.trim()) {
          appendUserMessage(inp.value.trim());
          inp.value = '';
          showTypingIndicator();
        }
      }
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); handleSend(); }
      });
      if (sendBtn) sendBtn.addEventListener('click', handleSend);
    }

    demo.querySelectorAll('.rail-suggest .chip').forEach(function(c) {
      c.addEventListener('click', function() {
        var t = c.textContent.trim();
        appendUserMessage(t);
        showTypingIndicator();
      });
    });

    function appendUserMessage(text) {
      if (!msgs) return;
      var now = new Date();
      var t = now.toLocaleTimeString([], {hour:'numeric', minute:'2-digit'});
      var wrap = document.createElement('div');
      wrap.className = 'msg user';
      var inner = document.createElement('div');
      var bubble = document.createElement('div');
      bubble.className = 'bubble';
      bubble.textContent = text;
      var meta = document.createElement('div');
      meta.className = 'meta';
      meta.textContent = t;
      inner.appendChild(bubble);
      inner.appendChild(meta);
      wrap.appendChild(inner);
      msgs.appendChild(wrap);
      msgs.scrollTop = msgs.scrollHeight;
    }

    function showTypingIndicator() {
      if (!msgs) return;
      var old = msgs.querySelector('.typing-indicator');
      if (old) old.remove();
      var ti = document.createElement('div');
      ti.className = 'typing-indicator';
      ti.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
      msgs.appendChild(ti);
      msgs.scrollTop = msgs.scrollHeight;
      setTimeout(function() {
        if (ti.parentNode) ti.remove();
        var ack = document.createElement('div');
        ack.className = 'msg agent';
        ack.innerHTML =
          '<div class="header"><span class="av"><i class="ti ti-sparkles"></i></span><span class="who">The Desk</span><span class="when">just now</span></div>' +
          '<div class="body">This is a mockup — in the real build, I\'d pull the relevant data and respond with a grounded answer plus the right artifact. Try the quick chips below for example flows.</div>' +
          '<div class="actions"><button class="act" title="Regenerate"><i class="ti ti-refresh"></i></button><button class="act" title="Copy"><i class="ti ti-copy"></i></button><button class="act" title="Helpful"><i class="ti ti-thumb-up"></i></button><button class="act" title="Not helpful"><i class="ti ti-thumb-down"></i></button></div>';
        msgs.appendChild(ack);
        msgs.scrollTop = msgs.scrollHeight;
      }, 1400);
    }

    demo.querySelectorAll('.msg.agent').forEach(function(m) {
      if (m.querySelector('.actions')) return;
      var actions = document.createElement('div');
      actions.className = 'actions';
      actions.innerHTML =
        '<button class="act" title="Regenerate"><i class="ti ti-refresh"></i></button>' +
        '<button class="act" title="Copy"><i class="ti ti-copy"></i></button>' +
        '<button class="act" title="Helpful"><i class="ti ti-thumb-up"></i></button>' +
        '<button class="act" title="Not helpful"><i class="ti ti-thumb-down"></i></button>';
      m.appendChild(actions);
    });
  })();
</script>

