// Emit once near the top of <body>. All <Mark /> instances reference #sunGrad.
---
<svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
  <linearGradient id="sunGrad" x1="3" y1="30" x2="29" y2="3" gradientUnits="userSpaceOnUse">
    <stop offset="0" stop-color="#F2A83F" /><stop offset=".4" stop-color="#EE6A4C" /><stop offset=".72" stop-color="#CE5286" /><stop offset="1" stop-color="#5A57C8" />
  </linearGradient>
  <radialGradient id="dawnGlow" cx="50%" cy="62%" r="60%">
    <stop offset="0" stop-color="#F2864C" stop-opacity=".7" /><stop offset="1" stop-color="#EE6A4C" stop-opacity="0" />
  </radialGradient>
</defs></svg>
