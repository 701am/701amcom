  <circle cx="30" cy="30" r="28" fill="none" stroke="#D4A853" stroke-width="0.8" />
  <circle cx="30" cy="30" r="24" fill="none" stroke="#D4A853" stroke-width="0.4" />
  <line x1="10" y1="38" x2="50" y2="38" stroke="#D4A853" stroke-width="0.6" />
  <path d="M 18 38 A 12 12 0 0 1 42 38 Z" fill="#D4A853" />
  <line x1="30" y1="14" x2="30" y2="20" stroke="#D4A853" stroke-width="0.8" />
  <line x1="18" y1="18" x2="22" y2="22" stroke="#D4A853" stroke-width="0.8" />
  <line x1="42" y1="18" x2="38" y2="22" stroke="#D4A853" stroke-width="0.8" />
