---
// Early-access modal. Submits to the Netlify "early-access" form via AJAX
// so the thanks-state UX is preserved (no page reload). Captured at build
// time via the hidden detection form in Layout.astro.
---
<div class="overlay" id="overlay">
  <div class="modal" id="modal">
    <button class="mclose" id="mclose" aria-label="Close"><i class="ti ti-x"></i></button>
    <div class="mbadge"><i class="ti ti-clock-hour-4"></i>Coming soon</div>
    <h3>The desk isn't open yet.</h3>
    <p>701am is still in the build. Leave your email and we'll bring you in with the first group of higher-ed teams.</p>
    <form class="mform" id="ea-form" name="early-access" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="early-access" />
      <input type="hidden" name="source" id="ea-source" value="site" />
      <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
      <input type="email" name="email" id="memail" placeholder="you@institution.edu" autocomplete="email" required />
      <button type="submit" id="msubmit">Join the list</button>
    </form>
    <div class="mfine" id="ea-fine">No spam · one note when the desk opens</div>
    <div class="mthanks">
      <div class="ok"><i class="ti ti-check"></i></div>
      <h3>You're on the list.</h3>
      <p>We'll be in touch when 701am opens. Filed at sunrise.</p>
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('nav');
  if (nav) addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 8), { passive: true });

  const overlay = document.getElementById('overlay');
  const modal = document.getElementById('modal');

  function openModal() {
    overlay?.classList.add('show');
    setTimeout(() => {
      const i = document.getElementById('memail') as HTMLInputElement | null;
      if (i && !modal?.classList.contains('done')) i.focus();
    }, 230);
  }
  function closeModal() {
    overlay?.classList.remove('show');
    setTimeout(() => modal?.classList.remove('done'), 200);
  }
  document.querySelectorAll('.js-soon').forEach((el) =>
    el.addEventListener('click', (e) => { e.preventDefault(); openModal(); })
  );
  document.getElementById('mclose')?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  function encode(data: Record<string, string>) {
    return Object.keys(data)
      .map((k) => encodeURIComponent(k) + '=' + encodeURIComponent(data[k]))
      .join('&');
  }

  const form = document.getElementById('ea-form') as HTMLFormElement | null;
  const fine = document.getElementById('ea-fine');
  const source = document.getElementById('ea-source') as HTMLInputElement | null;
  if (source) source.value = location.pathname === '/' ? 'home' : location.pathname.replace(/\//g, '') || 'home';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('msubmit') as HTMLButtonElement | null;
    const email = (document.getElementById('memail') as HTMLInputElement | null)?.value.trim() || '';
    if (!/.+@.+\..+/.test(email)) return;
    if (btn) { btn.disabled = true; btn.textContent = 'Joining…'; }
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: encode({ 'form-name': 'early-access', email, source: source?.value || 'site', 'bot-field': '' }),
      });
      modal?.classList.add('done');
    } catch {
      if (fine) { fine.textContent = "Something went wrong — email hello@701am.com and we'll add you."; (fine as HTMLElement).style.color = 'var(--coral-deep)'; }
      if (btn) { btn.disabled = false; btn.textContent = 'Join the list'; }
    }
  });
</script>
