---
// Search overlay — mounted once via BaseLayout. Hidden by default.
---
<div class="search-overlay" data-search-overlay aria-hidden="true">
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Search dispatches">
    <div class="search-head">
      <p class="search-eyebrow">
        <span class="search-rule"></span>
        Search the record
        <span class="search-rule"></span>
      </p>
      <button class="search-close" type="button" aria-label="Close search" data-search-close>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="search-input-wrap">
      <svg class="search-input-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="20" y1="20" x2="16.5" y2="16.5"></line>
      </svg>
      <input
        type="text"
        class="search-input"
        placeholder="Find a dispatch by title, topic, or word…"
        autocomplete="off"
        spellcheck="false"
        data-search-input
      />
    </div>

    <div class="search-hint">
      <kbd>/</kbd> to open · <kbd>esc</kbd> to close · <kbd>↑↓</kbd> to navigate · <kbd>↵</kbd> to open
    </div>

    <div class="search-results" data-search-results>
      <p class="search-prompt">Start typing to search the record.</p>
    </div>
  </div>
</div>

<style>
  .search-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding: 6vh var(--x3) var(--x3);
  }
  .search-overlay.is-open { display: flex; }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 14, 14, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
  }
  .search-panel {
    position: relative;
    width: 100%;
    max-width: 42rem;
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    box-shadow: 0 30px 80px rgba(15, 14, 14, 0.25);
    padding: var(--x2) var(--x2) var(--x3);
    max-height: 88vh;
    display: flex;
    flex-direction: column;
  }

  .search-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--x3);
  }
  .search-eyebrow {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.30em;
    color: var(--claret);
    text-transform: uppercase;
    margin: 0;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
  }
  .search-rule {
    display: inline-block;
    width: 20px; height: 1px;
    background: var(--claret);
  }

  .search-close {
    width: 30px;
    height: 30px;
    background: transparent;
    border: 1px solid var(--rule-strong);
    color: var(--ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: border-color 0.2s, color 0.2s;
  }
  .search-close:hover {
    border-color: var(--claret);
    color: var(--claret);
  }

  .search-input-wrap {
    position: relative;
    border-bottom: 1px solid var(--rule-strong);
    padding-bottom: var(--x4);
  }
  .search-input-icon {
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    color: var(--claret);
  }
  .search-input {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--ink);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: clamp(20px, 3vw, 28px);
    line-height: 1.3;
    padding: 4px 0 4px 36px;
    font-weight: 400;
  }
  .search-input::placeholder {
    color: var(--ink-fainter);
    font-style: italic;
  }

  .search-hint {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-fainter);
    margin-top: var(--x4);
    margin-bottom: var(--x3);
  }
  .search-hint kbd {
    display: inline-block;
    padding: 2px 6px;
    border: 1px solid var(--rule-strong);
    background: var(--paper-soft);
    border-radius: 2px;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: 10px;
    color: var(--claret);
    margin: 0 2px;
  }

  .search-results {
    overflow-y: auto;
    flex: 1;
    margin: 0 calc(-1 * var(--x2));
    padding: 0 var(--x2);
  }
  .search-prompt,
  .search-empty {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    color: var(--ink-faint);
    text-align: center;
    padding: var(--x2) 0;
    margin: 0;
  }
  .search-result {
    display: block;
    padding: var(--x4) var(--x3);
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s ease;
  }
  .search-result:last-child { border-bottom: none; }
  .search-result:hover,
  .search-result.is-active {
    background: var(--paper-soft);
  }
  .search-result-head {
    display: flex;
    align-items: baseline;
    gap: var(--x4);
    margin-bottom: 4px;
  }
  .search-result-num {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: var(--claret);
    font-variant-numeric: oldstyle-nums;
  }
  .search-result-topic {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.28em;
    color: var(--claret);
    text-transform: uppercase;
    font-weight: 600;
  }
  .search-result-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 19px;
    line-height: 1.25;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }
  .search-result-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1.45;
    color: var(--ink-faint);
    margin: 0;
  }
  .search-result mark {
    background: var(--rule-strong);
    color: var(--claret-dark);
    padding: 0 2px;
  }
</style>

<script>
  type SearchDoc = {
    slug: string;
    title: string;
    deck: string;
    number: number;
    topic: string;
    date: string;
    tags: string[];
  };

  let docs: SearchDoc[] | null = null;
  let activeIndex = -1;

  const overlay = document.querySelector('[data-search-overlay]') as HTMLElement | null;
  const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
  const results = document.querySelector('[data-search-results]') as HTMLElement | null;

  function isOpen(): boolean {
    return overlay?.classList.contains('is-open') ?? false;
  }
  function openOverlay() {
    if (!overlay) return;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (input) setTimeout(() => input.focus(), 50);
  }
  function closeOverlay() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (results) {
      results.innerHTML = '<p class="search-prompt">Start typing to search the record.</p>';
    }
    activeIndex = -1;
  }

  document.querySelectorAll('[data-open-search]').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); openOverlay(); });
  });
  document.querySelectorAll('[data-search-close]').forEach((btn) => {
    btn.addEventListener('click', (e) => { e.preventDefault(); closeOverlay(); });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen()) { e.preventDefault(); closeOverlay(); return; }
    if (e.key === '/' && !isOpen()
        && !(e.target instanceof HTMLInputElement)
        && !(e.target instanceof HTMLTextAreaElement)) {
      e.preventDefault();
      openOverlay();
    }
  });

  async function loadDocs(): Promise<SearchDoc[]> {
    if (docs) return docs;
    try {
      const res = await fetch('/search.json');
      if (!res.ok) return [];
      docs = (await res.json()) as SearchDoc[];
      return docs;
    } catch { return []; }
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }
  function highlight(text: string, query: string): string {
    const esc = escapeHtml(text);
    if (!query) return esc;
    const pattern = query.split(/\s+/).filter(Boolean)
      .map((q) => q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
    if (!pattern) return esc;
    return esc.replace(new RegExp(`(${pattern})`, 'gi'), '<mark>$1</mark>');
  }
  function score(doc: SearchDoc, terms: string[]): number {
    let s = 0;
    const title = doc.title.toLowerCase();
    const deck = doc.deck.toLowerCase();
    const topic = doc.topic.toLowerCase();
    const tagStr = doc.tags.join(' ').toLowerCase();
    for (const t of terms) {
      if (title.includes(t)) s += 10;
      if (topic.includes(t)) s += 6;
      if (deck.includes(t)) s += 4;
      if (tagStr.includes(t)) s += 3;
    }
    return s;
  }

  async function runSearch(q: string) {
    if (!results) return;
    if (!q.trim()) {
      results.innerHTML = '<p class="search-prompt">Start typing to search the record.</p>';
      activeIndex = -1;
      return;
    }
    const all = await loadDocs();
    if (!all || all.length === 0) {
      results.innerHTML = '<p class="search-empty">The record is empty.</p>';
      return;
    }
    const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
    const matched = all.map((d) => ({ doc: d, s: score(d, terms) }))
      .filter((m) => m.s > 0).sort((a, b) => b.s - a.s).slice(0, 12);

    if (matched.length === 0) {
      results.innerHTML = `<p class="search-empty">No dispatches match <em>${escapeHtml(q)}</em>.</p>`;
      activeIndex = -1;
      return;
    }
    results.innerHTML = matched.map(({ doc }) => {
      const num = String(doc.number).padStart(3, '0');
      return `<a class="search-result" href="/notes/${doc.slug}">
        <div class="search-result-head">
          <span class="search-result-num">№ ${num}</span>
          <span class="search-result-topic">${escapeHtml(doc.topic)}</span>
        </div>
        <h3 class="search-result-title">${highlight(doc.title, q)}</h3>
        <p class="search-result-deck">${highlight(doc.deck, q)}</p>
      </a>`;
    }).join('');
    activeIndex = -1;
  }

  if (input) input.addEventListener('input', () => runSearch(input.value));

  document.addEventListener('keydown', (e) => {
    if (!isOpen() || !results) return;
    const items = results.querySelectorAll<HTMLAnchorElement>('.search-result');
    if (items.length === 0) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      items.forEach((el, i) => el.classList.toggle('is-active', i === activeIndex));
      items[activeIndex].scrollIntoView({ block: 'nearest' });
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, 0);
      items.forEach((el, i) => el.classList.toggle('is-active', i === activeIndex));
      items[activeIndex].scrollIntoView({ block: 'nearest' });
    }
    if (e.key === 'Enter' && activeIndex >= 0) {
      e.preventDefault();
      items[activeIndex].click();
    }
  });
</script>
