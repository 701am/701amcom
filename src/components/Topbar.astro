---
import Seal from './Seal.astro';
---
<header class="topbar">
  <a class="brand" href="/">
    <Seal size={44} ariaLabel="701am" />
    <div class="brand-text">
      <div class="brand-name">701am</div>
      <div class="brand-tag">Office of Earned Media</div>
    </div>
  </a>
  <nav class="topbar-nav">
    <a class="nav-link" href="/notes">
      Dispatches
    </a>
    <a class="nav-pill" href="/#choose">
      Begin
      <span class="nav-pill-arrow" aria-hidden="true">→</span>
    </a>
  </nav>
</header>
<div class="bunting"></div>

<style>
  .topbar-nav {
    display: flex;
    gap: var(--x2);
    align-items: center;
  }

  /* Nav pill — promoted "Begin" CTA in the topbar */
  .nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--gold);
    color: var(--navy-deep);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--gold);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .nav-pill:hover {
    background: var(--cream-warm);
    border-color: var(--cream-warm);
    transform: translateY(-1px);
  }
  .nav-pill-arrow {
    font-size: 11px;
    transition: transform 0.2s ease;
  }
  .nav-pill:hover .nav-pill-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 540px) {
    .topbar-nav { gap: var(--x4); }
    .topbar-nav .nav-link {
      font-size: 14px;
    }
    .nav-pill {
      padding: 7px 12px;
      font-size: 11px;
      letter-spacing: 0.14em;
    }
  }
  @media (max-width: 380px) {
    .topbar-nav .nav-link { display: none; }
  }
</style>
