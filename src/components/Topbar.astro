---
import Seal from './Seal.astro';
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="topbar">
  <div class="topbar-grid">
    <a class="brand" href="/">
      <Seal size={36} ariaLabel="701am" />
      <div class="brand-name">701am</div>
    </a>

    <nav class="topbar-center" aria-label="Primary">
      <a class="nav-link" href="/" aria-current={isCurrent('/') ? 'page' : undefined}>Home</a>
      <a class="nav-link" href="/notes" aria-current={isCurrent('/notes') ? 'page' : undefined}>Dispatches</a>
      <a class="nav-link" href="/legend-maker" aria-current={isCurrent('/legend-maker') ? 'page' : undefined}>The Scroll</a>
      <a class="nav-link" href="/about" aria-current={isCurrent('/about') ? 'page' : undefined}>About</a>
      <a class="nav-link" href="/contact" aria-current={isCurrent('/contact') ? 'page' : undefined}>Contact</a>
    </nav>

    <div class="topbar-right">
      <button class="topbar-icon" type="button" aria-label="Search dispatches" data-open-search>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="20" y1="20" x2="16.5" y2="16.5"></line>
        </svg>
      </button>
      <a class="nav-pill" href="https://cal.com/davidkrug/discovery">
        Begin
        <span class="nav-pill-arrow" aria-hidden="true">→</span>
      </a>
      <button class="topbar-burger" type="button" aria-label="Open menu" aria-expanded="false" data-burger>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-drawer" data-mobile-drawer>
    <a class="mobile-link" href="/">Home</a>
    <a class="mobile-link" href="/notes">Dispatches</a>
    <a class="mobile-link" href="/legend-maker">The Scroll</a>
    <a class="mobile-link" href="/about">About</a>
    <a class="mobile-link" href="/contact">Contact</a>
  </div>
</header>
<div class="bunting"></div>

<style>
  .topbar-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--x3);
    max-width: 84rem;
    margin: 0 auto;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .brand-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.018em;
    line-height: 1;
    font-feature-settings: "kern" 1, "onum" 1;
  }

  .topbar-center {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-self: center;
  }
  .topbar-center .nav-link {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 6px 4px;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .topbar-center .nav-link:hover {
    color: var(--claret);
    border-bottom-color: var(--claret);
  }
  .topbar-center .nav-link[aria-current="page"] {
    color: var(--claret);
    border-bottom-color: var(--claret);
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    justify-self: end;
  }

  .topbar-icon {
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--rule-strong);
    color: var(--ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .topbar-icon:hover {
    border-color: var(--claret);
    color: var(--claret);
    background: var(--paper-soft);
  }

  .nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--ink-deep);
    color: var(--paper-soft);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--ink-deep);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .nav-pill:hover {
    background: var(--claret);
    border-color: var(--claret);
    transform: translateY(-1px);
  }
  .nav-pill-arrow {
    font-size: 11px;
    transition: transform 0.2s ease;
  }
  .nav-pill:hover .nav-pill-arrow {
    transform: translateX(2px);
  }

  .topbar-burger {
    display: none;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--rule-strong);
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .topbar-burger span {
    display: block;
    width: 16px;
    height: 1px;
    background: var(--ink);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .topbar-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .topbar-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .topbar-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  .mobile-drawer {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: var(--x3);
    display: none;
    flex-direction: column;
    gap: var(--x4);
  }
  .mobile-drawer.is-open { display: flex; }

  .mobile-link {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid var(--rule);
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: var(--claret); }

  @media (max-width: 980px) {
    .topbar-center { display: none; }
    .topbar-grid { grid-template-columns: 1fr auto; }
    .topbar-burger { display: flex; }
  }
  @media (max-width: 420px) {
    .topbar-right { gap: 0.45rem; }
    .nav-pill { display: none; }
  }
</style>

<script>
  // Mobile burger menu — search logic lives in SearchOverlay.astro
  const burger = document.querySelector('[data-burger]');
  const drawer = document.querySelector('[data-mobile-drawer]');
  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      drawer.classList.toggle('is-open', !expanded);
    });
  }
</script>
