---
import Seal from './Seal.astro';
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="topbar">
  <div class="topbar-grid">
    <a class="brand" href="/">
      <Seal size={40} ariaLabel="701am" />
      <div class="brand-name">701am</div>
    </a>

    <nav class="topbar-center" aria-label="Primary">
      <a class="nav-link" href="/" aria-current={isCurrent('/') ? 'page' : undefined}>Home</a>
      <a class="nav-link" href="/notes" aria-current={isCurrent('/notes') ? 'page' : undefined}>Dispatches</a>
      <a class="nav-link" href="/about" aria-current={isCurrent('/about') ? 'page' : undefined}>About</a>
      <a class="nav-link" href="/contact" aria-current={isCurrent('/contact') ? 'page' : undefined}>Contact</a>
    </nav>

    <div class="topbar-right">
      <button class="topbar-icon" type="button" aria-label="Search dispatches" data-open-search>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="20" y1="20" x2="16.5" y2="16.5"></line>
        </svg>
      </button>
      <a class="nav-pill" href="/contact">
        Begin
        <span class="nav-pill-arrow" aria-hidden="true">→</span>
      </a>
      <button class="topbar-burger" type="button" aria-label="Open menu" aria-expanded="false" data-burger>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-drawer" data-mobile-drawer hidden>
    <a class="mobile-link" href="/">Home</a>
    <a class="mobile-link" href="/notes">Dispatches</a>
    <a class="mobile-link" href="/about">About</a>
    <a class="mobile-link" href="/contact">Contact</a>
  </div>
</header>
<div class="bunting"></div>

<style>
  .topbar-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--x3);
    max-width: 84rem;
    margin: 0 auto;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--x4);
    text-decoration: none;
    color: inherit;
  }
  .brand-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 24px;
    font-weight: 500;
    color: var(--cream-warm);
    letter-spacing: -0.018em;
    line-height: 1;
    font-feature-settings: "kern" 1, "onum" 1;
  }

  .topbar-center {
    display: flex;
    gap: var(--x2);
    align-items: center;
    justify-self: center;
  }
  .topbar-center .nav-link {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    color: var(--cream);
    text-decoration: none;
    padding: 6px 4px;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .topbar-center .nav-link:hover {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
  }
  .topbar-center .nav-link[aria-current="page"] {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: var(--x4);
    justify-self: end;
  }

  .topbar-icon {
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(212, 168, 83, 0.3);
    color: var(--gold);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .topbar-icon:hover {
    border-color: var(--gold);
    color: var(--gold-light);
    background: rgba(212, 168, 83, 0.06);
  }

  .nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--gold);
    color: var(--navy-deep);
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--gold);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .nav-pill:hover {
    background: var(--cream-warm);
    border-color: var(--cream-warm);
    transform: translateY(-1px);
  }
  .nav-pill-arrow {
    font-size: 11px;
    transition: transform 0.2s ease;
  }
  .nav-pill:hover .nav-pill-arrow {
    transform: translateX(2px);
  }

  .topbar-burger {
    display: none;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(212, 168, 83, 0.3);
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .topbar-burger span {
    display: block;
    width: 16px;
    height: 1px;
    background: var(--gold);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .topbar-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .topbar-burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .topbar-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  .mobile-drawer {
    background: rgba(10, 22, 51, 0.98);
    border-top: 1px solid rgba(212, 168, 83, 0.2);
    padding: var(--x3);
    display: flex;
    flex-direction: column;
    gap: var(--x4);
  }
  .mobile-link {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 22px;
    color: var(--cream);
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid rgba(212, 168, 83, 0.15);
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover { color: var(--gold-light); }

  @media (max-width: 880px) {
    .topbar-center { display: none; }
    .topbar-grid { grid-template-columns: 1fr auto; }
    .topbar-burger { display: flex; }
  }
  @media (max-width: 420px) {
    .topbar-right { gap: var(--x5); }
    .nav-pill { display: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-open-search]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const overlay = document.querySelector('[data-search-overlay]');
      if (overlay instanceof HTMLElement) {
        overlay.removeAttribute('hidden');
        const input = overlay.querySelector('input');
        if (input instanceof HTMLInputElement) {
          setTimeout(() => input.focus(), 50);
        }
        document.body.style.overflow = 'hidden';
      }
    });
  });

  const burger = document.querySelector('[data-burger]');
  const drawer = document.querySelector('[data-mobile-drawer]');
  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        drawer.setAttribute('hidden', '');
      } else {
        drawer.removeAttribute('hidden');
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !(e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement)) {
      e.preventDefault();
      const btn = document.querySelector('[data-open-search]');
      if (btn instanceof HTMLButtonElement) btn.click();
    }
  });
</script>
