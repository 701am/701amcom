---
import Seal from './Seal.astro';

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Editorial datestamp — "SAT · 16 MAY 2026"
const today = new Date();
const days = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const dayLabel = days[today.getDay()];
const monthLabel = months[today.getMonth()];
const dateLabel = `${dayLabel} · ${today.getDate()} ${monthLabel} ${today.getFullYear()}`;
---
<header class="masthead">

  <!-- ════════════════════════════════════════════════════════════════
       TIER 1 — Brand + editorial datestamp
       ════════════════════════════════════════════════════════════════ -->
  <div class="mast-tier mast-tier--top">
    <div class="mast-inner">

      <a class="mast-brand" href="/" aria-label="701am — the morning record">
        <span class="mast-seal" aria-hidden="true">
          <Seal size={32} ariaLabel="" />
        </span>
        <span class="mast-brand-text">
          <span class="mast-brand-num">701</span><span class="mast-brand-suf">am</span>
        </span>
        <span class="mast-brand-tag" aria-hidden="true">The morning record</span>
      </a>

      <p class="mast-datestamp" aria-label="Today's edition">
        <span class="mast-ds-label">Filed at sunrise</span>
        <span class="mast-ds-dot" aria-hidden="true">·</span>
        <span class="mast-ds-date">{dateLabel}</span>
      </p>

      <p class="mast-datestamp-mobile" aria-label="Today's edition">
        {dateLabel}
      </p>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════
       TIER 2 — Primary nav + actions
       ════════════════════════════════════════════════════════════════ -->
  <div class="mast-tier mast-tier--nav">
    <div class="mast-inner">

      <nav class="mast-nav" aria-label="Primary">
        <a class="mast-link" href="/legend-maker" aria-current={isCurrent('/legend-maker') ? 'page' : undefined}>The Scroll</a>
        <span class="mast-sep" aria-hidden="true">·</span>
        <a class="mast-link" href="/notes" aria-current={isCurrent('/notes') ? 'page' : undefined}>Dispatches</a>
        <span class="mast-sep" aria-hidden="true">·</span>
        <a class="mast-link" href="/about" aria-current={isCurrent('/about') ? 'page' : undefined}>About</a>
        <span class="mast-sep" aria-hidden="true">·</span>

        <div class="mast-tools" data-mast-tools>
          <button
            class="mast-link mast-tools-trigger"
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            data-mast-tools-trigger
          >
            Tools
            <span class="mast-tools-caret" aria-hidden="true">▾</span>
          </button>
          <div class="mast-tools-menu" data-mast-tools-menu role="menu">
            <a class="mast-tools-item" role="menuitem" href="/build" aria-current={isCurrent('/build') ? 'page' : undefined}>
              <span class="mast-tools-item-star" aria-hidden="true">★</span>
              <span class="mast-tools-item-text">
                <span class="mast-tools-item-name">Build a Data Story</span>
                <span class="mast-tools-item-deck">A 3-minute workshop · One memo</span>
              </span>
            </a>
            <a class="mast-tools-item" role="menuitem" href="/skills" aria-current={isCurrent('/skills') ? 'page' : undefined}>
              <span class="mast-tools-item-star" aria-hidden="true">★</span>
              <span class="mast-tools-item-text">
                <span class="mast-tools-item-name">Earned Media Skills</span>
                <span class="mast-tools-item-deck">28 open-source skills · MIT licensed</span>
              </span>
            </a>
            <a class="mast-tools-item" role="menuitem" href="/kraken" aria-current={isCurrent('/kraken') ? 'page' : undefined}>
              <span class="mast-tools-item-star" aria-hidden="true">★</span>
              <span class="mast-tools-item-text">
                <span class="mast-tools-item-name">Kraken</span>
                <span class="mast-tools-item-deck">The Newsroom Prediction Engine</span>
              </span>
            </a>
            <a class="mast-tools-all" role="menuitem" href="/tools" aria-current={isCurrent('/tools') ? 'page' : undefined}>
              View the full tool gallery <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <button class="mast-search" type="button" aria-label="Search dispatches" data-open-search>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="20" y1="20" x2="16.5" y2="16.5"></line>
          </svg>
        </button>
      </nav>

      <div class="mast-actions">
        <a class="mast-cta" href="/discovery">
          Work with us
          <span class="mast-cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mast-mobile-cluster">
        <button class="mast-search-mobile" type="button" aria-label="Search" data-open-search>
          <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="20" y1="20" x2="16.5" y2="16.5"></line>
          </svg>
        </button>
        <button class="mast-burger" type="button" aria-label="Menu" aria-expanded="false" data-burger>
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════
       MOBILE DRAWER
       ════════════════════════════════════════════════════════════════ -->
  <div class="mast-drawer" data-mobile-drawer>
    <a class="mast-drawer-link" href="/legend-maker">The Scroll</a>
    <a class="mast-drawer-link" href="/notes">Dispatches</a>
    <a class="mast-drawer-link" href="/about">About</a>

    <div class="mast-drawer-rule">
      <span class="mast-drawer-rule-bar"></span>
      <span class="mast-drawer-rule-label">★ The tools</span>
      <span class="mast-drawer-rule-bar"></span>
    </div>

    <a class="mast-drawer-tool" href="/build">
      <span class="mast-drawer-tool-star" aria-hidden="true">★</span>
      <span class="mast-drawer-tool-text">
        <span class="mast-drawer-tool-name">Build a Data Story</span>
        <span class="mast-drawer-tool-deck">A 3-minute workshop</span>
      </span>
    </a>
    <a class="mast-drawer-tool" href="/skills">
      <span class="mast-drawer-tool-star" aria-hidden="true">★</span>
      <span class="mast-drawer-tool-text">
        <span class="mast-drawer-tool-name">Earned Media Skills</span>
        <span class="mast-drawer-tool-deck">28 open-source skills</span>
      </span>
    </a>
    <a class="mast-drawer-tool" href="/kraken">
      <span class="mast-drawer-tool-star" aria-hidden="true">★</span>
      <span class="mast-drawer-tool-text">
        <span class="mast-drawer-tool-name">Kraken</span>
        <span class="mast-drawer-tool-deck">The Newsroom Prediction Engine</span>
      </span>
    </a>
    <a class="mast-drawer-all" href="/tools">
      View the full tool gallery <span aria-hidden="true">→</span>
    </a>

    <a class="mast-drawer-cta" href="/discovery">
      Work with us <span aria-hidden="true">→</span>
    </a>
  </div>

</header>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     MASTHEAD — two tiers, divided by a 1px claret hairline.
     Tier 1: brand + editorial datestamp (~58px)
     Tier 2: nav + actions              (~48px)
     ═══════════════════════════════════════════════════════════════════ */
  .masthead {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(252, 228, 208, 0.96);
    backdrop-filter: blur(14px) saturate(115%);
    -webkit-backdrop-filter: blur(14px) saturate(115%);
    border-bottom: 1px solid var(--rule);
    font-family: 'Instrument Sans', sans-serif;
  }
  .mast-inner {
    max-width: 88rem;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--x3);
  }

  /* ─────────────── TIER 1 ─────────────── */
  .mast-tier--top {
    border-bottom: 1px solid var(--claret);
    box-shadow: 0 1px 0 var(--paper-deep);  /* subtle paper-fold under the claret rule */
  }
  .mast-tier--top .mast-inner {
    min-height: 58px;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  /* Brand block */
  .mast-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
  }
  .mast-seal {
    display: inline-flex;
    color: var(--ink);
  }
  .mast-brand-text {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 30px;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.025em;
    font-feature-settings: "kern" 1, "onum" 1;
    display: inline-flex;
    align-items: baseline;
  }
  .mast-brand-num {
    font-variant-numeric: oldstyle-nums;
    color: var(--ink);
  }
  .mast-brand-suf {
    font-style: italic;
    font-weight: 400;
    color: var(--claret);
    letter-spacing: -0.005em;
  }
  .mast-brand-tag {
    margin-left: 12px;
    padding-left: 14px;
    border-left: 1px solid var(--rule-strong);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1;
    white-space: nowrap;
  }

  /* Editorial datestamp */
  .mast-datestamp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    color: var(--ink-soft);
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  .mast-ds-label {
    color: var(--claret);
    font-weight: 600;
  }
  .mast-ds-dot {
    color: var(--rule-strong);
    font-size: 14px;
    line-height: 1;
    margin: 0 -2px;
  }
  .mast-ds-date {
    color: var(--ink);
  }
  .mast-datestamp-mobile {
    display: none;
  }

  /* ─────────────── TIER 2 ─────────────── */
  .mast-tier--nav .mast-inner {
    min-height: 48px;
  }

  /* Nav links */
  .mast-nav {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    line-height: 1;
  }
  .mast-link {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0;
    padding: 8px 0;
    position: relative;
    transition: color 0.2s ease;
    line-height: 1;
  }
  .mast-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 4px;
    height: 1px;
    background: var(--claret);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mast-link:hover { color: var(--claret); }
  .mast-link:hover::after { transform: scaleX(1); }
  .mast-link[aria-current="page"] { color: var(--claret); }
  .mast-link[aria-current="page"]::after { transform: scaleX(1); }

  .mast-sep {
    color: var(--rule-strong);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1;
    user-select: none;
  }

  .mast-search {
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    color: var(--ink-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin-left: 8px;
    transition: color 0.2s ease;
  }
  .mast-search:hover { color: var(--claret); }

  /* ─────────── TOOLS DROPDOWN ─────────── */
  .mast-tools {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .mast-tools-trigger {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    position: relative;
  }
  .mast-tools-caret {
    font-size: 9px;
    color: var(--claret);
    transition: transform 0.25s ease;
    line-height: 1;
    margin-top: 1px;
  }
  .mast-tools[data-open="true"] .mast-tools-caret {
    transform: rotate(180deg);
  }
  .mast-tools[data-open="true"] .mast-tools-trigger { color: var(--claret); }
  .mast-tools[data-open="true"] .mast-tools-trigger::after { transform: scaleX(1); }

  .mast-tools-menu {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    width: 320px;
    background: var(--paper-soft);
    border: 1px solid var(--ink);
    border-top: 3px solid var(--claret);
    box-shadow:
      0 22px 48px rgba(15, 14, 14, 0.18),
      0 4px 12px rgba(15, 14, 14, 0.08);
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s linear 0.3s;
    z-index: 60;
  }
  .mast-tools-menu::before {
    content: "";
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: var(--paper-soft);
    border-top: 1px solid var(--claret);
    border-left: 1px solid var(--claret);
  }
  .mast-tools[data-open="true"] .mast-tools-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0s linear 0s;
  }

  .mast-tools-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.2s ease;
    border-bottom: 1px solid var(--rule);
  }
  .mast-tools-item:last-child { border-bottom: none; }
  .mast-tools-item:hover {
    background: var(--paper);
  }
  .mast-tools-item-star {
    color: var(--claret);
    font-size: 11px;
    line-height: 1.4;
    flex-shrink: 0;
    margin-top: 3px;
    transition: transform 0.3s ease;
  }
  .mast-tools-item:hover .mast-tools-item-star {
    transform: rotate(72deg);
  }
  .mast-tools-item-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.3;
  }
  .mast-tools-item-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    transition: color 0.2s ease;
  }
  .mast-tools-item:hover .mast-tools-item-name { color: var(--claret); }
  .mast-tools-item-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 12.5px;
    color: var(--ink-fainter);
  }
  .mast-tools-item[aria-current="page"] .mast-tools-item-name {
    color: var(--claret);
  }
  .mast-tools-all {
    display: block;
    padding: 10px 12px;
    margin-top: 6px;
    text-align: center;
    border-top: 1px solid var(--rule);
    text-decoration: none;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-soft);
    transition: color 0.2s ease, background 0.2s ease;
  }
  .mast-tools-all:hover {
    color: var(--claret);
    background: var(--paper);
  }

  /* Actions cluster */
  .mast-actions {
    display: inline-flex;
    align-items: center;
    gap: 18px;
  }

  /* CTA — bordered */
  .mast-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    text-decoration: none;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    line-height: 1;
  }
  .mast-cta:hover {
    background: var(--ink-deep);
    color: var(--paper-soft);
    border-color: var(--ink-deep);
  }
  .mast-cta-arrow {
    font-size: 13px;
    transition: transform 0.25s ease;
  }
  .mast-cta:hover .mast-cta-arrow { transform: translateX(2px); }

  /* Mobile cluster — hidden until breakpoint */
  .mast-mobile-cluster {
    display: none;
    align-items: center;
    gap: 6px;
  }
  .mast-search-mobile,
  .mast-burger {
    width: 34px;
    height: 34px;
    background: transparent;
    border: none;
    color: var(--ink);
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .mast-search-mobile:hover { color: var(--claret); }
  .mast-burger {
    flex-direction: column;
    gap: 4px;
  }
  .mast-burger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .mast-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .mast-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .mast-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  /* ─────────────── MOBILE DRAWER ─────────────── */
  .mast-drawer {
    display: none;
    flex-direction: column;
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: var(--x3) 32px var(--x2);
  }
  .mast-drawer.is-open { display: flex; }

  .mast-drawer-link {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
  }
  .mast-drawer-link:hover { color: var(--claret); }

  .mast-drawer-rule {
    display: flex;
    align-items: center;
    gap: var(--x4);
    margin: var(--x3) 0 var(--x4);
  }
  .mast-drawer-rule-bar {
    flex: 1;
    height: 1px;
    background: var(--rule-strong);
  }
  .mast-drawer-rule-label {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--claret);
    font-weight: 600;
    white-space: nowrap;
  }

  .mast-drawer-tool {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 0;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
  }
  .mast-drawer-tool:last-of-type { border-bottom: none; margin-bottom: var(--x4); }
  .mast-drawer-tool-star {
    color: var(--claret);
    font-size: 14px;
    margin-top: 3px;
  }
  .mast-drawer-tool-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .mast-drawer-tool-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
  }
  .mast-drawer-tool-deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 13px;
    color: var(--ink-fainter);
  }

  .mast-drawer-all {
    display: block;
    padding: 12px 0;
    text-align: center;
    text-decoration: none;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--x4);
  }
  .mast-drawer-all:hover { color: var(--claret); }

  .mast-drawer-cta {
    margin-top: var(--x4);
    padding: 14px 18px;
    border: 1px solid var(--ink);
    text-align: center;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .mast-drawer-cta:hover {
    background: var(--ink-deep);
    color: var(--paper-soft);
    border-color: var(--ink-deep);
  }

  /* ═══════════════════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════════════════ */

  /* Hide the italic tagline a bit earlier so brand stays clean */
  @media (max-width: 1180px) {
    .mast-brand-tag { display: none; }
  }

  /* Mobile: collapse the nav into a burger, datestamp shrinks */
  @media (max-width: 960px) {
    .mast-inner { padding: 0 20px; }
    .mast-tier--top .mast-inner { min-height: 50px; }
    .mast-tier--nav .mast-inner { min-height: 50px; }

    .mast-brand-text { font-size: 24px; }
    .mast-datestamp { display: none; }
    .mast-datestamp-mobile {
      display: inline-block;
      margin: 0;
      font-family: 'Instrument Sans', sans-serif;
      font-size: 9.5px;
      letter-spacing: 0.20em;
      color: var(--ink-soft);
      text-transform: uppercase;
      white-space: nowrap;
    }

    .mast-nav { display: none; }
    .mast-actions { display: none; }
    .mast-mobile-cluster { display: inline-flex; }
  }

  @media (max-width: 480px) {
    .mast-inner { padding: 0 16px; }
    .mast-brand-text { font-size: 22px; }
    .mast-datestamp-mobile { font-size: 9px; letter-spacing: 0.16em; }
    .mast-drawer { padding: var(--x3) 16px var(--x2); }
  }
</style>

<script>
  // Mobile burger
  const burger = document.querySelector('[data-burger]');
  const drawer = document.querySelector('[data-mobile-drawer]');
  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      drawer.classList.toggle('is-open', !expanded);
    });
  }

  // Tools dropdown
  const tools = document.querySelector('[data-mast-tools]');
  const toolsTrigger = document.querySelector('[data-mast-tools-trigger]');
  const toolsMenu = document.querySelector('[data-mast-tools-menu]');

  if (tools && toolsTrigger && toolsMenu) {
    function openTools() {
      tools.setAttribute('data-open', 'true');
      toolsTrigger.setAttribute('aria-expanded', 'true');
    }
    function closeTools() {
      tools.removeAttribute('data-open');
      toolsTrigger.setAttribute('aria-expanded', 'false');
    }
    function toggleTools() {
      if (tools.getAttribute('data-open') === 'true') closeTools();
      else openTools();
    }

    toolsTrigger.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggleTools();
    });

    // Open on hover for desktop discoverability
    let hoverTimer;
    tools.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimer);
      if (window.matchMedia('(min-width: 961px)').matches) openTools();
    });
    tools.addEventListener('mouseleave', () => {
      hoverTimer = setTimeout(closeTools, 180);
    });

    // Outside click closes
    document.addEventListener('click', (e) => {
      if (tools.getAttribute('data-open') !== 'true') return;
      if (tools.contains(e.target as Node)) return;
      closeTools();
    });

    // Escape closes
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && tools.getAttribute('data-open') === 'true') {
        closeTools();
        (toolsTrigger as HTMLElement).focus();
      }
    });
  }
</script>
