---
const testimonials = [
  {
    quote: "David is one of the brightest minds I know out there on the web, and I've worked with many. Work with him whenever you can!",
    name: "Brian Wallace",
    role: "Founder, NowSourcing – Infographic Expert | Featured: NYT, Forbes, Mashable",
    initial: "B",
  },
  {
    quote: "David's expertise in SEO is incredible. He has the ability to jump between SEO strategies and tactics to drive substantial growth while managing and leading high performance teams. He's an impactful (and essential) person to have on your growth team!",
    name: "Meredith Kokos",
    role: "AI-Driven SVP of Growth | Scaling PE & VC-Backed B2C/DTC & B2B Companies",
    initial: "M",
  },
  {
    quote: "I have never learned so much from someone I worked with. He was always an inspiration to me. He's the hardest worker I have ever met. No idea how he finds the time to accomplish all he does in a day. Couldn't have more respect for him.",
    name: "Sara Routhier",
    role: "Senior Director of Content at Quote.com",
    initial: "S",
  },
];
---
<section class="section section-navy testimonials-section">
  <div class="container-wide">
    <div class="section-label">
      <div class="label-bar"></div>
      <div class="label-text">§ — In their words</div>
      <div class="label-bar"></div>
    </div>
    <h2 class="h2">What people say <em>about David.</em></h2>
    <p class="body body-center" style="margin-bottom: var(--x1);">
      Recommendations from the people who have worked alongside David — colleagues, editors, and founders. Real names, real titles, words unchanged.
    </p>

    <div class="testimonials-grid">
      {testimonials.map((t) => (
        <figure class="testimonial">
          <span class="testimonial-mark" aria-hidden="true">“</span>
          <blockquote class="testimonial-quote">
            {t.quote}
          </blockquote>
          <figcaption class="testimonial-attr">
            <span class="testimonial-avatar" aria-hidden="true">{t.initial}</span>
            <div>
              <div class="testimonial-name">— {t.name}</div>
              <div class="testimonial-role">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: var(--x1);
    border-top: 1px solid var(--rule);
  }
  .testimonial {
    margin: 0;
    padding: var(--x2) var(--x3);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .testimonial:last-child { border-right: none; }
  .testimonial-mark {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 64px;
    line-height: 0.6;
    color: var(--claret);
    margin-bottom: var(--x4);
    font-variant-numeric: oldstyle-nums;
  }
  .testimonial-quote {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 var(--x3);
    flex: 1;
    text-wrap: pretty;
  }
  .testimonial-attr {
    display: flex;
    align-items: center;
    gap: var(--x4);
    padding-top: var(--x3);
    border-top: 1px dotted var(--rule-strong);
  }
  .testimonial-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--claret) 0%, var(--coral) 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    color: var(--ink);
    flex-shrink: 0;
  }
  .testimonial-name {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 15px;
    color: var(--ink);
    line-height: 1.2;
  }
  .testimonial-role {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--ink-fainter);
    text-transform: uppercase;
    margin-top: 3px;
  }

  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: 1fr; }
    .testimonial { border-right: none; }
  }
</style>
