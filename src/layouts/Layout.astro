---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Modal from '../components/Modal.astro';
import GradDefs from '../components/GradDefs.astro';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}
const { title, description = SITE.description, ogType = 'website' } = Astro.props;
const fullTitle = title ? `701am — ${title}` : '701am — The earned-media engine for Higher Education';
const canonical = new URL(Astro.url.pathname, SITE.url).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/assets/logo-mark.svg" />
  <link rel="alternate" type="application/rss+xml" title="701am · Founder Notes" href="/rss.xml" />
  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="701am" />
  <meta name="twitter:card" content="summary_large_image" />
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Inter:wght@400;450;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/3.31.0/tabler-icons.min.css" />
</head>
<body>
  <GradDefs />

  <!--
    Netlify Forms detection stubs. Netlify's build bot parses these static forms
    so the named forms exist; the visible UI submits to them via fetch (AJAX),
    keeping the modal/thanks UX. Do not remove.
  -->
  <form name="early-access" netlify netlify-honeypot="bot-field" hidden>
    <input type="email" name="email" />
    <input type="text" name="source" />
    <input type="text" name="bot-field" />
  </form>
  <form name="newsletter" netlify netlify-honeypot="bot-field" hidden>
    <input type="email" name="email" />
    <input type="text" name="source" />
    <input type="text" name="bot-field" />
  </form>
  <form name="contact" netlify netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="text" name="org" />
    <input type="text" name="segment" />
    <textarea name="message"></textarea>
    <input type="text" name="bot-field" />
  </form>

  <Nav />
  <slot />
  <Footer />
  <Modal />
</body>
</html>
